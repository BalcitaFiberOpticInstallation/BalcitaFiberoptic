window,(window._walkmeWebpackJP=window._walkmeWebpackJP||[]).push([[70],{1443:function(e){e.exports=JSON.parse('{"Add Launcher":"Dodaj Launcher","Icon and Name":"Ikona i nazwa","Name already exists":"Ta nazwa już istnieje","Name your action...":"Nazwij swoje działanie...","Prompt":"Polecenie","Type what you want the AI engine to do for you...":"Wpisz, co ma dla Ciebie zrobić model AI...","Visibility settings":"Ustawienia widoczności","Display the action only when the":"Wyświetl to działanie tylko wtedy, gdy","highlighted text":"wyróżniony tekst","webpage":"strona internetowa","input":"wejście","is":"jest","isn\'t":"nie jest","optional":"opcjonalne","Type the criteria for showing the action":"Wpisz kryteria wyświetlania działania","a question":"pytanie","a code snippet":"fragment kodu","in Spanish and all caps":"w języku hiszpańskim i pisany wielkimi literami","a non english text":"tekst nie po angielsku","a report":"raport","a form":"formularz","a data table":"tabela danych","an email":"adres e-mail","empty":"pusty","incomplete":"niekompletny","Show on all apps":"Pokaż we wszystkich aplikacjach","Show on this app only":"Pokaż tylko w tej aplikacji","Use this setting when the action is relevant only to the current app you\'re in":"Użyj tego ustawienia, gdy działanie dotyczy tylko bieżącej aplikacji","Use this setting when the action is relevant for any website or app":"Użyj tego ustawienia, gdy działanie jest istotne dla dowolnej witryny lub aplikacji","New Action":"Nowe działanie","Edit Action":"Edytuj działanie","Delete Action":"Usuń działanie","Deleted custom actions cannot be restored.":"Nie można przywrócić usuniętych niestandardowych działań.","Delete Custom Action":"Usuń niestandardowe działanie","Are you sure you want to delete this custom action?":"Czy na pewno chcesz usunąć to niestandardowe działanie?","Import":"Importuj","Export":"Eksportuj","Share your action with coworkers":"Podziel się swoim działaniem ze współpracownikami","The action couldn\'t be uploaded. The file seems to be corrupted or incomplete. Please ask your coworker to export the action again and import the new action.":"Nie udało się przesłać tego działania. Plik wydaje się być uszkodzony lub niekompletny. Poproś współpracownika o ponowne wyeksportowanie tego działania akcji i zaimportowanie nowego działania.","Cancel":"Anuluj","Close":"Zamknij","Save":"Zapisz","Save Changes":"Zapisz zmiany","Save and Export":"Zapisz i wyeksportuj","Pin":"Przypnij","Unpin":"Odepnij","Create First Action":"Ustaw pierwsze dział","Quick Actions Menu":"Menu szybkich działań","Back":"Wstecz","Add new action":"Dodaj nowe działanie","Default action cannot be edited":"Nie można edytować domyślnego działania","Edit":"Edytuj","Note: Action Bar can display up to 5 actions":"Uwaga: pasek działań może wyświetlać maksymalnie 5 działań","Something went wrong":"Coś poszło nie tak","Content generating has failed. Please try again later":"Nie udało się wygenerować treści. Spróbuj ponownie później","No relevant reference found":"Nie znaleziono odpowiedniego odniesienia","Stop generating":"Zatrzymaj generowanie","Copy":"Kopiuj","Copied":"Skopiowano","Copy Prompt":"Skopiuj prompt","Prompt copied":"Prompt skopiowany","Maximize":"Maksymalizuj","Minimize":"Minimalizuj","Helpful":"Przydatne","Unhelpful":"Nieprzydatne","Save to Memory":"Zapisz do pamięci","Saved to Memory":"Zapisane w pamięci","AI-generated content may be incorrect":"Treści wygenerowane przez AI mogą być nieprawidłowe","Refine":"Doprecyzuj","Refine...":"Doprecyzuj...","Refine (eg. add details about...)":"Doprecyzuj (np. dodaj szczegóły o...)","Generate":"Wygeneruj","Regenerate":"Regeneruj","Insert":"Wstaw","Insert Below":"Wstaw poniżej","Select tone":"Wybierz ton","Select format":"Wybierz format","Select language":"Wybierz język","Go Back":"Wróć","Replace":"Zastąp","New draft":"Nowy projekt","Save prompt":"Zapisz prompt","Don\'t show this message again":"Nie pokazuj więcej tej wiadomości","Be sure to review carefully before replacing":"Dokonaj dokładnego przeglądu przed zastąpieniem","Be sure to review carefully before inserting":"Dokonaj dokładnego przeglądu przed wstawieniem","Text options":"Opcje tekstu","Working on it...":"Przetwarzanie...","The text used for this response":"Tekst użyty w tej odpowiedzi","Share your ideas or ask me anything, and I\'ll generate a first draft to help you out...":"Podziel się swoimi pomysłami lub zapytaj mnie o cokolwiek, a ja wygeneruję pierwszy szkic, który Ci pomoże...","Share your ideas for editing the selected text, or ask me anything about it...":"Podziel się swoimi pomysłami na edycję wybranego tekstu lub zapytaj mnie o coś na jego temat...","Share your ideas on what you\'d like to write, and I\'ll help you get started...":"Podziel się swoimi pomysłami na temat tego, co chciałbyś napisać, a ja pomogę Ci zacząć...","Share your ideas about the selected text, and I\'ll help with editing or writing something new...":"Podziel się swoimi pomysłami na temat wybranego tekstu, a ja pomogę Ci go edytować lub napisać coś nowego...","Share your ideas about the text you focused on, and I\'ll help with editing or writing something new...":"Podziel się swoimi pomysłami na temat tekstu, którym się zajumjesz a ja pomogę Ci go edytować lub napisać coś nowego...","Work with:":"Współpracuj z:","Remove":"Usuń","Open menu":"Otwórz menu","Open Joule":"Otwórz Joule","Help me write":"Pomóż mi pisać","See more actions":"Zobacz więcej działań","Show actions":"Pokaż działania","Hide actions":"Ukryj działania","Actions are kept hidden, Expand to view them":"Działania są ukryte, rozwiń, aby je wyświetlić","Neutral":"Neutralny","Professional":"Profesjonalny","Casual":"Swobodny","Concise":"Zwięzły","Free Text":"Tekst swobodny","Email":"Adres e-mail","Paragraph":"Akapit","Bullet List":"Lista punktów","Numbered List":"Lista numerowana","Included context":"Dołączony kontekst","This whole page":"Cała bieżąca strona","Change tone":"Zmień ton","Sound neutral":"Neutralne brzmienie","Sound professional":"Profesjonalne brzmienie","Sound casual":"Swobodne brzmienie","Sound concise":"Zwięzłe brzmienie","Sound engaging":"Angażujące brzmienie","Sound enthusiastic":"Entuzjastyczne brzmienie","Sound confident":"Pewne brzmienie","Translate":"Przetłumacz","English":"Angielski","French":"Francuski","German":"Niemiecki","Spanish":"Hiszpański","Japanese":"Japoński","Hebrew":"Hebrajski","Korean":"Koreański","Chinese":"Chiński","Portuguese":"Portugalski","Vietnamese":"Wietnamski","Greek":"Grecki","Polish":"Polski","Change format":"Zmień format","Elaborate":"Rozwiń","Shorten":"Skróć","Retry":"Spróbuj ponownie","Auto Length":"Długość automatyczna","Shorter":"Krótki","Longer":"Wypracowany","AI analyzes the user input to set the length":"AI analizuje dane wprowadzone przez użytkownika, aby ustawić długość","Icons":"Ikony","Settings":"Ustawienia","Next":"Następny","Ok, got it":"Ok, rozumiem","Done":"Wykonane","Introducing the AI Action Bar":"Pasek działań AI – wprowadzenie","Discover the power of your AI copilot to get the next best actions in the flow of your work.":"Odkryj potencjał swojego współpracownika AI, aby wykonywać kolejne najlepsze działania w toku pracy.","Upgraded Menu":"Ulepszone menu","Open the menu to get instant answers to your questions with our conversational AI Chat":"Otwórz menu, aby uzyskać natychmiastowe odpowiedzi na pytania dzięki naszemu konwersacyjnemu czatu AI","Draft content from scratch with the help of AI":"Projektuj treści od podstaw za pomocą AI","Highlighted text tools":"Podświetlone narzędzia tekstowe","Highlight text to use AI reading and writing tools, including text summarization, translation, and writing editing tools.":"Podświetl tekst, aby korzystać z narzędzi do odczytu i zapisu AI, w tym narzędzi do podsumowywania, tłumaczenia i edycji tekstu.","Create your own actions":"Twórz własne działania","Create and save your own personalized prompts for fast reuse whenever text is highlighted on screen.":"Twórz i zapisuj własne spersonalizowane polecenia, aby wygodnie użyć ich ponownie za każdym razem, gdy tekst jest podświetlony na ekranie.","Workflow tools":"Narzędzia do zarządzania przepływem pracy","Get workflow suggestions from your organization in the right place at the right time.":"Uzyskaj sugestie dotyczące procesów pracy z organizacji we właściwym miejscu i we właściwym czasie.","Text tools":"Narzędzia tekstowe","More actions":"Więcej działań","Create new action":"Utwórz nowe działanie","Edit highlighted text with AI":"Edytuj wyróżniony tekst za pomocą AI","Create and save your own custom prompts":"Twórz i zapisuj własne niestandardowe polecenia","My actions":"Moje działania","System actions":"Działania systemowe","Contextual Action Bar":"Pasek działań kontekstowych","More Settings":"Więcej ustawień","Text Tools Display":"Wyświetlanie narzędzi tekstowych","Some actions, made by your organization will still appear in the action bar":"Niektóre działania stworzone przez organizację nadal będą widoczne na pasku działań","Hide always":"Ukryj zawsze","Hide on this site":"Ukryj na tej stronie","Learn more":"Dowiedz się więcej","My custom actions":"Moje niestandardowe działania","My actions:":"Moje działania:","All apps":"Wszystkie aplikacje","Location-specific":"Specyficzne dla lokalizacji","Replay onboarding guide":"Odtwórz samouczek","Smart highlights":"Inteligentne wyróżnienia","Get instant details on people and customers by hovering over highlighted names":"Najedź kursorem na podświetlone nazwy i uzyskaj natychmiastowe informacje o osobach i klientach","Tone":"Ton","Format":"Format","Length":"Długość","Language":"Język","Suggestions":"Sugestie","Tools":"Narzędzia","Add custom action":"Dodaj niestandardowe działanie","Stop listening":"Przestań słuchać","Use microphone":"Użyj mikrofonu","I\'m listening...":"Słucham...","Microphone disabled. Please enable it to be heard":"Mikrofon wyłączony. Włącz go, by uruchomić funkcje dźwiękowe","Please enable mic to be heard":"Włącz mikrofon, by uruchomić funkcje dźwiękowe","Hide from bar":"Ukryj na pasku","Add to bar":"Dodaj do paska","Delete":"Usuń","Refresh":"Odśwież","Rephrase":"Przeformułuj","No more space in your bar":"Nie ma już miejsca na pasku","No actions available":"Brak dostępnych działań","Got It":"Rozumiem","Don’t show again":"Nie pokazuj ponownie","We noticed you use this action often":"Zauważyliśmy, że często używasz tego działania","To quickly reuse, right-click the action and add to the bar. Undo anytime.":"Aby szybko wykorzystać to działanie, kliknij prawym przyciskiem myszy i dodaj ją do paska. Anuluj w dowolnym momencie.","Find your custom action here":"Znajdź tutaj swoją niestandardowe działanie","Right-click the action to edit, delete, or hide from the bar.":"Kliknij działanie prawym przyciskiem myszy, aby je edytować, usunąć lub ukryć z paska.","You can find your hidden action here.":"Tutaj znajdziesz swoje ukryte działanie.","Right click and select ‘Hide from bar’ to undo":"Kliknij prawym przyciskiem i wybierz „Ukryj z paska”, aby cofnąć","Right-click the action to edit or delete.":"Kliknij prawym przyciskiem myszy działanie, które chcesz edytować lub usunąć.","Approaching the character limit":"Zbliżanie się do limitu znaków","Character limit reached":"Osiągnięto limit znaków","Add to memory":"Dodaj do pamięci","Add Memory":"Dodaj wspomnienie","Add selected text to memory":"Dodaj wybrany tekst do pamięci","An error occurred":"Wystąpił błąd","Failed to generate memories":"Nie udało się wygenerować pamięci","Scanning this page for memory suggestions...":"Skanowanie tej strony w poszukiwaniu sugestii dotyczących pamięci...","Share anything you’d like us to remember to improve future AI responses.":"Podziel się wszystkim, co chcesz, abyśmy zapamiętali, aby poprawić przyszłe reakcje AI.","Type your own memory...":"Wpisz własną treść do zapamiętania...","Saved to memory!":"Zapisano do pamięci!","Manage information in the AI\'s memory to improve future responses.":"Zarządzaj informacjami w pamięci AI, aby poprawić przyszłe reakcje.","Manage Memory":"Zarządzaj pamięcią","Memory":"Pamięć","Memories":"Zapisy w pamięci","Search...":"Szukaj...","Add new memory...":"Dodaj nowy wspomnienie...","Add":"Dodaj","Edit memory":"Edytuj zapis w pamięci","Delete memory":"Usuń zapis w pamięci","Clear all memories":"Wyczyść wszystkie pamięci","No memories added yet":"Nie dodano jeszcze żadnych zapisów w pamięci","Saved memory":"Treści zapisane w pamięci","Saved in":"Zapisano w","Created date":"Data utworzenia","Updated date":"Data aktualizacji","Manage memories":"Zarządzaj zapisami w pamięci","Generate in chat":"Generuj na czacie","Sort":"Sortuj","Sorted up":"Sortowanie w górę","Sorted down":"Sortowanie w dół","Memory updated successfully":"Pamięć zaktualizowana pomyślnie","This will permanently remove all saved memories, and the AI will no longer use it to improve future responses.":"Spowoduje to trwałe usunięcie wszystkie zapisane w pamięci dane, a AI nie będzie już ich używać do poprawy przyszłych odpowiedzi.","Right-Click any action":"Kliknij prawym przyciskiem myszy dowolne działanie,","to explore additional options such as hiding it from the bar, adding it into the bar, and making edits.":"aby wypróbować dodatkowe opcje, takie jak ukrycie go na pasku, dodanie do paska i wprowadzenie zmian.","Proactive memory suggestion":"Proaktywna sugestia dotycząca pamięci","Enable to receive memory suggestion action when the page contains relevant information":"Włącz odbieranie sugestii pamięci, gdy strona zawiera istotne informacje","Relevant Memory":"Istotny zapis w pamięci","Enabling this will disable the Hide on this site toggle.":"Włączenie tej opcji spowoduje wyłączenie przełącznika Ukryj na tej stronie.","Generating response...":"Generowanie odpowiedzi...","Chat response:":"Odpowiedź na czacie:","Personalization":"Personalizacja","Customization":"Dostosowywanie","Get better responses by sharing who you are and how you work":"Powiedz więcej o sobie i o swojej pracy, aby otrzymywać lepsze odpowiedzi.","Introduce yourself to get better, more personalized responses":"Przedstaw się, aby otrzymywać lepsze, bardziej spersonalizowane odpowiedzi","How would you like to be called?":"Jak chciałbyś, żeby Cię nazywano?","Your name":"Twoje imię","What do you do?":"Czym się zajmujesz?","Sales agent at Acme":"Agent handlowy w Acme","How would you like the AI to respond?":"Jak mają wyglądać odpowiedzi AI?","Custom":"Niestandardowe","Straight Shooter":"Szczere i bezpośrednie","Collaborator":"Pomocne","Task Master":"Polecenia","Decision Advisor":"Doradca","Type your communication preferences...":"Podaj preferencje komunikacji...","Restore":"Przywróć","Anything else the AI should know about you?":"Czy AI powinna o Tobie wiedzieć jeszcze coś więcej?","Job responsibilities, areas of interest, career goals":"Obowiązki zawodowe, obszary zainteresowań, cele zawodowe","Generating a prompt that matches your role...":"Generowanie polecenia pasującego do Twojej roli...","Enable personalization":"Włącz personalizację","Run a quick action":"Wykonaj szybkie działanie","Hey":"Cześć","Ask me anything...":"Zapytaj mnie o cokolwiek...","Ask me anything about this page...":"Zapytaj mnie o cokolwiek na temat tej strony...","Ask me anything about the text you highlighted...":"Zapytaj mnie o cokolwiek na temat wyróżnionego tekstu...","Ask me anything about what you typed in the field...":"Zapytaj mnie o cokolwiek na temat tekstu w polu...","Use":"Użyj","Ignore":"Ignoruj","New webpage identified":"Zidentyfikowano nową stronę internetową","New highlighted text identified":"Zidentyfikowano nowy podświetlony tekst","Webpage identified":"Zidentyfikowano stronę internetową","Highlighted text identified":"Zidentyfikowano podświetlony tekst","Text field identified":"Zidentyfikowano pole tekstowe","New text field identified":"Zidentyfikowano nowe pole tekstowe","Would you prefer to use this as context for the AI, rather than the webpage?":"Czy wolisz używać tego jako kontekstu dla AI, a nie strony internetowej?","Would you prefer to use this as context for the AI, rather than the previous webpage?":"Czy wolisz używać tego jako kontekstu dla AI, a nie poprzedniej strony internetowej?","Would you prefer to use this as context for the AI, rather than the text you highlighted earlier?":"Czy wolisz używać tego jako kontekstu dla AI, a nie wcześniej zaznaczonego tekstu?","Would you prefer to use this as context for the AI, rather than the text in the previous field?":"Czy wolisz używać tego jako kontekstu dla AI, a nie tekstu w poprzednim polu?","Would you like to use this as context for the AI?":"Czy chcesz wykorzystać to jako kontekst dla AI?","The AI can tailor its responses based on context like text you highlight, the page you\'re on, or text you type in a field":"Sztuczna inteligencja może dostosowywać swoje odpowiedzi do kontekstu, np. do wyróżnionego tekstu, wyświetlanej strony lub tekstu wpisanego w polu","Webpage":"Strona internetowa","Highlighted text":"Podświetlony tekst","Text field":"Pole tekstowe","Add context":"Dodaj kontekst","Choose this to focus the AI response on a specific part of the page.":"Wybierz tę opcję, aby skupić się na odpowiedzi AI na określonej części strony.","To use, highlight text on screen first.":"Najpierw zaznacz tekst na ekranie.","Choose this to focus the AI response on text you\'ve typed in a specific field.":"Wybierz tę opcję, aby skupić się na odpowiedzi AI na tekście wpisanym w określonym polu.","To use, click a text field that already contains text.":"Kliknij pole tekstowe zawierające tekst.","Notifications":"Powiadomienia","More notifications":"Więcej powiadomień","Clear":"Wyczyść","Clear all":"Wyczyść wszystko","Pin to screen":"Przypnij do ekranu","Hide for 1 Hour":"Ukryj na 1 godzinę","Hide options":"Ukryj opcje","Restart":"Uruchom ponownie","Run automation":"Uruchom automatyzację","Ask me to do any task for you":"Poproś mnie o wykonanie za Ciebie dowolnego zadania","Creating a draft...":"Tworzenie projektu...","AI Chats":"Czaty AI","Help Content":"Pomoc","WalkMe Menu":"Menu WalkMe","Learning Content":"Treści edukacyjne","Open sidebar":"Otwórz panel boczny","Set as default":"Ustaw jako domyślne","The AI will use the information you provide to tailor it\'s responses to you.":"Sztuczna inteligencja wykorzysta podane informacje, aby dostosować swoje odpowiedzi do Ciebie.","Learn more about how we use your data":"Dowiedz się więcej o tym, jak wykorzystujemy Twoje dane","You can tell the AI to do things like:\\n* Be opinionated. If a question could have multiple answers, try to give only the best one\\n* Be casual and friendly\\n* Be concise and professional":"Możesz polecić sztucznej inteligencji, aby:\\n* wyrażała opinie. Jeśli pytanie może mieć wiele odpowiedzi, spróbuj podać tylko najlepszą z nich\\n* była swobona i przyjazna\\n* była zwięzła i profesjonalna","Delivering only blunt facts or instructions—no filler, no questions, no fluff.":"Dostarczamy tylko konkretne fakty lub instrukcje – bez zapychaczy, pytań, ani zbędnych treści","Brainstorming support with friendly tone, multiple perspectives, and open-ended prompts.":"Wsparcie przy burzy mózgów z przyjaznym tonem, różnymi perspektywami i otwartymi sugestiami.","Breaking tasks into concise checklists and focusing on fast, action-oriented execution.":"Podział zadań na zwięzłe listy kontrolne i skupienie się na szybkim, zorientowanym na działanie wykonaniu.","Framing choices with data-driven pros/cons and clear, strategic recommendations.":"Opisywanie wyborów w kontekście konkretnych zalet i wad opartych na danych oraz jasnych, strategicznych zaleceń.","Sources":"Źródła","Personal AI memory":"Pamięć osobistej AI","Improve my prompt":"Popraw mój komunikat","Undo":"Cofnij","Redo":"Ponów","Improving your prompt...":"Ulepszam Twój komunikat...","Meet the Action Bar":"Poznaj pasek działań","A secure, company-provided AI tool to improve your daily work.":"Bezpieczne narzędzie AI dostarczone przez firmę i usprawniające codzienną pracę.","What is your role?":"Jaka jest Twoja rola?","Share a little about yourself so the Action Bar can personalize your experience.":"Powiedz co nieco o sobie, aby Action Bar mógł spersonalizować Twoje wrażenia.","Example: Sales manager at Acme":"Przykład: menedżer sprzedaży w Acme","Continue without role":"Kontynuuj bez roli","Continue":"Kontynuuj","Chat with AI or explore resources":"Porozmawiaj z AI lub eksploruj zasoby","Chat with AI for guidance or explore curated company resources to get the help you need.":"Porozmawiaj z AI, aby uzyskać wskazówki lub przeglądaj wybrane zasoby firmowe, aby uzyskać potrzebną pomoc.","Chat with AI":"Rozmawiaj z AI","Chat with AI to ask questions and complete your daily tasks faster.":"Czatuj za pomocą AI, aby zadawać pytania i szybciej wykonywać codzienne zadania.","Find helpful resources":"Znajdź przydatne zasoby","Explore curated company resources and app-specific tips to guide your work.":"Poznaj wyselekcjonowane zasoby firmowe i wskazówki dotyczące aplikacji, które pomogą Ci w pracy.","Get quick help":"Uzyskaj szybką pomoc","Ask your question":"Zadaj pytanie","Action Bar understands what you’re working on":"Action Bar rozumie, nad czym pracujesz","Ask AI about this page":"Zapytaj AI o tę stronę","The Action Bar understands what you’re working on and uses that to run quick actions, like editing text, answering questions, or scanning for key details.":"Action Bar rozumie, nad czym pracujesz, i wykorzystuje to do wykonywania szybkich działań, takich jak edycja tekstu, odpowiadanie na pytania lub skanowanie w poszukiwaniu kluczowych szczegółów.","Use ready-made AI tools":"Użyj gotowych narzędzi AI","Run instant actions like Summarize, Proofread, or Translate, all designed to work with what’s on your screen and give you instant, relevant results.":"Wykonuj błyskawiczne działania, takie jak Podsumuj, Sprawdź lub Przetłumacz, które zostały zaprojektowane tak, aby współpracowały z treścią na ekranie i zapewniały natychmiastowe, trafne rezultaty.","Create and save your own actions":"Twórz i zapisuj własne działania","Not seeing actions or recommendations you need? Turn your favorite prompts into reusable AI actions going forward.":"Nie widzisz potrzebnych działań lub rekomendacji? Zamień swoje ulubione polecenia w działania AI wielokrotnego użytku.","Turn this into a LinkedIn post":"Przekształć to w post na LinkedIn","Draft a response message":"Szkicuj wiadomość odpowiedzi","Find next steps":"Znajdź następne kroki","Personalize the Action Bar":"Personalizuj pasek działań","Set the tone, style, display settings, and more to match how you like to work. Once set, the Action Bar will use these preferences automatically.":"Ustaw ton, styl, ustawienia wyświetlania i inne elementy, aby dopasować je do Twojego preferowanego sposobu pracy. Po ich ustawieniu pasek działań będzie automatycznie używał tych preferencji.","I am a sales agent at Acme corp.":"Jestem agentem handlowym w Acme corp.","I prefer concise answers":"Preferuję zwięzłe odpowiedzi","Your privacy comes first":"Twoja prywatność przede wszystkim","Your information is processed securely and is never used to train the AI models.":"Twoje informacje są przetwarzane bezpiecznie i nigdy nie są wykorzystywane do szkolenia modeli AI.","You stay in control":"Masz kontrolę","No data training on your content":"Brak szkolenia danych na Twoich treściach","Data processed within your company":{"translation":"Brak szkolenia na treściach","maxCharacters":31},"Saved to memory":"Zapisano do pamięci","Save key information to Memory":"Zapisz kluczowe informacje w pamięci","Save key details for later, so the Action Bar can provide more relevant recommendations and support. You control what\'s stored at all times.":"Zapisz kluczowe szczegóły na później, aby Action Bar mógł zapewniać bardziej trafne rekomendacje i wsparcie. Ty zawsze kontrolujesz, co jest przechowywane.","Customize your Action Bar":"Dostosuj pasek działań","Right-click any action to hide tools you don’t need, pin the ones you use most, or edit custom actions to fit how you work.":"Kliknij prawym przyciskiem myszy dowolne działanie, aby ukryć niepotrzebne narzędzia, przypnij te, których używasz najczęściej, lub edytuj niestandardowe działania, aby dopasować je do Twojej pracy.","Manage what the Action Bar remembers":"Zarządzaj tym, co zapamiętuje pasek działań","Review, edit, delete, or add memories to keep the Action Bar’s saved information accurate and relevant to your work.":"Przeglądaj, edytuj, usuwaj lub dodawaj informacje, aby zapisane informacje na pasku działań były dokładne i istotne dla Twojej pracy.","Get smart workflow suggestions":"Uzyskaj inteligentne sugestie dotyczące przepływów pracy","These actions are provided by your organization and are condition-based, appearing automatically when relevant to your page or task.":"Te działania są dostarczane przez organizację i oparte na warunkach. Pojawiają się automatycznie, gdy są istotne dla Twojej strony lub zadania.","Start tour":"Rozpocznij wycieczkę","Skip tour":"Pomiń wycieczkę","AI Chat":"Czat AI","Resources":"Zasoby","Reading Tools":"Narzędzia do czytania","Summarize":"Podsumuj","Writing Tools":"Narzędzia do pisania","Change Tone":"Zmień ton","Improve":"Popraw","Secure processing":"Bezpieczne przetwarzanie","Account renewal due Dec 10":"Termin odnowienia konta: 10 grudnia","Finance lead: Sarah Kim":"Kierownik ds. finansów: Sarah Kim","Save key details for smarter recommendations. Managed by you.":"Zapisz kluczowe szczegóły i otrzymuj inteligentniejsze rekomendacje. Zarządzane przez Ciebie.","AI Action":"Działanie AI","Right-click an action to pin, hide, or edit your workspace.":"Kliknij działanie prawym przyciskiem myszy, aby przypiąć, ukryć lub edytować przestrzeń roboczą.","I am a sales agent":"Jestem agentem sprzedaży","Set your role and communication preferences to match how you like to work.":"Ustaw swoją rolę i preferencje komunikacji, aby odpowiadały Twojemu sposobowi pracy.","Keep saved information accurate and relevant to your work.":"Zapisane informacje powinny być dokładne i powiązane z Twoją pracą.","Turn this into a post":"Zamień w post","Draft a message":"Stwórz szkic wiadomości","Save your go-to prompts":"Zapisz swoje ulubione komunikaty","Not seeing what you need? Turn your favorite prompts into reusable AI actions.":"Nie widzisz potrzebnych elementów? Zamień swoje ulubione komunikaty w wielokrotnego użytku działania AI.","Ask your question...":"Zadaj pytanie...","Action Bar understands context":"Pasek działań rozumie kontekst.","The Action Bar uses your page to answer questions, scan for key details or edit text.":"Pasek działań korzysta z Twojej strony do udzielania odpowiedzi na pytania, poszukiwania ważnych informacji lub edytowania tekstu.","Designed to work with what\'s on your screen and give you instant, relevant results.":"Został stworzony z myślą o pracy z treścią ekranową i przekazywaniu natychmiastowych oraz istotnych wyników.","Provided by your organization and appear when relevant to your page or task.":"Udostępniany przez Twoją organizację. Pojawia się, gdy zachodzi powiązanie z Twoją stroną lub zadaniem.","Unhide Action Bar":"Pokaż pasek działań","Tools group":"Grupa narzędzi","Automatically expand":"Automatycznie rozwijaj","Hide action bar":"Ukryj pasek akcji","Hide for 1 hour":"Ukryj na 1 godzinę","Hide everywhere":"Ukryj wszędzie","Disabled while \'Hide for 1 hour\' is active":"Wyłączone, gdy \'Ukryj na 1 godzinę\' jest aktywne","Disabled while \'Hide everywhere\' is active":"Wyłączone, gdy \'Ukryj wszędzie\' jest aktywne","Help menu":"Menu pomocy"}')}}]);