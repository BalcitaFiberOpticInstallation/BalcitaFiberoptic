window,(window._walkmeWebpackJP=window._walkmeWebpackJP||[]).push([[71],{1444:function(e){e.exports=JSON.parse('{"Add Launcher":"Adicionar Launcher","Icon and Name":"Ícone e nome","Name already exists":"O nome já existe","Name your action...":"Dê um nome à sua ação...","Prompt":"Prompt","Type what you want the AI engine to do for you...":"Digite o que você quer que o mecanismo de IA faça por você...","Visibility settings":"Ajustes de visibilidade","Display the action only when the":"Exibir a ação somente quando","highlighted text":"texto destacado","webpage":"página da web","input":"entrada","is":"é","isn\'t":"não é","optional":"opcional","Type the criteria for showing the action":"Digite os critérios para mostrar a ação","a question":"uma pergunta","a code snippet":"um trecho de código","in Spanish and all caps":"em espanhol e em letras maiúsculas","a non english text":"um texto que não seja em inglês","a report":"um relatório","a form":"um formulário","a data table":"uma tabela de dados","an email":"um e-mail","empty":"vazio","incomplete":"incompleto","Show on all apps":"Mostrar em todos os aplicativos","Show on this app only":"Mostrar apenas neste aplicativo","Use this setting when the action is relevant only to the current app you\'re in":"Use essa configuração quando a ação for relevante apenas para o aplicativo atual no qual você está","Use this setting when the action is relevant for any website or app":"Use esta configuração quando a ação for relevante para qualquer site ou aplicativo","New Action":"Nova ação","Edit Action":"Editar ação","Delete Action":"Excluir ação","Deleted custom actions cannot be restored.":"Ações personalizadas excluídas não podem ser restauradas.","Delete Custom Action":"Excluir ação personalizada","Are you sure you want to delete this custom action?":"Tem certeza de que deseja excluir esta ação personalizada?","Import":"Importar","Export":"Exportar","Share your action with coworkers":"Compartilhe a sua ação com colegas de trabalho","The action couldn\'t be uploaded. The file seems to be corrupted or incomplete. Please ask your coworker to export the action again and import the new action.":"Não foi possível carregar a ação. O arquivo parece estar corrompido ou incompleto. Peça ao seu colega de trabalho para exportar a ação novamente e importar a nova ação.","Cancel":"Cancelar","Close":"Fechar","Save":"Salvar","Save Changes":"Salvar alterações","Save and Export":"Salvar e exportar","Pin":"Fixar","Unpin":"Desafixar","Create First Action":"Criar primeira ação","Quick Actions Menu":"Menu de ações rápidas","Back":"Voltar","Add new action":"Adicionar nova ação","Default action cannot be edited":"A ação padrão não pode ser editada","Edit":"Editar","Note: Action Bar can display up to 5 actions":"Observação: a barra de ação pode exibir até cinco ações","Something went wrong":"Algo deu errado","Content generating has failed. Please try again later":"Falha na geração de conteúdo. Tente novamente mais tarde","No relevant reference found":"Não foi encontrada nenhuma referência relevante","Stop generating":"Parar de gerar","Copy":"Copiar","Copied":"Copiado","Copy Prompt":"Copiar prompt","Prompt copied":"Prompt copiado","Maximize":"Maximizar","Minimize":"Minimizar","Helpful":"Útil","Unhelpful":"Inútil","Save to Memory":"Salvar na memória","Saved to Memory":"Salvo na memória","AI-generated content may be incorrect":"O conteúdo gerado por IA pode estar incorreto","Refine":"Refinar","Refine...":"Refinar...","Refine (eg. add details about...)":"Refinar (por exemplo, adicione detalhes sobre...)","Generate":"Gerar","Regenerate":"Regenerar","Insert":"Inserir","Insert Below":"Inserir abaixo","Select tone":"Selecionar tom","Select format":"Selecionar formato","Select language":"Selecionar idioma","Go Back":"Voltar","Replace":"Substituir","New draft":"Novo rascunho","Save prompt":"Salvar prompt","Don\'t show this message again":"Não mostrar esta mensagem novamente","Be sure to review carefully before replacing":"Certifique-se de revisar cuidadosamente antes de substituir","Be sure to review carefully before inserting":"Certifique-se de revisar cuidadosamente antes de inserir","Text options":"Opções de texto","Working on it...":"Estamos trabalhando nisso...","The text used for this response":"O texto usado para esta resposta","Share your ideas or ask me anything, and I\'ll generate a first draft to help you out...":"Compartilhe suas ideias ou me pergunte qualquer coisa e eu gerarei um primeiro rascunho para ajudar você...","Share your ideas for editing the selected text, or ask me anything about it...":"Compartilhe suas ideias para editar o texto selecionado ou me faça perguntas sobre ele...","Share your ideas on what you\'d like to write, and I\'ll help you get started...":"Compartilhe suas ideias sobre o que você gostaria de escrever e eu ajudarei você a começar...","Share your ideas about the selected text, and I\'ll help with editing or writing something new...":"Compartilhe suas ideias sobre o texto selecionado e eu ajudarei a editar ou escrever algo novo...","Share your ideas about the text you focused on, and I\'ll help with editing or writing something new...":"Compartilhe suas ideias sobre o texto em que você se concentrou e eu ajudarei a editar ou escrever algo novo...","Work with:":"Trabalhar com:","Remove":"Remover","Open menu":"Abrir menu","Open Joule":"Abrir Joule","Help me write":"Ajude-me a escrever","See more actions":"Ver mais ações","Show actions":"Mostrar ações","Hide actions":"Ocultar ações","Actions are kept hidden, Expand to view them":"As ações são mantidas ocultas, expanda para visualizá-las","Neutral":"Neutro","Professional":"Profissional","Casual":"Casual","Concise":"Conciso","Free Text":"Texto livre","Email":"E-mail","Paragraph":"Parágrafo","Bullet List":"Lista de marcadores","Numbered List":"Lista numerada","Included context":"Contexto incluído","This whole page":"Esta página inteira","Change tone":"Alterar o tom","Sound neutral":"Soar neutro","Sound professional":"Parecer profissional","Sound casual":"Parecer casual","Sound concise":"Tom conciso","Sound engaging":"Soar envolvente","Sound enthusiastic":"Parecer entusiasmado","Sound confident":"Parecer confiante","Translate":"Traduzir","English":"Inglês","French":"Francês","German":"Alemão","Spanish":"Espanhol","Japanese":"Japonês","Hebrew":"Hebraico","Korean":"Coreano","Chinese":"Chinês","Portuguese":"Português","Vietnamese":"Vietnamita","Greek":"Grego","Polish":"Polonês","Change format":"Alterar formato","Elaborate":"Elaborar","Shorten":"Encurtar","Retry":"Tente de novo","Auto Length":"Comprimento automático","Shorter":"Breve","Longer":"Elaborado","AI analyzes the user input to set the length":"A IA analisa a entrada do usuário para definir o comprimento","Icons":"Ícones","Settings":"Ajustes","Next":"Próximo","Ok, got it":"Ok, entendi","Done":"Concluído","Introducing the AI Action Bar":"Apresentação da barra de ação de IA","Discover the power of your AI copilot to get the next best actions in the flow of your work.":"Descubra o poder do seu copiloto de IA para obter as melhores ações no seu fluxo de trabalho.","Upgraded Menu":"Menu atualizado","Open the menu to get instant answers to your questions with our conversational AI Chat":"Abra o menu para obter respostas instantâneas às suas perguntas com o nosso AI Chat","Draft content from scratch with the help of AI":"Elabore conteúdo a partir do zero com a ajuda da AI","Highlighted text tools":"Ferramentas para texto destacado","Highlight text to use AI reading and writing tools, including text summarization, translation, and writing editing tools.":"Destaque o texto para usar as ferramentas de leitura e escrita de IA, incluindo ferramentas de resumo de texto, tradução e edição de escrita.","Create your own actions":"Crie suas próprias ações","Create and save your own personalized prompts for fast reuse whenever text is highlighted on screen.":"Crie e salve seus próprios avisos personalizados para reutilização rápida sempre que o texto for destacado na tela.","Workflow tools":"Ferramentas de fluxo de trabalho","Get workflow suggestions from your organization in the right place at the right time.":"Receba sugestões de fluxo de trabalho de sua organização no lugar certo e na hora certa.","Text tools":"Ferramentas de texto","More actions":"Mais ações","Create new action":"Criar nova ação","Edit highlighted text with AI":"Editar texto destacado com IA","Create and save your own custom prompts":"Crie e salve seus próprios prompts personalizados","My actions":"Minhas ações","System actions":"Ações do sistema","Contextual Action Bar":"Barra de ação contextual","More Settings":"Mais ajustes","Text Tools Display":"Exibição de ferramentas de texto","Some actions, made by your organization will still appear in the action bar":"Algumas ações realizadas pela sua organização ainda aparecerão na barra de ação","Hide always":"Ocultar sempre","Hide on this site":"Ocultar neste site","Learn more":"Saiba mais","My custom actions":"Minhas ações personalizadas","My actions:":"Minhas ações:","All apps":"Todos os aplicativos","Location-specific":"Específico da localização","Replay onboarding guide":"Reproduzir guia de integração","Smart highlights":"Destaques inteligentes","Get instant details on people and customers by hovering over highlighted names":"Obtenha detalhes instantâneos a respeito de pessoas e clientes passando o mouse sobre os nomes colocados em destaque","Tone":"Tom","Format":"Formato","Length":"Comprimento","Language":"Idioma","Suggestions":"Sugestões","Tools":"Ferramentas","Add custom action":"Adicionar ação personalizada","Stop listening":"Parar de ouvir","Use microphone":"Usar microfone","I\'m listening...":"Estou ouvindo...","Microphone disabled. Please enable it to be heard":"Microfone desativado. Ative para ser ouvido","Please enable mic to be heard":"Ative o microfone para ser ouvido","Hide from bar":"Ocultar da barra","Add to bar":"Adicionar à barra","Delete":"Excluir","Refresh":"Atualizar","Rephrase":"Reformular","No more space in your bar":"Não há mais espaço na sua barra","No actions available":"Nenhuma ação disponível","Got It":"Entendi","Don’t show again":"Não mostrar novamente","We noticed you use this action often":"Percebemos que você usa essa ação com frequência","To quickly reuse, right-click the action and add to the bar. Undo anytime.":"Para reutilizar rapidamente, clique com o botão direito do mouse na ação e adicione à barra. Desfaça a qualquer momento.","Find your custom action here":"Encontre sua ação personalizada aqui","Right-click the action to edit, delete, or hide from the bar.":"Clique com o botão direito do mouse na ação para editar, excluir ou ocultar da barra.","You can find your hidden action here.":"Você pode encontrar sua ação oculta aqui.","Right click and select ‘Hide from bar’ to undo":"Clique com o botão direito e selecione \\"Ocultar da barra\\" para desfazer","Right-click the action to edit or delete.":"Clique com o botão direito do mouse na ação para editar ou excluir.","Approaching the character limit":"Aproximando-se do limite de caracteres","Character limit reached":"Limite de caracteres atingido","Add to memory":"Adicionar à memória","Add Memory":"Adicionar memória","Add selected text to memory":"Adicionar texto selecionado à memória","An error occurred":"Ocorreu um erro","Failed to generate memories":"Falha ao gerar memórias","Scanning this page for memory suggestions...":"Verificando esta página em busca de sugestões de memória...","Share anything you’d like us to remember to improve future AI responses.":"Compartilhe tudo o que você deseja que nos lembremos para melhorar futuras respostas de IA","Type your own memory...":"Digite sua própria memória...","Saved to memory!":"Salvo na memória!","Manage information in the AI\'s memory to improve future responses.":"Gerencie informações na memória da IA para melhorar respostas futuras.","Manage Memory":"Gerenciar memória","Memory":"Memória","Memories":"Memórias","Search...":"Pesquisar...","Add new memory...":"Adicionar nova memória...","Add":"Adicionar","Edit memory":"Editar memória","Delete memory":"Excluir memória","Clear all memories":"Limpar todas as memórias","No memories added yet":"Ainda não foram adicionadas memórias","Saved memory":"Memória salva","Saved in":"Salvo em","Created date":"Data de criação","Updated date":"Data de atualização","Manage memories":"Gerenciar memórias","Generate in chat":"Gerar no chat","Sort":"Classificar","Sorted up":"Classificado para cima","Sorted down":"Classificado para baixo","Memory updated successfully":"Memória atualizada","This will permanently remove all saved memories, and the AI will no longer use it to improve future responses.":"Isso removerá permanentemente todas as memórias salvas e a IA não as usará mais para melhorar respostas futuras.","Right-Click any action":"Clique com o botão direito em qualquer ação","to explore additional options such as hiding it from the bar, adding it into the bar, and making edits.":"para explorar opções adicionais, como ocultá-la da barra, adicioná-la à barra e fazer edições.","Proactive memory suggestion":"Sugestão proativa de memória","Enable to receive memory suggestion action when the page contains relevant information":"Ativar o recebimento de ação de sugestão de memória quando a página contiver informações relevantes","Relevant Memory":"Memória relevante","Enabling this will disable the Hide on this site toggle.":"Ao ativar isso, a opção Ocultar neste site será desativada.","Generating response...":"Gerando resposta...","Chat response:":"Resposta de chat:","Personalization":"Personalização","Customization":"Personalização","Get better responses by sharing who you are and how you work":"Receba respostas melhores compartilhando quem você é e como trabalha","Introduce yourself to get better, more personalized responses":"Apresente-se para obter respostas melhores e mais personalizadas","How would you like to be called?":"Como você gostaria de ser chamado?","Your name":"Seu nome","What do you do?":"O que você faz?","Sales agent at Acme":"Agente de vendas na Acme","How would you like the AI to respond?":"Como você gostaria que a IA respondesse?","Custom":"Personalizado","Straight Shooter":"Direto e objetivo","Collaborator":"Colaborador","Task Master":"Mestre das tarefas","Decision Advisor":"Consultor de decisão","Type your communication preferences...":"Digite suas preferências de comunicação...","Restore":"Restaurar","Anything else the AI should know about you?":"Mais alguma coisa que a IA deva saber sobre você?","Job responsibilities, areas of interest, career goals":"Responsabilidades do trabalho, áreas de interesse, objetivos de carreira","Generating a prompt that matches your role...":"Geração de um prompt que corresponde à sua função...","Enable personalization":"Ativar personalização","Run a quick action":"Executar uma ação rápida","Hey":"Olá","Ask me anything...":"Pergunte-me qualquer coisa...","Ask me anything about this page...":"Pergunte-me qualquer coisa sobre esta página...","Ask me anything about the text you highlighted...":"Pergunte-me qualquer coisa sobre o texto que você destacou...","Ask me anything about what you typed in the field...":"Pergunte-me sobre o que você digitou no campo...","Use":"Use","Ignore":"Ignorar","New webpage identified":"Nova página da web identificada","New highlighted text identified":"Novo texto destacado identificado","Webpage identified":"Página da web identificada","Highlighted text identified":"Texto destacado identificado","Text field identified":"Campo de texto identificado","New text field identified":"Novo campo de texto identificado","Would you prefer to use this as context for the AI, rather than the webpage?":"Você prefere usar este como contexto para a IA, em vez da página da web?","Would you prefer to use this as context for the AI, rather than the previous webpage?":"Você prefere usar este como contexto para a IA, em vez da página da web anterior?","Would you prefer to use this as context for the AI, rather than the text you highlighted earlier?":"Prefere usar este como contexto para a IA, em vez do texto que você destacou anteriormente?","Would you prefer to use this as context for the AI, rather than the text in the previous field?":"Você prefere usar este como contexto para a IA, em vez do texto no campo anterior?","Would you like to use this as context for the AI?":"Você gostaria de usar este como contexto para a IA?","The AI can tailor its responses based on context like text you highlight, the page you\'re on, or text you type in a field":"A IA pode personalizar suas respostas com base no contexto, como um texto que você destaca, a página em que você está ou texto que você digita em um campo.","Webpage":"Página da web","Highlighted text":"Texto destacado","Text field":"Campo de texto","Add context":"Adicionar contexto","Choose this to focus the AI response on a specific part of the page.":"Escolha essa opção para concentrar a resposta da IA em uma parte específica da página.","To use, highlight text on screen first.":"Para usar, destaque primeiro o texto na tela.","Choose this to focus the AI response on text you\'ve typed in a specific field.":"Escolha essa opção para concentrar a resposta da IA no texto que você digitou em um campo específico.","To use, click a text field that already contains text.":"Para usar, clique em um campo de texto que já contenha texto.","Notifications":"Notificações","More notifications":"Mais notificações","Clear":"Limpar","Clear all":"Limpar tudo","Pin to screen":"Fixar na tela","Hide for 1 Hour":"Ocultar por 1 hora","Hide options":"Ocultar opções","Auto expand bar":"Barra de expansão automática","Action bar display":"Exibição da barra de ação","Restart":"Reiniciar","Run automation":"Executar automação","Ask me to do any task for you":"Peça-me para fazer uma tarefa para você","Creating a draft...":"Criando um rascunho...","AI Chats":"Chats de IA","Help Content":"Conteúdo de ajuda","WalkMe Menu":"WalkMe Menu","Learning Content":"Conteúdo de Learning","Open sidebar":"Abrir barra lateral","Set as default":"Definir como padrão","The AI will use the information you provide to tailor it\'s responses to you.":"A IA usará as informações que você fornecer para personalizar suas respostas.","Learn more about how we use your data":"Saiba mais sobre como usamos seus dados","You can tell the AI to do things like:\\n* Be opinionated. If a question could have multiple answers, try to give only the best one\\n* Be casual and friendly\\n* Be concise and professional":"Você pode dizer à IA para fazer coisas como:\\n* Seja opinativa. Se uma pergunta puder ter várias respostas, tente dar apenas a melhor delas.\\n* Seja casual e amigável\\n* Seja concisa e profissional","Delivering only blunt facts or instructions—no filler, no questions, no fluff.":"Fornecimento apenas fatos ou instruções diretas: não preenchimento, não perguntas, não enrolação.","Brainstorming support with friendly tone, multiple perspectives, and open-ended prompts.":"Suporte para brainstorming com tom amigável, várias perspectivas e prompts abertos.","Breaking tasks into concise checklists and focusing on fast, action-oriented execution.":"Divida as tarefas em listas de verificação concisas e foque na execução rápida e orientada à ação.","Framing choices with data-driven pros/cons and clear, strategic recommendations.":"Defina as escolhas com prós/contras baseados em dados e recomendações estratégicas claras.","Sources":"Fontes","Personal AI memory":"Memória de IA pessoal","Improve my prompt":"Melhorar meu prompt","Undo":"Desfazer","Redo":"Refazer","Improving your prompt...":"Melhorando o seu prompt...","Meet the Action Bar":"Conheça a Barra de ação","A secure, company-provided AI tool to improve your daily work.":"Uma ferramenta de IA segura fornecida pela empresa para melhorar seu trabalho diário.","What is your role?":"Qual é a sua função?","Share a little about yourself so the Action Bar can personalize your experience.":"Compartilhe um pouco sobre você para que a Barra de ação possa personalizar sua experiência.","Example: Sales manager at Acme":"Exemplo: gerente de vendas na Acme","Continue without role":"Continuar sem função","Continue":"Continuar","Chat with AI or explore resources":"Faça um chat com a IA ou explore recursos","Chat with AI for guidance or explore curated company resources to get the help you need.":"Faça um chat com a IA para obter orientação ou explore os recursos com curadoria da empresa para obter a ajuda de que você precisa.","Chat with AI":"Chat com IA","Chat with AI to ask questions and complete your daily tasks faster.":"Faça um chat com a IA para fazer perguntas e concluir suas tarefas diárias mais rapidamente.","Find helpful resources":"Encontre recursos úteis","Explore curated company resources and app-specific tips to guide your work.":"Explore os recursos com curadoria da empresa e dicas específicas de aplicativos para orientar seu trabalho.","Get quick help":"Obtenha ajuda rápida","Ask your question":"Faça sua pergunta","Action Bar understands what you’re working on":{"translation":"A Barra de ação entende seu trabalho","maxCharacters":48},"Ask AI about this page":"Pergunte à IA sobre esta página","The Action Bar understands what you’re working on and uses that to run quick actions, like editing text, answering questions, or scanning for key details.":"A Barra de ação entende no que você está trabalhando e usa isso para executar ações rápidas, como editar texto, responder a perguntas ou procurar detalhes importantes.","Use ready-made AI tools":"Use ferramentas de IA prontas","Run instant actions like Summarize, Proofread, or Translate, all designed to work with what’s on your screen and give you instant, relevant results.":"Execute ações instantâneas como Resumir, Revisar ou Traduzir, todas projetadas para funcionar com o que está na sua tela e fornecer resultados instantâneos e relevantes.","Create and save your own actions":"Crie e salve suas próprias ações","Not seeing actions or recommendations you need? Turn your favorite prompts into reusable AI actions going forward.":"Não vê as ações ou recomendações de que você precisa? Transforme seus prompts favoritos em ações de IA reutilizáveis daqui para frente.","Turn this into a LinkedIn post":{"translation":"Transforme em post no LinkedIn","maxCharacters":40},"Draft a response message":"Rascunhe uma mensagem de resposta","Find next steps":"Encontre as próximas etapas","Personalize the Action Bar":"Personalize a Barra de ação","Set the tone, style, display settings, and more to match how you like to work. Once set, the Action Bar will use these preferences automatically.":"Defina os ajustes de tom, estilo, exibição e muito mais para se adequar à sua forma de trabalhar. Depois de definida, a Barra de ação usará essas preferências automaticamente.","I am a sales agent at Acme corp.":"Sou um agente de vendas na Acme corp.","I prefer concise answers":"Prefiro respostas concisas","Your privacy comes first":"Sua privacidade vem em primeiro lugar","Your information is processed securely and is never used to train the AI models.":"Suas informações são processadas com segurança e nunca são usadas para treinar os modelos de IA.","You stay in control":"Você permanece no controle","No data training on your content":{"translation":"Sem treinamento de dados no conteúdo","maxCharacters":48},"Data processed within your company":"Dados processados dentro de sua empresa","Saved to memory":"Salvo na memória","Save key information to Memory":"Salve as principais informações na memória","Save key details for later, so the Action Bar can provide more relevant recommendations and support. You control what\'s stored at all times.":"Salve os principais detalhes para mais tarde, para que a Barra de ação possa fornecer recomendações e suporte mais relevantes. Você controla o que é armazenado em todos os momentos.","Customize your Action Bar":"Personalize sua Barra de ação","Right-click any action to hide tools you don’t need, pin the ones you use most, or edit custom actions to fit how you work.":"Clique com o botão direito do mouse em qualquer ação para ocultar ferramentas que não precisa, fixar aquelas que você mais usa ou editar ações personalizadas para se adequar a como você trabalha.","Manage what the Action Bar remembers":"Gerencie o que a Barra de ação memoriza","Review, edit, delete, or add memories to keep the Action Bar’s saved information accurate and relevant to your work.":"Revise, edite, exclua ou adicione memórias para manter as informações salvas na Barra de ação precisas e relevantes para o seu trabalho.","Get smart workflow suggestions":"Obtenha sugestões de fluxo de trabalho inteligentes","These actions are provided by your organization and are condition-based, appearing automatically when relevant to your page or task.":"Essas ações são fornecidas por sua organização e são baseadas em condições, aparecendo automaticamente quando relevantes para sua página ou tarefa.","Start tour":"Iniciar tour","Skip tour":"Pular tour","AI Chat":"IA Chat","Resources":"Recursos","Reading Tools":"Ferramentas de leitura","Summarize":"Resumir","Writing Tools":"Ferramentas de escrita","Change Tone":"Alterar tom","Improve":"Melhorar","Secure processing":"Processamento seguro","Account renewal due Dec 10":"Renovação da conta prevista para 10 de dezembro","Finance lead: Sarah Kim":"Líder financeiro: Sarah Kim","Save key details for smarter recommendations. Managed by you.":"Salve os principais detalhes para recomendações mais inteligentes. Gerenciado por você.","AI Action":"Ação de IA","Right-click an action to pin, hide, or edit your workspace.":"Clique com o botão direito do mouse em uma ação para fixar, ocultar ou editar seu espaço de trabalho.","I am a sales agent":"Sou um agente de vendas","Set your role and communication preferences to match how you like to work.":"Defina sua função e preferências de comunicação para corresponder à forma como deseja trabalhar.","Keep saved information accurate and relevant to your work.":"Mantenha as informações salvas precisas e relevantes para o seu trabalho.","Turn this into a post":"Transforme isso em uma postagem","Draft a message":"Escreva uma mensagem","Save your go-to prompts":"Salve seus prompts favoritos","Not seeing what you need? Turn your favorite prompts into reusable AI actions.":"Não vê o que você precisa? Transforme seus prompts favoritos em ações de IA reutilizáveis.","Ask your question...":"Faça sua pergunta...","Action Bar understands context":"A barra de ação entende o contexto","The Action Bar uses your page to answer questions, scan for key details or edit text.":"A barra de ação usa sua página para responder a perguntas, procurar detalhes importantes ou editar texto.","Designed to work with what\'s on your screen and give you instant, relevant results.":"Projetado para funcionar com o que está na sua tela e fornecer resultados instantâneos e relevantes.","Provided by your organization and appear when relevant to your page or task.":"Fornecido pela sua organização e exibido quando relevante para a sua página ou tarefa.","Unhide Action Bar":"Reexibir Barra de ação","Tools group":"Grupo de ferramentas","Automatically expand":"Expandir automaticamente","Hide action bar":"Ocultar barra de ações","Hide for 1 hour":"Ocultar por 1 hora","Hide everywhere":"Ocultar em todos os lugares","Disabled while \'Hide for 1 hour\' is active":"Desativado enquanto \'Ocultar por 1 hora\' está ativo","Disabled while \'Hide everywhere\' is active":"Desativado enquanto \'Ocultar em todos os lugares\' está ativo","Help menu":"Menu de ajuda"}')}}]);