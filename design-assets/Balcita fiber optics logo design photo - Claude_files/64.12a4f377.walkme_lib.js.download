window,window._walkmeWebpackJP&&(window._walkmeWebpackJP=window._walkmeWebpackJP||[]).push([[64],{1437:function(e){e.exports=JSON.parse('{"Add Launcher":"Launcher hinzufügen","Icon and Name":"Symbol und Name","Name already exists":"Name existiert bereits","Name your action...":"Benennen Sie Ihre Aktion…","Prompt":"Aufforderung","Type what you want the AI engine to do for you...":"Geben Sie ein, was die KI-Engine für Sie tun soll…","Visibility settings":"Sichtbarkeitseinstellungen","Display the action only when the":"Anzeigen der Aktion nur dann, wenn:","highlighted text":"hervorgehobener Text","webpage":"Webseite","input":"Eingabe","is":"ist","isn\'t":"ist nicht","optional":"optional","Type the criteria for showing the action":"Geben Sie die Kriterien zum Anzeigen der Aktion ein","a question":"eine Frage","a code snippet":"ein Code-Snippet","in Spanish and all caps":"auf Spanisch und in Großbuchstaben","a non english text":"nicht-englischer Text","a report":"ein Bericht","a form":"ein Formular","a data table":"eine Datentabelle","an email":"eine E-Mail","empty":"leer","incomplete":"unvollständig","Show on all apps":"In allen Apps anzeigen","Show on this app only":"Nur in dieser App anzeigen","Use this setting when the action is relevant only to the current app you\'re in":"Verwenden Sie diese Einstellung, wenn die Aktion nur für die aktuelle App relevant ist, in der Sie sich befinden","Use this setting when the action is relevant for any website or app":"Verwenden Sie diese Einstellung, wenn die Aktion für eine Website oder App relevant ist","New Action":"Neue Aktion","Edit Action":"Aktion bearbeiten","Delete Action":"Aktion löschen","Deleted custom actions cannot be restored.":"Gelöschte benutzerdefinierte Aktionen können nicht wiederhergestellt werden.","Delete Custom Action":"Benutzerdefinierte Aktion löschen","Are you sure you want to delete this custom action?":"Sind Sie sicher, dass Sie diese benutzerdefinierte Aktion löschen möchten?","Import":"Importieren","Export":"Exportieren","Share your action with coworkers":"Mit Kollegen und Kolleginnen teilen","The action couldn\'t be uploaded. The file seems to be corrupted or incomplete. Please ask your coworker to export the action again and import the new action.":"Die Aktion konnte nicht hochgeladen werden. Die Datei scheint beschädigt oder unvollständig zu sein. Bitten Sie Ihren Kollegen, die Aktion erneut zu exportieren und zu importieren.","Cancel":"Abbrechen","Close":"Schließen","Save":"Speichern","Save Changes":"Speichern","Save and Export":"Speichern und exportieren","Pin":"Pin","Unpin":"Pin aufheben","Create First Action":"Erste Aktion erstellen","Quick Actions Menu":"Schnellaktionsmenü","Back":"Zurück","Add new action":"Neue Aktion hinzufügen","Default action cannot be edited":"Standardaktion kann nicht bearbeitet werden","Edit":"Bearbeiten","Note: Action Bar can display up to 5 actions":"Hinweis: Aktionsleiste kann bis zu 5 Aktionen anzeigen","Something went wrong":"Das hat leider nicht geklappt","Content generating has failed. Please try again later":"Die Inhaltsgenerierung ist fehlgeschlagen. Bitte versuchen Sie es später erneut.","No relevant reference found":"Keine relevante Referenz gefunden","Stop generating":"Generierung stoppen","Copy":"Kopieren","Copied":"Kopiert","Copy Prompt":"Eingabeaufforderung kopieren","Prompt copied":"Eingabeaufforderung kopiert","Maximize":"Maximieren","Minimize":"Minimieren","Helpful":"Hilfreich","Unhelpful":"Nicht hilfreich","Save to Memory":"Im Gedächtnis speichern","Saved to Memory":"Im Gedächtnis gespeichert","AI-generated content may be incorrect":"Von KI generierte Inhalte können falsch sein","Refine":"Verfeinern","Refine...":"Verfeinern...","Refine (eg. add details about...)":"Verfeinern (z. B. Details hinzufügen über...)","Generate":"Generieren","Regenerate":"Erneut generieren","Insert":"Einfügen","Insert Below":"Unten einfügen","Select tone":"Ton auswählen","Select format":"Format auswählen","Select language":"Sprache auswählen","Go Back":"Zurück","Replace":"Ersetzen","New draft":"Neuer Entwurf","Save prompt":"Eingabeaufforderung speichern","Don\'t show this message again":"Diese Nachricht nicht wieder anzeigen","Be sure to review carefully before replacing":"Achten Sie darauf, sorgfältig zu prüfen, bevor Sie ersetzen","Be sure to review carefully before inserting":"Achten Sie darauf, vor dem Einfügen sorgfältig zu prüfen","Text options":"Textoptionen","Working on it...":"Arbeite daran…","The text used for this response":"Der für diese Antwort verwendete Text","Share your ideas or ask me anything, and I\'ll generate a first draft to help you out...":"Teilen Sie Ihre Ideen oder fragen Sie mich etwas und ich generiere einen ersten Entwurf, um Ihnen zu helfen…","Share your ideas for editing the selected text, or ask me anything about it...":"Teilen Sie Ihre Ideen zur Bearbeitung des ausgewählten Textes oder fragen Sie mich etwas darüber…","Share your ideas on what you\'d like to write, and I\'ll help you get started...":"Teilen Sie Ihre Ideen mit, was Sie schreiben möchten, und ich helfe Ihnen zu Beginn…","Share your ideas about the selected text, and I\'ll help with editing or writing something new...":"Teilen Sie Ihre Ideen zum ausgewählten Text mit und ich helfe beim Bearbeiten oder Schreiben von etwas Neuem…","Share your ideas about the text you focused on, and I\'ll help with editing or writing something new...":"Teilen Sie Ihre Ideen über den Text, auf den Sie sich konzentriert haben, und ich helfe beim Bearbeiten oder Schreiben von etwas Neuem…","Work with:":"Arbeiten mit:","Remove":"Entfernen","Open menu":"Menü öffnen","Open Joule":"Joule öffnen","Help me write":"Hilf mir beim Schreiben","See more actions":"Weitere Aktionen anzeigen","Show actions":"Aktionen anzeigen","Hide actions":"Aktionen ausblenden","Actions are kept hidden, Expand to view them":"Aktionen werden ausgeblendet – erweitern, um sie anzuzeigen","Neutral":"Neutral","Professional":"Beruflich","Casual":"Privat","Concise":"Präzise","Free Text":"Freitext","Email":"E-Mail","Paragraph":"Absatz","Bullet List":"Aufzählungsliste","Numbered List":"Nummerierte Liste","Included context":"Eingeschlossener Kontext","This whole page":"Diese ganze Seite","Change tone":"Ton ändern","Sound neutral":"Neutraler Ton","Sound professional":"Professioneller Ton","Sound casual":"Umgangssprachlicher Ton","Sound concise":"Präziser Ton","Sound engaging":"Ansprechender Ton","Sound enthusiastic":"Begeisterter Ton","Sound confident":"Selbstbewusster Ton","Translate":"Übersetzen","English":"English","French":"Französisch","German":"Deutsch","Spanish":"Spanisch","Japanese":"Japanisch","Hebrew":"Hebräisch","Korean":"Koreanisch","Chinese":"Chinesisch","Portuguese":"Portugiesisch","Vietnamese":"Vietnamesisch","Greek":"Griechisch","Polish":"Polnisch","Change format":"Format ändern","Elaborate":"Aufwendig","Shorten":"Kürzen","Retry":"Erneut versuchen","Auto Length":"Auto-Länge","Shorter":"Kurz","Longer":"Aufwändig","AI analyzes the user input to set the length":"KI analysiert die Benutzereingabe, um die Länge festzulegen","Icons":"Symbole","Settings":"Einstellungen","Next":"Weiter","Ok, got it":"Verstanden","Done":"Fertig","Introducing the AI Action Bar":"Einführung in die KI-Aktionsleiste","Discover the power of your AI copilot to get the next best actions in the flow of your work.":"Entdecken Sie die Leistungsfähigkeit Ihres KI-Co-Piloten, um die besten nächsten Aktionen im Arbeitsablauf zu erzielen.","Upgraded Menu":"Verbessertes Menü","Open the menu to get instant answers to your questions with our conversational AI Chat":"Öffnen Sie das Menü, um mit unserem Konversations-KI-Chat sofortige Antworten auf Ihre Fragen zu erhalten.","Draft content from scratch with the help of AI":"Entwerfen Sie Inhalte mithilfe von KI","Highlighted text tools":"Werkzeuge zum Hervorheben von Text","Highlight text to use AI reading and writing tools, including text summarization, translation, and writing editing tools.":"Heben Sie Text hervor, um KI-Lese- und Schreibwerkzeuge zu verwenden, darunter Textzusammenfassung, Übersetzungs- und Schreibwerkzeuge.","Create your own actions":"Erstellen Sie eigene Aktionen","Create and save your own personalized prompts for fast reuse whenever text is highlighted on screen.":"Erstellen und speichern Sie Ihre eigenen personalisierten Eingabeaufforderungen zur schnellen Wiederverwendung, wenn Text auf dem Bildschirm hervorgehoben wird.","Workflow tools":"Workflow-Tools","Get workflow suggestions from your organization in the right place at the right time.":"Lassen Sie sich Workflow-Vorschläge von Ihrer Organisation zur richtigen Zeit am richtigen Ort anzeigen.","Text tools":"Textwerkzeuge","More actions":"Weitere Aktionen","Create new action":"Neue Aktion erstellen","Edit highlighted text with AI":"Hervorgehobenen Text mit KI bearbeiten","Create and save your own custom prompts":"Erstellen und speichern Sie benutzerdefinierte Eingabeaufforderungen","My actions":"Meine Aktionen","System actions":"Systemaktionen","Contextual Action Bar":"Kontextbezogene Aktionsleiste","More Settings":"Weitere Einstellungen","Text Tools Display":"Textwerkzeuganzeige","Some actions, made by your organization will still appear in the action bar":"Einige von Ihrer Organisation durchgeführte Aktionen werden weiterhin in der Aktionsleiste angezeigt","Hide always":"Immer ausblenden","Hide on this site":"Auf dieser Website ausblenden","Learn more":"Erfahren Sie mehr","My custom actions":"Benutzerdefinierten Aktionen","My actions:":"Meine Aktionen:","All apps":"Alle Anwendungen","Location-specific":"Standortspezifisch","Replay onboarding guide":"Onboarding-Guide erneut","Smart highlights":"Intelligente Highlights","Get instant details on people and customers by hovering over highlighted names":"Erhalten Sie sofort Details zu Personen und Kunden, indem Sie den Mauszeiger über hervorgehobene Namen bewegen.","Tone":"Ton","Format":"Format","Length":"Länge","Language":"Sprache","Suggestions":"Vorschläge","Tools":"Tools","Add custom action":"Benutzerdefinierte Aktion hinzufügen","Stop listening":"Nicht mehr zuhören","Use microphone":"Mikrofon verwenden","I\'m listening...":"Ich höre zu…","Microphone disabled. Please enable it to be heard":"Mikrofon deaktiviert. Bitte aktivieren, damit Sie gehört werden.","Please enable mic to be heard":"Bitte das Mikrofon aktivieren, damit Sie gehört werden.","Hide from bar":"Von der Suchleiste ausblenden","Add to bar":"Zur Suchleiste hinzufügen","Delete":"Löschen","Refresh":"Aktualisieren","Rephrase":"Neu formulieren","No more space in your bar":"Kein Platz mehr in Ihrer Suchleiste","No actions available":"Keine Aktionen verfügbar","Got It":"Das habe ich verstanden","Don’t show again":"Nicht erneut anzeigen","We noticed you use this action often":"Wir haben bemerkt, dass Sie diese Aktion häufig verwenden.","To quickly reuse, right-click the action and add to the bar. Undo anytime.":"Um sie schnell wiederzuverwenden, klicken Sie mit der rechten Maustaste auf die Aktion und fügen Sie sie zur Leiste hinzu. Jederzeit rückgängig machen.","Find your custom action here":"Finden Sie Ihre benutzerdefinierte Aktion hier","Right-click the action to edit, delete, or hide from the bar.":"Klicken Sie mit der rechten Maustaste auf die Aktion, um sie zu bearbeiten, zu löschen oder in der Leiste auszublenden.","You can find your hidden action here.":"Sie können Ihre ausgeblendete Aktion hier finden.","Right click and select ‘Hide from bar’ to undo":"Klicken Sie mit der rechten Maustaste und wählen Sie „In der Leiste ausblenden“ aus, um dies rückgängig zu machen.","Right-click the action to edit or delete.":"Klicken Sie mit der rechten Maustaste auf die Aktion, um sie zu bearbeiten oder zu löschen.","Approaching the character limit":"Zeichenlimit fast erreicht","Character limit reached":"Zeichenlimit erreicht","Add to memory":"Dem Gedächtnis hinzufügen","Add Memory":"Gedächtnis hinzufügen","Add selected text to memory":"Ausgewählten Text dem Gedächtnis hinzufügen","An error occurred":"Es ist ein Fehler aufgetreten","Failed to generate memories":"Erinnerungen konnten nicht generiert werden","Scanning this page for memory suggestions...":"Diese Seite wird nach Vorschlägen aus dem Gedächtnis gescannt …","Share anything you’d like us to remember to improve future AI responses.":"Teilen Sie alles, damit wir uns zur Verbesserung künftiger KI-Antworten daran erinnern können.","Type your own memory...":"Geben Sie Ihre eigene Erinnerung ein …","Saved to memory!":"Im Gedächtnis gespeichert!","Manage information in the AI\'s memory to improve future responses.":"Verwalten Sie Informationen zur Verbesserung künftiger Antworten im Gedächtnis der KI.","Manage Memory":"Gedächtnis verwalten","Memory":"Speicher","Memories":"Erinnerungen","Search...":"Suche …","Add new memory...":"Neues Gedächtnis hinzufügen …","Add":"Hinzufügen","Edit memory":"Gedächtnis bearbeiten","Delete memory":"Gedächtnis löschen","Clear all memories":"Alle Erinnerungen löschen","No memories added yet":"Noch kein Gedächtnis hinzugefügt","Saved memory":"Gespeichertes Gedächtnis","Saved in":"Gespeichert in","Created date":"Erstellungsdatum","Updated date":"Aktualisiertes Datum","Manage memories":"Erinnerungen verwalten","Generate in chat":"Im Chat generieren","Sort":"Sortieren","Sorted up":"Aufsteigend sortiert","Sorted down":"Absteigend sortiert","Memory updated successfully":"Gedächtnis erfolgreich aktualisiert","This will permanently remove all saved memories, and the AI will no longer use it to improve future responses.":"Dadurch werden alle gespeicherten Erinnerungen dauerhaft entfernt, und die KI wird sie nicht mehr zur Verbesserung zukünftiger Antworten verwenden.","Right-Click any action":"Klicken Sie mit der rechten Maustaste auf eine beliebige Aktion,","to explore additional options such as hiding it from the bar, adding it into the bar, and making edits.":"um zusätzliche Optionen zu erkunden, z. B. das Ausblenden aus der Leiste, das Hinzufügen zur Leiste und das Bearbeiten.","Proactive memory suggestion":"Proaktiver Speichervorschlag","Enable to receive memory suggestion action when the page contains relevant information":"Empfangen von Vorschlagsaktion aus dem Speicher aktivieren, wenn die Seite relevante Informationen enthält","Relevant Memory":"Relevanter Speicher","Enabling this will disable the Hide on this site toggle.":"Durch die Aktivierung dieser Option wird der Umschalter für das Ausblenden auf dieser Website deaktiviert.","Generating response...":"Antwort wird generiert ...","Chat response:":"Chat-Antwort:","Personalization":"Personalisierung","Customization":"Anpassung","Get better responses by sharing who you are and how you work":"Erhalten Sie bessere Antworten, indem Sie zeigen, wer Sie sind und wie Sie arbeiten.","Introduce yourself to get better, more personalized responses":"Stellen Sie sich vor, um bessere, personalisierte Antworten zu erhalten.","How would you like to be called?":"Wie möchten Sie genannt werden?","Your name":"Ihr Name","What do you do?":"Was machen Sie?","Sales agent at Acme":"Vertriebsmitarbeiter bei Acme","How would you like the AI to respond?":"Wie soll die KI reagieren?","Custom":"Angepasst","Straight Shooter":"Geradliniger Typ","Collaborator":"Mitwirkender","Task Master":"Aufgabenmeister","Decision Advisor":"Entscheidungsberater","Type your communication preferences...":"Geben Sie Ihre Kommunikationspräferenzen ein ...","Restore":"Wiederherstellen","Anything else the AI should know about you?":"Sollte die KI noch etwas anderes über Sie wissen?","Job responsibilities, areas of interest, career goals":"Verantwortlichkeiten, Interessengebiete, Karriereziele","Generating a prompt that matches your role...":"Eine Eingabeaufforderung wird generiert, die Ihrer Rolle entspricht ...","Enable personalization":"Personalisierung aktivieren","Run a quick action":"Eine Schnellaktion ausführen","Hey":"Hey","Ask me anything...":"Sie können mich alles fragen…","Ask me anything about this page...":"Fragen Sie mich etwas zu dieser Seite …","Ask me anything about the text you highlighted...":"Fragen Sie mich etwas zu dem Text, den Sie hervorgehoben haben …","Ask me anything about what you typed in the field...":"Fragen Sie mich alles dazu, was Sie in das Feld eingegeben haben …","Use":"verwenden","Ignore":"Ignorieren","New webpage identified":"Neue Webseite identifiziert","New highlighted text identified":"Neuer hervorgehobener Text identifiziert","Webpage identified":"Webseite identifiziert","Highlighted text identified":"Hervorgehobener Text identifiziert","Text field identified":"Textfeld identifiziert","New text field identified":"Neues Textfeld identifiziert","Would you prefer to use this as context for the AI, rather than the webpage?":"Möchten Sie dies lieber als Kontext für die KI verwenden anstatt der Webseite?","Would you prefer to use this as context for the AI, rather than the previous webpage?":"Möchten Sie dies lieber als Kontext für die KI verwenden anstatt der vorherigen Webseite?","Would you prefer to use this as context for the AI, rather than the text you highlighted earlier?":"Möchten Sie diesen Text lieber als Kontext für die KI verwenden anstatt des von Ihnen zuvor hervorgehobenen Texts?","Would you prefer to use this as context for the AI, rather than the text in the previous field?":"Möchten Sie diesen Text lieber als Kontext für die KI verwenden anstatt des Texts im vorherigen Feld?","Would you like to use this as context for the AI?":"Möchten Sie dies als Kontext für die KI verwenden?","The AI can tailor its responses based on context like text you highlight, the page you\'re on, or text you type in a field":"Die KI kann ihre Antworten basierend auf dem Kontext anpassen, z. B. den von Ihnen hervorgehobenen Text, die Seite, auf der Sie sich befinden, oder den in ein Feld eingegebenen Text.","Webpage":"Webseite","Highlighted text":"Hervorgehobener Text","Text field":"Textfeld","Add context":"Kontext hinzufügen","Choose this to focus the AI response on a specific part of the page.":"Wählen Sie diese Option, damit sich die KI-Antwort auf einen bestimmten Teil der Seite konzentriert.","To use, highlight text on screen first.":"Markieren Sie dazu zuerst den Text auf dem Bildschirm.","Choose this to focus the AI response on text you\'ve typed in a specific field.":"Wählen Sie diese Option, um die KI-Antwort auf Text zu konzentrieren, den Sie in ein bestimmtes Feld eingegeben haben.","To use, click a text field that already contains text.":"Klicken Sie dazu auf ein Textfeld, das bereits Text enthält.","Notifications":"Benachrichtigungen","More notifications":"Weitere Benachrichtigungen","Clear":"Löschen","Clear all":"Alle entfernen","Pin to screen":"An Bildschirm anheften","Hide for 1 Hour":"Für 1 Stunde ausblenden","Hide options":"Optionen ausblenden","Restart":"Neustart","Run automation":"Automatisierung ausführen","Ask me to do any task for you":"Bitten Sie mich, eine Aufgabe für Sie zu erledigen.","Creating a draft...":"Ein Entwurf wird erstellt …","AI Chats":"KI-Chats","Help Content":"Hilfeinhalte","WalkMe Menu":"WalkMe-Menü","Learning Content":"Lerninhalt","Open sidebar":"Seitenleiste öffnen","Set as default":"Als Standard festlegen","The AI will use the information you provide to tailor it\'s responses to you.":"Die KI verwendet die von Ihnen bereitgestellten Informationen für auf Sie zugeschnittene Antworten.","Learn more about how we use your data":"Erfahren Sie mehr darüber, wie wir Ihre Daten verwenden.","You can tell the AI to do things like:\\n* Be opinionated. If a question could have multiple answers, try to give only the best one\\n* Be casual and friendly\\n* Be concise and professional":"Sie können der KI sagen, sie soll Dinge tun wie zum Beispiel:\\n* Seien Sie meinungsstark. Wenn es zu einer Frage mehrere Antworten geben könnte, versuchen Sie, nur die bestmögliche Antwort zu geben.\\n* Seien Sie ungezwungen und freundlich\\n* Seien Sie prägnant und professionell","Delivering only blunt facts or instructions—no filler, no questions, no fluff.":"Nur reine Fakten oder Anweisungen bereitstellen – keine Füllstoffe, keine Fragen, kein Blabla.","Brainstorming support with friendly tone, multiple perspectives, and open-ended prompts.":"Brainstorming-Unterstützung mit freundlichem Ton, mehreren Perspektiven und offenen Eingabeaufforderungen.","Breaking tasks into concise checklists and focusing on fast, action-oriented execution.":"Aufteilung der Aufgaben in prägnante Checklisten und Konzentration auf die schnelle, aktionsorientierte Ausführung.","Framing choices with data-driven pros/cons and clear, strategic recommendations.":"Auswahlen mit datengesteuerten Vor- und Nachteilen und klaren strategischen Empfehlungen umrahmen.","Sources":"Quellen","Personal AI memory":"Persönlicher KI-Speicher","Improve my prompt":"Meine Eingabeaufforderung verbessern","Undo":"Rückgängig","Redo":"Wiederholen","Improving your prompt...":"Wir verbessern Ihre Eingabeaufforderung …","Meet the Action Bar":"Lernen Sie die Aktionsleiste kennen","A secure, company-provided AI tool to improve your daily work.":"Ein sicheres, vom Unternehmen bereitgestelltes KI-Tool zur Verbesserung Ihrer täglichen Arbeit.","What is your role?":"Was ist Ihre Rolle?","Share a little about yourself so the Action Bar can personalize your experience.":"Teilen Sie ein wenig über sich selbst, damit die Aktionsleiste Ihre Erfahrung personalisieren kann.","Example: Sales manager at Acme":"Beispiel: Vertriebsmanager bei Acme","Continue without role":"Ohne Rolle fortfahren","Continue":"Weiter","Chat with AI or explore resources":"Mit KI chatten oder Ressourcen erkunden","Chat with AI for guidance or explore curated company resources to get the help you need.":"Chatten Sie mit KI, um Anleitung zu erhalten oder kuratierte Unternehmensressourcen zu erkunden, um die Hilfe zu erhalten, die Sie benötigen.","Chat with AI":"Mit KI chatten","Chat with AI to ask questions and complete your daily tasks faster.":"Chatten Sie mit KI, um Fragen zu stellen und Ihre täglichen Aufgaben schneller zu erledigen.","Find helpful resources":"Hilfreiche Ressourcen finden","Explore curated company resources and app-specific tips to guide your work.":"Entdecken Sie kuratierte Unternehmensressourcen und App-spezifische Tipps, um Ihre Arbeit zu unterstützen.","Get quick help":"Schnelle Hilfe erhalten","Ask your question":"Stellen Sie Ihre Frage","Action Bar understands what you’re working on":"Die Aktionsleiste versteht, woran Sie arbeiten","Ask AI about this page":"Fragen Sie AI zu dieser Seite","The Action Bar understands what you’re working on and uses that to run quick actions, like editing text, answering questions, or scanning for key details.":"Die Aktionsleiste versteht, woran Sie arbeiten, und verwendet dies, um schnelle Aktionen auszuführen, wie z. B. das Bearbeiten von Text, das Beantworten von Fragen oder das Scannen nach wichtigen Details.","Use ready-made AI tools":"Vorgefertigte AI-Tools verwenden","Run instant actions like Summarize, Proofread, or Translate, all designed to work with what’s on your screen and give you instant, relevant results.":"Führen Sie sofortige Aktionen wie Zusammenfassen, Korrekturlesen oder Übersetzen aus, die alle darauf ausgelegt sind, mit dem zu arbeiten, was sich auf Ihrem Bildschirm befindet, und Ihnen sofortige, relevante Ergebnisse zu liefern.","Create and save your own actions":"Erstellen und speichern Sie Ihre eigenen Aktionen","Not seeing actions or recommendations you need? Turn your favorite prompts into reusable AI actions going forward.":"Sehen Sie Aktionen oder Empfehlungen nicht, die Sie benötigen? Wandeln Sie Ihre Lieblingsaufforderungen in Zukunft in wiederverwendbare KI-Aktionen um.","Turn this into a LinkedIn post":"Verwandeln Sie dies in einen LinkedIn-Beitrag","Draft a response message":"Entwerfen Sie eine Antwortnachricht","Find next steps":"Weitere Schritte ermitteln","Personalize the Action Bar":"Die Aktionsleiste personalisieren","Set the tone, style, display settings, and more to match how you like to work. Once set, the Action Bar will use these preferences automatically.":"Legen Sie den Ton, den Stil, die Anzeigeeinstellungen und mehr so fest, dass sie Ihrer Arbeit entsprechen. Einmal festgelegt, verwendet die Aktionsleiste diese Einstellungen automatisch.","I am a sales agent at Acme corp.":"Ich bin Vertriebsagent bei Acme corp.","I prefer concise answers":"Ich bevorzuge prägnante Antworten","Your privacy comes first":"Ihre Privatsphäre steht an erster Stelle","Your information is processed securely and is never used to train the AI models.":"Ihre Informationen werden sicher verarbeitet und niemals zum Trainieren der KI-Modelle verwendet.","You stay in control":"Sie behalten die Kontrolle","No data training on your content":{"translation":"Keine Verarbeitung Ihrer Inhalte","maxCharacters":34},"Data processed within your company":"Innerhalb Ihres Unternehmens verarbeitete Daten","Saved to memory":"In der Erinnerung gespeichert","Save key information to Memory":"Wichtige Informationen im Speicher sichern","Save key details for later, so the Action Bar can provide more relevant recommendations and support. You control what\'s stored at all times.":"Speichern Sie wichtige Details für später, damit die Aktionsleiste relevantere Empfehlungen und Unterstützung bieten kann. Sie steuern jederzeit, was gespeichert wird.","Customize your Action Bar":"Passen Sie Ihre Aktionsleiste an","Right-click any action to hide tools you don’t need, pin the ones you use most, or edit custom actions to fit how you work.":"Klicken Sie mit der rechten Maustaste auf eine Aktion, um Tools auszublenden, die Sie nicht benötigen, häufig verwendete Tools zu fixieren oder benutzerdefinierte Aktionen zu bearbeiten, um sie an Ihre Arbeitsweise anzupassen.","Manage what the Action Bar remembers":"Verwalten, woran sich die Aktionsleiste erinnert.","Review, edit, delete, or add memories to keep the Action Bar’s saved information accurate and relevant to your work.":"Überprüfen, bearbeiten, löschen oder fügen Sie Erinnerungen hinzu, um die gespeicherten Informationen der Aktionsleiste genau und relevant für Ihre Arbeit zu halten.","Get smart workflow suggestions":"Erhalten Sie intelligente Workflow-Vorschläge","These actions are provided by your organization and are condition-based, appearing automatically when relevant to your page or task.":"Diese Aktionen werden von Ihrer Organisation bereitgestellt und basieren auf Bedingungen. Sie werden automatisch angezeigt, wenn sie für Ihre Seite oder Aufgabe relevant sind.","Start tour":"Tour starten","Skip tour":"Tour überspringen","AI Chat":"AI-Chat","Resources":"Ressourcen","Reading Tools":"Lesewerkzeuge","Summarize":{"translation":"Kurzfassung","maxCharacters":12},"Writing Tools":"Schreibwerkzeuge","Change Tone":"Ton ändern","Improve":"Verbessern","Secure processing":"Sichere Verarbeitung","Account renewal due Dec 10":"Kontoverlängerung fällig am 10. Dezember","Finance lead: Sarah Kim":"Finanzleitung: Sarah Kim","Save key details for smarter recommendations. Managed by you.":"Speichern Sie wichtige Details für intelligentere Empfehlungen. Von Ihnen verwaltet.","AI Action":"KI-Aktion","Right-click an action to pin, hide, or edit your workspace.":"Klicken Sie mit der rechten Maustaste auf eine Aktion, um Ihren Arbeitsbereich zu heften, auszublenden oder zu bearbeiten.","I am a sales agent":"Ich bin Vertriebsmitarbeiter","Set your role and communication preferences to match how you like to work.":"Legen Sie Ihre Rolle und Kommunikationspräferenzen so fest, dass sie Ihrer Arbeitsweise entsprechen.","Keep saved information accurate and relevant to your work.":"Halten Sie gespeicherte Informationen präzise und arbeitsrelevant.","Turn this into a post":"Verwandeln Sie dies in einen Beitrag","Draft a message":"Entwerfen Sie eine Nachricht","Save your go-to prompts":"Speichern Sie Ihre Eingabeaufforderungen","Not seeing what you need? Turn your favorite prompts into reusable AI actions.":"Sehen Sie nicht, was Sie brauchen? Wandeln Sie Ihre Lieblingsaufforderungen in wiederverwendbare KI-Aktionen um.","Ask your question...":"Stellen Sie Ihre Frage...","Action Bar understands context":"Die Aktionsleiste versteht den Kontext","The Action Bar uses your page to answer questions, scan for key details or edit text.":"Die Aktionsleiste verwendet Ihre Seite, um Fragen zu beantworten, nach wichtigen Details zu suchen oder Text zu bearbeiten.","Designed to work with what\'s on your screen and give you instant, relevant results.":"Entwickelt, um mit dem zu arbeiten, was sich auf Ihrem Bildschirm befindet, und Ihnen sofortige, relevante Ergebnisse zu liefern.","Provided by your organization and appear when relevant to your page or task.":"Von Ihrer Organisation bereitgestellt und angezeigt, wenn sie für Ihre Seite oder Aufgabe relevant ist.","Unhide Action Bar":"Aktionsleiste einblenden","Tools group":"Werkzeuggruppe","Automatically expand":"Automatisch erweitern","Hide action bar":"Aktionsleiste ausblenden","Hide for 1 hour":"Für 1 Stunde ausblenden","Hide everywhere":"Überall ausblenden","Disabled while \'Hide for 1 hour\' is active":"Deaktiviert, während \'Für 1 Stunde ausblenden\' aktiv ist","Disabled while \'Hide everywhere\' is active":"Deaktiviert, während \'Überall ausblenden\' aktiv ist","Help menu":"Hilfemenü"}')}}]);