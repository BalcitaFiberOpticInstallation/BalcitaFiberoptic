window,(window._walkmeWebpackJP=window._walkmeWebpackJP||[]).push([[72],{1445:function(n){n.exports=JSON.parse('{"Add Launcher":"Thêm Trình khởi chạy","Icon and Name":"Biểu tượng và tên","Name already exists":"Tên đã tồn tại","Name your action...":"Đặt tên cho hành động của bạn...","Prompt":"Nhắc nhở","Type what you want the AI engine to do for you...":"Nhập những gì bạn muốn công cụ AI làm cho bạn...","Visibility settings":"Cài đặt khả năng hiển thị","Display the action only when the":"Chỉ hiển thị hành động khi","highlighted text":"văn bản được tô sáng","webpage":"trang web","input":"đầu vào","is":"là","isn\'t":"không phải là","optional":"tùy chọn","Type the criteria for showing the action":"Nhập các tiêu chí để hiển thị hành động","a question":"một câu hỏi","a code snippet":"một đoạn mã","in Spanish and all caps":"bằng tiếng Tây Ban Nha và tất cả các chữ hoa","a non english text":"một văn bản không phải tiếng Anh","a report":"một báo cáo","a form":"một biểu mẫu","a data table":"bảng dữ liệu","an email":"một email","empty":"trống","incomplete":"không đầy đủ","Show on all apps":"Hiển thị trên tất cả các ứng dụng","Show on this app only":"Chỉ hiển thị trên ứng dụng này","Use this setting when the action is relevant only to the current app you\'re in":"Sử dụng cài đặt này khi hành động chỉ liên quan đến ứng dụng hiện tại bạn đang sử dụng","Use this setting when the action is relevant for any website or app":"Sử dụng cài đặt này khi hành động có liên quan đến bất kỳ trang web hoặc ứng dụng nào","New Action":"Hành động mới","Edit Action":"Chỉnh sửa Hành động","Delete Action":"Xóa hành động","Deleted custom actions cannot be restored.":"Các hành động tùy chỉnh đã xóa không thể được khôi phục.","Delete Custom Action":"Xóa hành động tùy chỉnh","Are you sure you want to delete this custom action?":"Bạn có chắc chắn muốn xóa hành động tùy chỉnh này?","Import":"Nhập","Export":"Xuất","Share your action with coworkers":"Chia sẻ hành động của bạn với đồng nghiệp","The action couldn\'t be uploaded. The file seems to be corrupted or incomplete. Please ask your coworker to export the action again and import the new action.":"Hành động không thể tải lên. Tệp dường như bị hỏng hoặc không đầy đủ. Vui lòng yêu cầu đồng nghiệp của bạn xuất lại hành động và nhập hành động mới.","Cancel":"Hủy bỏ","Close":"Đóng","Save":"Lưu","Save Changes":"Lưu thay đổi","Save and Export":"Lưu và Xuất","Pin":"Pin","Unpin":"Gỡ ghim","Create First Action":"Tạo hành động đầu tiên","Quick Actions Menu":"Menu Hành động Nhanh","Back":"Trở lại","Add new action":"Thêm hành động mới","Default action cannot be edited":"Hành động mặc định không thể chỉnh sửa","Edit":"Chỉnh sửa","Note: Action Bar can display up to 5 actions":"Lưu ý: Thanh hành động có thể hiển thị tối đa 5 hành động","Something went wrong":"Đã xảy ra sự cố","Content generating has failed. Please try again later":"Việc tạo nội dung đã thất bại. Vui lòng thử lại sau","No relevant reference found":"Không tìm thấy tài liệu tham khảo có liên quan","Stop generating":"Ngừng tạo","Copy":"Sao chép","Copied":"Đã sao chép","Copy Prompt":"Nhắc nhở sao chép","Prompt copied":"Đã sao chép lời nhắc","Maximize":"Phóng to","Minimize":"Thu nhỏ","Helpful":"Hữu ích","Unhelpful":"Không hữu ích","Save to Memory":"Lưu vào bộ nhớ","Saved to Memory":"Đã lưu vào bộ nhớ","AI-generated content may be incorrect":"Nội dung do AI tạo có thể không chính xác","Refine":"Tinh chỉnh","Refine...":"Tinh chỉnh...","Refine (eg. add details about...)":"Tinh chỉnh (ví dụ: thêm chi tiết về...)","Generate":"Tạo","Regenerate":"Tái tạo","Insert":"Chèn","Insert Below":"Chèn bên dưới","Select tone":"Chọn tông","Select format":"Chọn định dạng","Select language":"Chọn ngôn ngữ","Go Back":"Quay lại","Replace":"Thay thế","New draft":"Bản nháp mới","Save prompt":"Lưu lời nhắc","Don\'t show this message again":"Không hiển thị thông báo này một lần nữa","Be sure to review carefully before replacing":"Hãy chắc chắn xem xét cẩn thận trước khi thay thế","Be sure to review carefully before inserting":"Hãy chắc chắn xem xét cẩn thận trước khi chèn","Text options":"Tùy chọn văn bản","Working on it...":"Đang nghiên cứu...","The text used for this response":"Văn bản được sử dụng cho câu trả lời này","Share your ideas or ask me anything, and I\'ll generate a first draft to help you out...":"Hãy chia sẻ ý tưởng của bạn hoặc hỏi tôi bất cứ điều gì, và tôi sẽ tạo một bản nháp đầu tiên để giúp bạn...","Share your ideas for editing the selected text, or ask me anything about it...":"Chia sẻ ý tưởng của bạn để chỉnh sửa văn bản đã chọn, hoặc hỏi tôi bất cứ điều gì về nó...","Share your ideas on what you\'d like to write, and I\'ll help you get started...":"Hãy chia sẻ ý tưởng của bạn về những gì bạn muốn viết, và tôi sẽ giúp bạn bắt đầu...","Share your ideas about the selected text, and I\'ll help with editing or writing something new...":"Chia sẻ ý tưởng của bạn về văn bản đã chọn, và tôi sẽ giúp chỉnh sửa hoặc viết một cái gì đó mới...","Share your ideas about the text you focused on, and I\'ll help with editing or writing something new...":"Hãy chia sẻ ý tưởng của bạn về văn bản bạn tập trung vào, và tôi sẽ giúp bạn chỉnh sửa hoặc viết một cái gì đó mới...","Work with:":"Làm việc với:","Remove":"Loại bỏ","Open menu":"Mở menu","Open Joule":"Mở Joule","Help me write":"Giúp tôi viết","See more actions":"Xem thêm các hành động","Show actions":"Hiển thị hành động","Hide actions":"Ẩn hành động","Actions are kept hidden, Expand to view them":"Các hành động được ẩn, Mở rộng để xem chúng","Neutral":"Trung lập","Professional":"Chuyên nghiệp","Casual":"Không trang trọng","Concise":"Súc tích","Free Text":"Văn bản tự do","Email":"Email","Paragraph":"Đoạn","Bullet List":"Danh sách dấu đầu dòng","Numbered List":"Danh sách đánh số","Included context":"Bao gồm ngữ cảnh","This whole page":"Toàn bộ trang này","Change tone":{"translation":"Đổi giọng điệu","maxCharacters":14},"Sound neutral":"Giữ giọng trung lập","Sound professional":"Giữ giọng chuyên nghiệp","Sound casual":"Giữ giọng thân thiện","Sound concise":"Giữ giọng súc tích","Sound engaging":"Tạo ấn tượng hấp dẫn","Sound enthusiastic":"Tạo ấn tượng nhiệt tình","Sound confident":"Tạo ấn tượng tự tin","Translate":"Dịch","English":"Tiếng Anh","French":"Tiếng Pháp","German":"Tiếng Đức","Spanish":"Tiếng Tây Ban Nha","Japanese":"Tiếng Nhật","Hebrew":"Tiếng Do Thái","Korean":"Tiếng Hàn","Chinese":"Tiếng Trung","Portuguese":"Tiếng Bồ Đào Nha","Vietnamese":"Tiếng Việt","Greek":"Tiếng Hy Lạp","Polish":"Tiếng Ba Lan","Change format":"Thay đổi định dạng","Elaborate":"Chi tiết","Shorten":"Rút ngắn","Retry":"Thử lại","Auto Length":"Độ dài tự động","Shorter":"Ngắn","Longer":"Mở rộng","AI analyzes the user input to set the length":"AI phân tích đầu vào của người dùng để đặt độ dài","Icons":"Biểu tượng","Settings":"Cài đặt","Next":"Tiếp theo","Ok, got it":"Ok, hiểu rồi.","Done":"Hoàn tất","Introducing the AI Action Bar":"Giới thiệu Thanh hành động AI","Discover the power of your AI copilot to get the next best actions in the flow of your work.":"Khám phá sức mạnh của trợ lý AI của bạn để đưa ra những hành động tối ưu tiếp theo trong quy trình công việc của bạn.","Upgraded Menu":"Thực đơn nâng cấp","Open the menu to get instant answers to your questions with our conversational AI Chat":"Mở menu để nhận câu trả lời nhanh cho câu hỏi của bạn với Trò chuyện AI của chúng tôi","Draft content from scratch with the help of AI":"Soạn thảo nội dung từ đầu với sự trợ giúp của AI","Highlighted text tools":"Các công cụ văn bản nổi bật","Highlight text to use AI reading and writing tools, including text summarization, translation, and writing editing tools.":"Làm nổi bật văn bản để sử dụng các công cụ đọc và viết AI, bao gồm các công cụ tóm tắt văn bản, dịch thuật và công cụ chỉnh sửa văn bản.","Create your own actions":"Tạo hành động của riêng bạn","Create and save your own personalized prompts for fast reuse whenever text is highlighted on screen.":"Tạo và lưu các lời nhắc được cá nhân hóa của riêng bạn để nhanh chóng sử dụng lại bất cứ khi nào văn bản được tô sáng trên màn hình.","Workflow tools":"Công cụ quy trình làm việc","Get workflow suggestions from your organization in the right place at the right time.":"Nhận đề xuất quy trình làm việc từ tổ chức của bạn ở đúng nơi vào đúng thời điểm.","Text tools":"Công cụ văn bản","More actions":"Thêm hành động","Create new action":"Tạo hành động mới","Edit highlighted text with AI":"Chỉnh sửa văn bản được tô sáng bằng AI","Create and save your own custom prompts":"Tạo và lưu các lời nhắc tùy chỉnh của riêng bạn","My actions":"Hành động của tôi","System actions":"Hành động hệ thống","Contextual Action Bar":"Thanh hành động theo ngữ cảnh","More Settings":"Thêm cài đặt","Text Tools Display":"Hiển thị công cụ văn bản","Some actions, made by your organization will still appear in the action bar":"Một số hành động, do tổ chức của bạn thực hiện, vẫn sẽ xuất hiện trong thanh hành động","Hide always":"Luôn ẩn","Hide on this site":"Ẩn trên trang này","Learn more":"Tìm hiểu thêm","My custom actions":"Hành động tùy chỉnh của tôi","My actions:":"Hành động của tôi:","All apps":"Tất cả ứng dụng","Location-specific":"Địa điểm cụ thể","Replay onboarding guide":"Phát lại hướng dẫn","Smart highlights":"Điểm nổi bật thông minh","Get instant details on people and customers by hovering over highlighted names":"Nhận chi tiết tức thì về mọi người và khách hàng bằng cách di chuột qua các tên được tô sáng","Tone":"Giọng điệu","Format":"Định dạng","Length":"Chiều dài","Language":"Ngôn ngữ","Suggestions":"Đề xuất","Tools":"Công cụ","Add custom action":"Thêm hành động tùy chỉnh","Stop listening":"Ngừng nghe","Use microphone":"Sử dụng micrô","I\'m listening...":"Tôi đang lắng nghe...","Microphone disabled. Please enable it to be heard":"Micrô bị tắt. Vui lòng bật nó để được nghe rõ.","Please enable mic to be heard":"Vui lòng bật micrô để nghe","Hide from bar":"Ẩn khỏi thanh","Add to bar":"Thêm vào thanh","Delete":"Xóa","Refresh":"Làm mới","Rephrase":"Viết lại","No more space in your bar":"Không còn không gian trong thanh của bạn","No actions available":"Không có hành động nào khả dụng","Got It":"Đã hiểu","Don’t show again":"Không hiển thị lại","We noticed you use this action often":"Chúng tôi nhận thấy bạn thường xuyên sử dụng hành động này","To quickly reuse, right-click the action and add to the bar. Undo anytime.":"Để nhanh chóng sử dụng lại, bấm chuột phải vào hành động và thêm vào thanh. Hoàn tác bất cứ lúc nào.","Find your custom action here":"Tìm hành động tùy chỉnh của bạn ở đây","Right-click the action to edit, delete, or hide from the bar.":"Bấm chuột phải vào hành động để chỉnh sửa, xóa hoặc ẩn khỏi thanh.","You can find your hidden action here.":"Bạn có thể tìm thấy hành động ẩn của mình ở đây.","Right click and select ‘Hide from bar’ to undo":"Nhấp chuột phải và chọn ‘Ẩn khỏi thanh’ để hoàn tác","Right-click the action to edit or delete.":"Bấm chuột phải vào hành động để chỉnh sửa hoặc xóa.","Approaching the character limit":"Đang tiến gần đến giới hạn ký tự","Character limit reached":"Đã đạt đến giới hạn ký tự","Add to memory":"Thêm vào bộ nhớ","Add Memory":"Thêm vào bộ nhớ","Add selected text to memory":"Thêm văn bản đã chọn vào bộ nhớ","An error occurred":"Đã xảy ra lỗi","Failed to generate memories":"Không thể tạo bộ nhớ","Scanning this page for memory suggestions...":"Đang quét trang này để tìm các đề xuất bộ nhớ...","Share anything you’d like us to remember to improve future AI responses.":"Chia sẻ bất cứ điều gì bạn muốn chúng tôi nhớ để cải thiện các phản hồi AI trong tương lai.","Type your own memory...":"Nhập bộ nhớ của riêng bạn...","Saved to memory!":"Đã lưu vào bộ nhớ!","Manage information in the AI\'s memory to improve future responses.":"Quản lý thông tin trong bộ nhớ của AI để cải thiện các phản hồi trong tương lai.","Manage Memory":"Quản lý bộ nhớ","Memory":"Bộ nhớ","Memories":"Kỷ niệm","Search...":"Tìm kiếm...","Add new memory...":"Thêm kỷ niệm mới...","Add":"Thêm","Edit memory":"Chỉnh sửa kỷ niệm","Delete memory":"Xóa bộ nhớ","Clear all memories":"Xóa tất cả ký ức","No memories added yet":"Chưa có kỷ niệm nào được thêm vào","Saved memory":"Bộ nhớ đã lưu","Saved in":"Lưu trong","Created date":"Ngày tạo","Updated date":"Ngày cập nhật","Manage memories":"Quản lý kỷ niệm","Generate in chat":"Tạo trong trò chuyện","Sort":"Sắp xếp","Sorted up":"Được sắp xếp lên trên","Sorted down":"Được sắp xếp xuống","Memory updated successfully":"Bộ nhớ đã cập nhật thành công","This will permanently remove all saved memories, and the AI will no longer use it to improve future responses.":"Điều này sẽ xóa vĩnh viễn tất cả các dữ liệu đã lưu và AI sẽ không còn sử dụng chúng để cải thiện các phản hồi trong tương lai.","Right-Click any action":"Bấm chuột phải vào bất kỳ hành động nào","to explore additional options such as hiding it from the bar, adding it into the bar, and making edits.":"để khám phá các tùy chọn bổ sung như ẩn nó khỏi thanh, thêm nó vào thanh và thực hiện chỉnh sửa.","Proactive memory suggestion":"Đề xuất bộ nhớ chủ động","Enable to receive memory suggestion action when the page contains relevant information":"Cho phép nhận hành động đề xuất bộ nhớ khi trang chứa thông tin liên quan","Relevant Memory":"Bộ nhớ liên quan","Enabling this will disable the Hide on this site toggle.":"Bật tính năng này sẽ vô hiệu hóa tính năng Ẩn trên trang web này.","Generating response...":"Đang tạo phản hồi...","Chat response:":"Phản hồi trò chuyện:","Personalization":"Cá nhân hóa","Customization":"Tùy chỉnh","Get better responses by sharing who you are and how you work":"Nhận phản hồi tốt hơn bằng cách chia sẻ bạn là ai và cách bạn làm việc","Introduce yourself to get better, more personalized responses":"Giới thiệu bản thân để nhận được phản hồi tốt hơn, cá nhân hơn","How would you like to be called?":"Bạn muốn được gọi là gì?","Your name":"Tên của bạn","What do you do?":"Bạn làm gì?","Sales agent at Acme":"Đại lý bán hàng tại Acme","How would you like the AI to respond?":"Bạn muốn AI phản ứng thế nào?","Custom":"Tùy chỉnh","Straight Shooter":"Người thẳng thắn","Collaborator":"Cộng tác viên","Task Master":"Người quản lý nhiệm vụ","Decision Advisor":"Cố vấn quyết định","Type your communication preferences...":"Nhập tùy chọn giao tiếp của bạn...","Restore":"Khôi phục","Anything else the AI should know about you?":"Có điều gì khác mà AI nên biết về bạn không?","Job responsibilities, areas of interest, career goals":"Trách nhiệm công việc, lĩnh vực quan tâm, mục tiêu nghề nghiệp","Generating a prompt that matches your role...":"Tạo lời nhắc phù hợp với vai trò của bạn...","Enable personalization":"Bật cá nhân hóa","Run a quick action":"Chạy một hành động nhanh chóng","Hey":"Chào","Ask me anything...":"Hãy hỏi tôi bất cứ điều gì...","Ask me anything about this page...":"Hỏi tôi bất cứ điều gì về trang này...","Ask me anything about the text you highlighted...":"Hỏi tôi bất cứ điều gì về văn bản bạn đã đánh dấu...","Ask me anything about what you typed in the field...":"Hỏi tôi bất cứ điều gì về những gì bạn đã nhập vào trường...","Use":"Sử dụng","Ignore":"Bỏ qua","New webpage identified":"Trang web mới được xác định","New highlighted text identified":"Văn bản được tô sáng mới được xác định","Webpage identified":"Trang web đã được xác định","Highlighted text identified":"Văn bản được tô sáng đã được xác định","Text field identified":"Trường văn bản được xác định","New text field identified":"Trường văn bản mới được xác định","Would you prefer to use this as context for the AI, rather than the webpage?":"Bạn có muốn sử dụng điều này làm ngữ cảnh cho AI thay vì trang web không?","Would you prefer to use this as context for the AI, rather than the previous webpage?":"Bạn có muốn sử dụng điều này làm ngữ cảnh cho AI thay vì trang web trước đó không?","Would you prefer to use this as context for the AI, rather than the text you highlighted earlier?":"Bạn có muốn sử dụng điều này làm bối cảnh cho AI không, thay vì văn bản bạn đã nhấn mạnh trước đó?","Would you prefer to use this as context for the AI, rather than the text in the previous field?":"Bạn có muốn sử dụng điều này làm ngữ cảnh cho AI thay vì văn bản trong trường trước không?","Would you like to use this as context for the AI?":"Bạn có muốn sử dụng điều này làm bối cảnh cho AI không?","The AI can tailor its responses based on context like text you highlight, the page you\'re on, or text you type in a field":"AI có thể điều chỉnh phản hồi của nó dựa trên ngữ cảnh như văn bản bạn tô sáng, trang bạn đang truy cập hoặc văn bản bạn nhập vào một trường","Webpage":"Trang web","Highlighted text":"Văn bản được tô sáng","Text field":"Trường văn bản","Add context":"Thêm ngữ cảnh","Choose this to focus the AI response on a specific part of the page.":"Chọn tùy chọn này để tập trung phản hồi AI vào một phần cụ thể của trang.","To use, highlight text on screen first.":"Để sử dụng, trước tiên hãy tô sáng văn bản trên màn hình.","Choose this to focus the AI response on text you\'ve typed in a specific field.":"Chọn tùy chọn này để tập trung phản hồi AI vào văn bản bạn đã nhập vào một trường cụ thể.","To use, click a text field that already contains text.":"Để sử dụng, nhấp vào một trường văn bản đã chứa văn bản.","Notifications":"Thông báo","More notifications":"Thêm thông báo","Clear":"Xóa","Clear all":"Xóa tất cả","Pin to screen":"Ghim vào màn hình","Hide for 1 Hour":"Ẩn trong 1 giờ","Hide options":"Ẩn tùy chọn","Restart":"Khởi động lại","Run automation":"Chạy tự động hóa","Ask me to do any task for you":"Yêu cầu tôi thực hiện bất kỳ nhiệm vụ nào cho bạn","Creating a draft...":"Tạo một bản nháp...","AI Chats":"Trò chuyện AI","Help Content":"Nội dung trợ giúp","WalkMe Menu":"Menu WalkMe","Learning Content":"Nội dung học tập","Open sidebar":"Mở thanh bên","Set as default":"Đặt làm mặc định","The AI will use the information you provide to tailor it\'s responses to you.":"AI sẽ sử dụng thông tin bạn cung cấp để điều chỉnh phản hồi phù hợp với bạn.","Learn more about how we use your data":"Tìm hiểu thêm về cách chúng tôi sử dụng dữ liệu của bạn","You can tell the AI to do things like:\\n* Be opinionated. If a question could have multiple answers, try to give only the best one\\n* Be casual and friendly\\n* Be concise and professional":"Bạn có thể yêu cầu AI làm những việc như:\\n* Hãy mạnh dạn bày tỏ ý kiến. Nếu một câu hỏi có thể có nhiều câu trả lời, hãy cố gắng chỉ cung cấp câu trả lời tốt nhất\\n* Hãy giản dị và thân thiện\\n* Hãy súc tích và chuyên nghiệp","Delivering only blunt facts or instructions—no filler, no questions, no fluff.":"Chỉ cung cấp các sự kiện thẳng thắn hoặc hướng dẫn — không chi tiết không cần thiết, không câu hỏi, không nội dung thừa.","Brainstorming support with friendly tone, multiple perspectives, and open-ended prompts.":"Hỗ trợ động não với giọng điệu thân thiện, nhiều quan điểm và các lời nhắc mở.","Breaking tasks into concise checklists and focusing on fast, action-oriented execution.":"Chia nhỏ các nhiệm vụ thành danh sách kiểm tra súc tích và tập trung vào việc thực hiện nhanh chóng, định hướng hành động.","Framing choices with data-driven pros/cons and clear, strategic recommendations.":"Đóng khung các lựa chọn với ưu / nhược điểm dựa trên dữ liệu và các khuyến nghị rõ ràng, chiến lược.","Sources":"Nguồn","Personal AI memory":"Bộ nhớ AI cá nhân","Improve my prompt":"Cải thiện lời nhắc của tôi","Undo":"Hoàn tác","Redo":"Làm lại","Improving your prompt...":"Cải thiện lời nhắc của bạn...","Meet the Action Bar":"Giới thiệu Thanh hành động","A secure, company-provided AI tool to improve your daily work.":"Công cụ AI an toàn, do công ty cung cấp để cải thiện công việc hàng ngày của bạn.","What is your role?":"Vai trò của bạn là gì?","Share a little about yourself so the Action Bar can personalize your experience.":"Chia sẻ một chút về bản thân để Thanh hành động có thể cá nhân hóa trải nghiệm của bạn.","Example: Sales manager at Acme":"Ví dụ: Người quản lý bán hàng tại Acme","Continue without role":"Tiếp tục mà không cần vai trò","Continue":"Tiếp tục","Chat with AI or explore resources":"Trò chuyện với AI hoặc khám phá tài nguyên","Chat with AI for guidance or explore curated company resources to get the help you need.":"Trò chuyện với AI để được hướng dẫn hoặc khám phá các tài nguyên của công ty được tuyển chọn để nhận sự giúp đỡ bạn cần.","Chat with AI":"Trò chuyện với AI","Chat with AI to ask questions and complete your daily tasks faster.":"Trò chuyện với AI để đặt câu hỏi và hoàn thành nhiệm vụ hàng ngày của bạn nhanh hơn.","Find helpful resources":"Tìm tài nguyên hữu ích","Explore curated company resources and app-specific tips to guide your work.":"Khám phá các tài nguyên của công ty được tuyển chọn và các mẹo dành riêng cho ứng dụng để hướng dẫn công việc của bạn.","Get quick help":"Nhận trợ giúp nhanh chóng","Ask your question":"Đặt câu hỏi của bạn","Action Bar understands what you’re working on":"Thanh hành động hiểu những gì bạn đang làm việc","Ask AI about this page":"Hỏi AI về trang này","The Action Bar understands what you’re working on and uses that to run quick actions, like editing text, answering questions, or scanning for key details.":"Thanh hành động hiểu những gì bạn đang làm việc và sử dụng điều đó để chạy các hành động nhanh, như chỉnh sửa văn bản, trả lời câu hỏi hoặc quét để tìm các chi tiết chính.","Use ready-made AI tools":"Sử dụng các công cụ AI làm sẵn","Run instant actions like Summarize, Proofread, or Translate, all designed to work with what’s on your screen and give you instant, relevant results.":"Chạy các hành động tức thời như Tóm tắt, Đọc lại hoặc Dịch, tất cả được thiết kế để làm việc với những gì trên màn hình của bạn và cung cấp cho bạn kết quả tức thì, có liên quan.","Create and save your own actions":"Tạo và lưu hành động của riêng bạn","Not seeing actions or recommendations you need? Turn your favorite prompts into reusable AI actions going forward.":"Không thấy hành động hoặc đề xuất bạn cần? Biến lời nhắc yêu thích của bạn thành các hành động AI có thể sử dụng lại trong tương lai.","Turn this into a LinkedIn post":"Biến bài này thành một bài đăng trên LinkedIn","Draft a response message":"Soạn thảo thông điệp phản hồi","Find next steps":"Tìm các bước tiếp theo","Personalize the Action Bar":"Cá nhân hóa Thanh hành động","Set the tone, style, display settings, and more to match how you like to work. Once set, the Action Bar will use these preferences automatically.":"Đặt tông giọng, phong cách, cài đặt hiển thị và hơn thế nữa để phù hợp với cách bạn muốn làm việc. Sau khi được đặt, Thanh hành động sẽ tự động sử dụng các tùy chọn này.","I am a sales agent at Acme corp.":"Tôi là một đại lý bán hàng tại Acme corp.","I prefer concise answers":"Tôi thích câu trả lời súc tích","Your privacy comes first":"Quyền riêng tư của bạn là ưu tiên hàng đầu","Your information is processed securely and is never used to train the AI models.":"Thông tin của bạn được xử lý an toàn và không bao giờ được sử dụng để đào tạo các mô hình AI.","You stay in control":"Bạn giữ quyền kiểm soát","No data training on your content":{"translation":"Không đào tạo dữ liệu nội dung của bạn","maxCharacters":38},"Data processed within your company":"Dữ liệu được xử lý trong công ty của bạn","Saved to memory":"Được lưu vào bộ nhớ","Save key information to Memory":"Lưu thông tin chính vào bộ nhớ","Save key details for later, so the Action Bar can provide more relevant recommendations and support. You control what\'s stored at all times.":"Lưu các chi tiết chính để sử dụng sau này để Thanh hành động có thể cung cấp các khuyến nghị và hỗ trợ có liên quan hơn. Bạn kiểm soát những gì được lưu trữ mọi lúc.","Customize your Action Bar":"Tùy chỉnh Thanh hành động của bạn","Right-click any action to hide tools you don’t need, pin the ones you use most, or edit custom actions to fit how you work.":"Nhấp chuột phải vào bất kỳ hành động nào để ẩn các công cụ bạn không cần, ghim các công cụ bạn sử dụng nhất hoặc chỉnh sửa hành động tùy chỉnh để phù hợp với cách bạn làm việc.","Manage what the Action Bar remembers":"Quản lý những gì Thanh hành động nhớ","Review, edit, delete, or add memories to keep the Action Bar’s saved information accurate and relevant to your work.":"Xem lại, chỉnh sửa, xóa hoặc thêm thông tin để giữ cho thông tin đã lưu của Thanh hành động chính xác và phù hợp với công việc của bạn.","Get smart workflow suggestions":"Nhận đề xuất quy trình làm việc thông minh","These actions are provided by your organization and are condition-based, appearing automatically when relevant to your page or task.":"Những hành động này được tổ chức của bạn cung cấp và dựa trên điều kiện, tự động xuất hiện khi có liên quan đến trang hoặc nhiệm vụ của bạn.","Start tour":"Bắt đầu hướng dẫn ban đầu","Skip tour":"Bỏ qua hướng dẫn ban đầu","AI Chat":"Trò chuyện AI","Resources":"Tài nguyên","Reading Tools":"Công cụ đọc","Summarize":"Tóm tắt","Writing Tools":"Công cụ viết","Change Tone":"Đổi giọng điệu","Improve":"Cải thiện","Secure processing":"Xử lý an toàn","Account renewal due Dec 10":"Gia hạn tài khoản đến hạn vào ngày 10 tháng 12","Finance lead: Sarah Kim":"Trưởng phòng tài chính: Sarah Kim","Save key details for smarter recommendations. Managed by you.":"Lưu các chi tiết chính để đề xuất thông minh hơn. Được bạn quản lý.","AI Action":"Hành động AI","Right-click an action to pin, hide, or edit your workspace.":"Nhấp chuột phải vào một hành động để ghim, ẩn hoặc chỉnh sửa không gian làm việc của bạn.","I am a sales agent":"Tôi là đại lý bán hàng","Set your role and communication preferences to match how you like to work.":"Đặt vai trò và sở thích giao tiếp của bạn để phù hợp với cách bạn muốn làm việc.","Keep saved information accurate and relevant to your work.":"Giữ thông tin đã lưu chính xác và phù hợp với công việc của bạn.","Turn this into a post":"Biến bài này thành một bài đăng","Draft a message":"Soạn thảo thông điệp","Save your go-to prompts":"Lưu lời nhắc ưa thích của bạn","Not seeing what you need? Turn your favorite prompts into reusable AI actions.":"Không thấy những gì bạn cần? Biến lời nhắc yêu thích của bạn thành hành động AI có thể sử dụng lại.","Ask your question...":"Đặt câu hỏi của bạn...","Action Bar understands context":"Thanh công cụ hiểu ngữ cảnh","The Action Bar uses your page to answer questions, scan for key details or edit text.":"Thanh hành động sử dụng trang của bạn để trả lời câu hỏi, quét các chi tiết chính hoặc chỉnh sửa văn bản.","Designed to work with what\'s on your screen and give you instant, relevant results.":"Được thiết kế để làm việc với những gì trên màn hình của bạn và cung cấp cho bạn kết quả tức thì, có liên quan.","Provided by your organization and appear when relevant to your page or task.":"Được cung cấp bởi tổ chức của bạn và xuất hiện khi có liên quan đến trang hoặc nhiệm vụ của bạn.","Unhide Action Bar":"Hiện Thanh công cụ","Tools group":"Nhóm công cụ","Automatically expand":"Tự động mở rộng","Hide action bar":"Ẩn thanh hành động","Hide for 1 hour":"Ẩn trong 1 giờ","Hide everywhere":"Ẩn ở mọi nơi","Disabled while \'Hide for 1 hour\' is active":"Bị vô hiệu hóa khi \'Ẩn trong 1 giờ\' đang hoạt động","Disabled while \'Hide everywhere\' is active":"Bị vô hiệu hóa khi \'Ẩn ở mọi nơi\' đang hoạt động","Help menu":"Menu trợ giúp"}')}}]);