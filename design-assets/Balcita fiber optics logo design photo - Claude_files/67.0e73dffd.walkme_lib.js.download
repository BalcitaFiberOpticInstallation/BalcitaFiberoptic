window,(window._walkmeWebpackJP=window._walkmeWebpackJP||[]).push([[67],{1440:function(e){e.exports=JSON.parse('{"Add Launcher":"Ajouter un Launcher","Icon and Name":"Icône et nom","Name already exists":"Le nom existe déjà","Name your action...":"Nommez votre action...","Prompt":"Invite","Type what you want the AI engine to do for you...":"Saisissez ce que vous souhaitez que le moteur d\'IA fasse pour vous...","Visibility settings":"Paramètres de visibilité","Display the action only when the":"Afficher l\'action uniquement lorsque le","highlighted text":"texte surligné","webpage":"page web","input":"saisie","is":"est","isn\'t":"n\'est pas","optional":"en option","Type the criteria for showing the action":"Saisissez les critères pour l\'affichage de l\'action","a question":"une question","a code snippet":"un extrait de code","in Spanish and all caps":"en espagnol et tout en majuscules","a non english text":"un texte non anglais","a report":"un rapport","a form":"un formulaire","a data table":"un tableau de données","an email":"un e-mail","empty":"vide","incomplete":"Incomplet","Show on all apps":"Afficher sur toutes les applications","Show on this app only":"Afficher sur cette application uniquement","Use this setting when the action is relevant only to the current app you\'re in":"Utilisez ce paramètre lorsque l\'action est pertinente uniquement pour l\'application dans laquelle vous vous trouvez","Use this setting when the action is relevant for any website or app":"Utilisez ce paramètre lorsque l\'action est pertinente pour tout site Web ou application","New Action":"Nouvelle action","Edit Action":"Modifier l\'action","Delete Action":"Supprimer l\'action","Deleted custom actions cannot be restored.":"Les actions personnalisées supprimées ne peuvent pas être restaurées.","Delete Custom Action":"Supprimer l\'action personnalisée","Are you sure you want to delete this custom action?":"Êtes-vous bien sûr de vouloir supprimer cette action personnalisée ?","Import":"Importer","Export":"Exporter","Share your action with coworkers":"Partager votre action avec vos collègues","The action couldn\'t be uploaded. The file seems to be corrupted or incomplete. Please ask your coworker to export the action again and import the new action.":"L\'action n\'a pas pu être téléchargée. Le fichier semble être corrompu ou incomplet. Veuillez demander à vos collègues d\'exporter à nouveau l\'action et d\'importer la nouvelle action.","Cancel":"Annuler","Close":"Fermer","Save":"Enregistrer","Save Changes":"Enreg. modifs","Save and Export":"Enregistrer et exporter","Pin":"Épingler","Unpin":"Désépingler","Create First Action":"Créer Première action","Quick Actions Menu":"Menu d\'actions rapides","Back":"Retour","Add new action":"Ajouter une nouvelle action","Default action cannot be edited":"L\'action par défaut ne peut pas être modifiée","Edit":"Modifier","Note: Action Bar can display up to 5 actions":"Remarque : la barre d\'action peut afficher jusqu\'à 5 actions","Something went wrong":"Un problème est survenu","Content generating has failed. Please try again later":"La génération de contenu a échoué. Veuillez essayer à nouveau ultérieurement.","No relevant reference found":"Aucune référence pertinente trouvée","Stop generating":"Arrêter la génération","Copy":"Copier","Copied":"Copié","Copy Prompt":"Copier l\'invite","Prompt copied":"Invite copiée","Maximize":"Maximiser","Minimize":"Minimiser","Helpful":"Utile","Unhelpful":"Inutile","Save to Memory":"Enregistrer en mémoire","Saved to Memory":"Enregistré en mémoire","AI-generated content may be incorrect":"Le contenu généré par l\'IA peut être incorrect","Refine":"Affiner","Refine...":"Affiner...","Refine (eg. add details about...)":"Affiner (par exemple, ajouter des détails à propos de...)","Generate":"Générer","Regenerate":"Régénérer","Insert":"Insérer","Insert Below":"Insérer ci-dessous","Select tone":"Sélectionner le ton","Select format":"Sélectionner le format","Select language":"Sélectionner la langue","Go Back":"Retour","Replace":"Remplacer","New draft":"Nouveau brouillon","Save prompt":"Enregistrer l\'invite","Don\'t show this message again":"Ne plus afficher ce message","Be sure to review carefully before replacing":"Assurez-vous de vérifier attentivement avant tout remplacement","Be sure to review carefully before inserting":"Assurez-vous de vérifier attentivement avant toute insertion","Text options":"Options de texte","Working on it...":"Génération en cours...","The text used for this response":"Le texte utilisé pour cette réponse","Share your ideas or ask me anything, and I\'ll generate a first draft to help you out...":"Partagez vos idées ou demandez-moi n\'importe quoi, et je générerai une première ébauche pour vous aider...","Share your ideas for editing the selected text, or ask me anything about it...":"Partagez vos idées pour modifier le texte sélectionné ou demandez-moi tout ce que vous souhaitez à son sujet...","Share your ideas on what you\'d like to write, and I\'ll help you get started...":"Partagez vos idées sur ce que vous souhaitez écrire et je vous aiderai à démarrer...","Share your ideas about the selected text, and I\'ll help with editing or writing something new...":"Partagez vos idées sur le texte sélectionné et je vous aiderai à le modifier ou à écrire quelque chose de nouveau...","Share your ideas about the text you focused on, and I\'ll help with editing or writing something new...":"Partagez vos idées sur le texte sur lequel vous travaillez, et je vous aiderai à le modifier ou à écrire quelque chose de nouveau…","Work with:":"Travailler avec :","Remove":"Supprimer","Open menu":"Ouvrir le menu","Open Joule":"Ouvrir Joule","Help me write":"Aidez-moi à rédiger","See more actions":"Afficher plus d’actions","Show actions":"Afficher les actions","Hide actions":"Masquer les actions","Actions are kept hidden, Expand to view them":"Les actions sont maintenues masquées, développer pour les afficher","Neutral":"Neutre","Professional":"Professionnel","Casual":"Décontracté","Concise":"Concis","Free Text":"Texte gratuit","Email":"E-mail","Paragraph":"Paragraphe","Bullet List":"Liste à puces","Numbered List":"Liste numérotée","Included context":"Contexte inclus","This whole page":"Toute cette page","Change tone":"Modifier le ton","Sound neutral":"Ton neutre","Sound professional":"Ton professionnel","Sound casual":"Ton décontracté","Sound concise":"Ton concis","Sound engaging":"Avoir l\'air engageant","Sound enthusiastic":"Avoir l\'air enthousiaste","Sound confident":"Avoir l\'air confiant","Translate":"Traduire","English":"English","French":"Français","German":"Allemand","Spanish":"Espagnol","Japanese":"Japonais","Hebrew":"Hébreu","Korean":"Coréen","Chinese":"Chinois","Portuguese":"Portugais","Vietnamese":"Vietnamien","Greek":"Grec","Polish":"Polonais","Change format":"Modifier le format","Elaborate":"Élaborer","Shorten":"Raccourcir","Retry":"Réessayer","Auto Length":"Longueur auto","Shorter":"Court","Longer":"Élaboré","AI analyzes the user input to set the length":"L\'IA analyse la saisie de l’utilisateur pour définir la longueur","Icons":"Icônes","Settings":"Paramètres","Next":"Suivant","Ok, got it":"D\'accord, compris","Done":"Terminé","Introducing the AI Action Bar":"Présentation de la barre d\'action de l\'IA","Discover the power of your AI copilot to get the next best actions in the flow of your work.":"Découvrez la puissance de votre copilote IA pour obtenir les prochaines meilleures actions dans le cadre de votre travail.","Upgraded Menu":"Menu amélioré","Open the menu to get instant answers to your questions with our conversational AI Chat":"Ouvrez le menu pour obtenir des réponses instantanées à vos questions avec notre chat IA conversationnel","Draft content from scratch with the help of AI":"Créez du contenu à partir de zéro avec l\'aide de l\'IA","Highlighted text tools":"Outils de surlignage de texte","Highlight text to use AI reading and writing tools, including text summarization, translation, and writing editing tools.":"Surlignez le texte pour utiliser les outils de lecture et d\'écriture basés sur l\'IA, y compris le résumé de texte, la traduction et les outils d\'édition d\'écriture.","Create your own actions":"Créez vos actions","Create and save your own personalized prompts for fast reuse whenever text is highlighted on screen.":"Créez et enregistrez vos propres invites personnalisées pour une réutilisation rapide chaque fois que le texte est surligné à l\'écran.","Workflow tools":"Outils de flux de tâches","Get workflow suggestions from your organization in the right place at the right time.":"Obtenez des suggestions de flux de travail de votre organisation au bon endroit au bon moment.","Text tools":"Outils de texte","More actions":"Plus d\'actions","Create new action":"Créer une nouvelle action","Edit highlighted text with AI":"Modifier le texte en surbrillance avec l\'IA","Create and save your own custom prompts":"Créer et enregistrer vos invites personnalisées","My actions":"Mes actions","System actions":"Actions du système","Contextual Action Bar":"Barre d\'action contextuelle","More Settings":"Plus de paramètres","Text Tools Display":"Affichage des outils de texte","Some actions, made by your organization will still appear in the action bar":"Certaines actions réalisées par votre organisation apparaîtront toujours dans la barre d\'action","Hide always":"Toujours masquer","Hide on this site":"Masquer sur ce site","Learn more":"En savoir plus","My custom actions":"Mes actions personnalisées","My actions:":"Mes actions :","All apps":"Toutes les applications","Location-specific":"Spécifique à l\'emplacement","Replay onboarding guide":"Relire guide intégration","Smart highlights":"Faits saillants intelligents","Get instant details on people and customers by hovering over highlighted names":"Obtenir des détails instantanés sur les personnes et les clients en survolant les noms mis en surbrillance","Tone":"Ton","Format":"Format","Length":"Longueur","Language":"Langue","Suggestions":"Suggestions","Tools":"Outils","Add custom action":"Ajouter une action personnalisée","Stop listening":"Arrêter l\'écoute","Use microphone":"Utiliser le microphone","I\'m listening...":"J\'écoute…","Microphone disabled. Please enable it to be heard":"Microphone désactivé. Veuillez l\'activer pour qu\'on puisse vous entendre","Please enable mic to be heard":"Veuillez activer le microphone pour qu\'on puisse vous entendre","Hide from bar":"Masquer de la barre","Add to bar":"Ajouter à la barre","Delete":"Supprimer","Refresh":"Actualiser","Rephrase":"Reformuler","No more space in your bar":"Aucun espace disponible dans votre barre","No actions available":"Aucune action disponible","Got It":"Compris","Don’t show again":"Ne plus afficher","We noticed you use this action often":"Nous avons remarqué que vous utilisez souvent cette action","To quickly reuse, right-click the action and add to the bar. Undo anytime.":"Pour la réutiliser rapidement, faites un clic droit sur l\'action et ajoutez-la à la barre. Vous pouvez annuler cette action à tout moment.","Find your custom action here":"Recherchez une action personnalisée ici","Right-click the action to edit, delete, or hide from the bar.":"Faites un clic droit sur l\'action pour la modifier, la supprimer ou la masquer de la barre.","You can find your hidden action here.":"Votre action masquée se trouve ici.","Right click and select ‘Hide from bar’ to undo":"Faites un clic droit et sélectionnez « Masquer de la barre » pour annuler l\'action","Right-click the action to edit or delete.":"Faites un clic droit sur l\'action pour la modifier ou la supprimer.","Approaching the character limit":"Nous approchons de la limite de caractères","Character limit reached":"Limite de caractères atteinte","Add to memory":"Ajouter à la mémoire","Add Memory":"Ajouter de la mémoire","Add selected text to memory":"Ajoutez le texte sélectionné à la mémoire","An error occurred":"Une erreur s\'est produite","Failed to generate memories":"Échec de la génération de mémoires","Scanning this page for memory suggestions...":"Numérisation de cette page pour des suggestions de mémoire...","Share anything you’d like us to remember to improve future AI responses.":"Partagez tout ce dont vous souhaitez que nous nous souvenions pour améliorer les futures réponses de l\'IA.","Type your own memory...":"Saisissez votre propre mémoire...","Saved to memory!":"Enregistré en mémoire !","Manage information in the AI\'s memory to improve future responses.":"Gérez les informations dans la mémoire de l\'IA pour améliorer les réponses futures.","Manage Memory":"Gérer la mémoire","Memory":"Mémoire","Memories":"Souvenirs","Search...":"Rechercher...","Add new memory...":"Ajoutez une nouvelle mémoire...","Add":"Ajouter","Edit memory":"Modifiez la mémoire","Delete memory":"Supprimer la mémoire","Clear all memories":"Effacer toutes les mémoires","No memories added yet":"Aucune mémoire ajoutée pour le moment","Saved memory":"Mémoire enregistrée","Saved in":"Enregistré dans","Created date":"Date de création","Updated date":"Date de mise à jour","Manage memories":"Gérer les mémoires","Generate in chat":"Générer dans le chat","Sort":"Trier","Sorted up":"Trié vers le haut","Sorted down":"Trié vers le bas","Memory updated successfully":"Mémoire mise à jour avec succès","This will permanently remove all saved memories, and the AI will no longer use it to improve future responses.":"Cela supprimera définitivement toutes les mémoires enregistrées et l\'IA ne les utilisera plus pour améliorer les réponses futures.","Right-Click any action":"Effectuez un clic droit sur n\'importe quelle action","to explore additional options such as hiding it from the bar, adding it into the bar, and making edits.":"pour explorer des options supplémentaires telles que la masquer de la barre, l\'ajouter dans la barre et apporter des modifications.","Proactive memory suggestion":"Suggestion proactive de mémoire","Enable to receive memory suggestion action when the page contains relevant information":"Activer les suggestions de mémoire lorsque la page contient des informations pertinentes","Relevant Memory":"Mémoire pertinente","Enabling this will disable the Hide on this site toggle.":"Activer cette option désactivera le paramètre « Masquer sur ce site ».","Generating response...":"Génération de réponse en cours...","Chat response:":"Réponse au chat :","Personalization":"Personnalisation","Customization":"Personnalisation","Get better responses by sharing who you are and how you work":"Obtenez de meilleures réponses en partageant qui vous êtes et comment vous travaillez","Introduce yourself to get better, more personalized responses":"Présentez-vous pour obtenir de meilleures réponses personnalisées","How would you like to be called?":"Comment souhaitez-vous que l\'on vous appelle ?","Your name":"Votre nom","What do you do?":"Que faites-vous dans la vie ?","Sales agent at Acme":"Agent de vente chez Acme","How would you like the AI to respond?":"Comment souhaitez-vous que l\'IA réponde ?","Custom":"Personnalisé(e)","Straight Shooter":"Franc et direct","Collaborator":"Collaborateur","Task Master":"Responsable des tâches","Decision Advisor":"Conseiller en décisions","Type your communication preferences...":"Saisissez vos préférences de communication...","Restore":"Restaurer","Anything else the AI should know about you?":"Y a-t-il autre chose que l\'IA devrait savoir à votre sujet ?","Job responsibilities, areas of interest, career goals":"Responsabilités professionnelles, domaines d\'intérêt, objectifs de carrière","Generating a prompt that matches your role...":"Génération d\'une invite qui correspond à votre rôle en cours...","Enable personalization":"Activer la personnalisation","Run a quick action":"Exécuter une action rapide","Hey":"Bonjour","Ask me anything...":"Posez-moi une question...","Ask me anything about this page...":"Posez-moi une question sur cette page...","Ask me anything about the text you highlighted...":"Posez-moi toute question sur le texte que vous avez mis en surbrillance...","Ask me anything about what you typed in the field...":"Posez-moi une question sur la valeur saisie dans le champ...","Use":"Utilisation","Ignore":"Ignorer","New webpage identified":"Nouvelle page Web identifiée","New highlighted text identified":"Nouveau texte en surbrillance identifié","Webpage identified":"Page Web identifiée","Highlighted text identified":"Texte en surbrillance identifié","Text field identified":"Champ de texte identifié","New text field identified":"Nouveau champ de texte identifié","Would you prefer to use this as context for the AI, rather than the webpage?":"Préférez-vous utiliser cette option comme contexte pour l\'IA, plutôt que la page Web ?","Would you prefer to use this as context for the AI, rather than the previous webpage?":"Préférez-vous utiliser cela comme contexte pour l\'IA, plutôt que la page Web précédente ?","Would you prefer to use this as context for the AI, rather than the text you highlighted earlier?":"Préférez-vous utiliser cette option comme contexte pour l\'IA, plutôt que le texte que vous avez mis en surbrillance précédemment ?","Would you prefer to use this as context for the AI, rather than the text in the previous field?":"Préférez-vous utiliser cette option comme contexte pour l\'IA, plutôt que le texte du champ précédent ?","Would you like to use this as context for the AI?":"Souhaitez-vous utiliser cette option comme contexte pour l\'IA ?","The AI can tailor its responses based on context like text you highlight, the page you\'re on, or text you type in a field":"L\'IA peut adapter ses réponses en fonction du contexte, comme le texte que vous mettez en surbrillance, la page sur laquelle vous êtes ou le texte que vous saisissez dans un champ","Webpage":"Page Web","Highlighted text":"Texte en surbrillance","Text field":"Champ de texte","Add context":"Ajoutez du contexte","Choose this to focus the AI response on a specific part of the page.":"Choisissez cette option pour concentrer la réponse de l\'IA sur une partie spécifique de la page.","To use, highlight text on screen first.":"Pour utiliser, mettez d\'abord en surbrillance le texte à l\'écran.","Choose this to focus the AI response on text you\'ve typed in a specific field.":"Choisissez cette option pour concentrer la réponse de l\'IA sur le texte que vous avez saisi dans un champ spécifique.","To use, click a text field that already contains text.":"Pour l\'utiliser, cliquez sur un champ de texte qui contient déjà du texte.","Notifications":"Notifications","More notifications":"Plus de notifications","Clear":"Effacer","Clear all":"Tout supprimer","Pin to screen":"Épingler à l\'écran","Hide for 1 Hour":"Masquer pendant 1 heure","Hide options":"Masquer les options","Restart":"Recommencer","Run automation":"Exécuter l\'automatisation","Ask me to do any task for you":"Me demander de faire n\'importe quelle tâche pour vous","Creating a draft...":"Création d\'un brouillon...","AI Chats":"Chats d\'IA","Help Content":"Contenu de l\'aide","WalkMe Menu":"Menu WalkMe","Learning Content":"Contenu d\'apprentissage","Open sidebar":"Ouvrir la barre latérale","Set as default":"Définir par défaut","The AI will use the information you provide to tailor it\'s responses to you.":"L\'IA utilisera les informations que vous fournissez pour adapter ses réponses à vos besoins.","Learn more about how we use your data":"En savoir plus sur la façon dont nous utilisons vos données","You can tell the AI to do things like:\\n* Be opinionated. If a question could have multiple answers, try to give only the best one\\n* Be casual and friendly\\n* Be concise and professional":"Vous pouvez dire à l\'IA de faire des choses comme :\\n* Soyez affirmé. Si une question pourrait avoir plusieurs réponses, essayez de ne donner que la meilleure\\n* Soyez décontracté et amical\\n* Soyez concis et professionnel","Delivering only blunt facts or instructions—no filler, no questions, no fluff.":"Seuls des faits ou des instructions directes sont donnés : aucun remplissage, aucune question, aucun superflu.","Brainstorming support with friendly tone, multiple perspectives, and open-ended prompts.":"Support pour le brainstorming avec un ton convivial, plusieurs perspectives et des invites ouvertes.","Breaking tasks into concise checklists and focusing on fast, action-oriented execution.":"Décomposition des tâches en listes de contrôle concises et concentration sur une exécution rapide et orientée vers l\'action.","Framing choices with data-driven pros/cons and clear, strategic recommendations.":"Cadrage des choix avec des avantages et des inconvénients basés sur les données et des recommandations stratégiques claires.","Sources":"Sources","Personal AI memory":"Mémoire d\'IA personnelle","Improve my prompt":"Améliorer ma demande","Undo":"Annuler","Redo":"Refaire","Improving your prompt...":"Amélioration de votre invite...","Meet the Action Bar":"Découvrir la barre d\'action","A secure, company-provided AI tool to improve your daily work.":"Un outil d\'IA sécurisé fourni par l\'entreprise pour améliorer votre travail quotidien.","What is your role?":"Quel est votre rôle ?","Share a little about yourself so the Action Bar can personalize your experience.":"Fournissez quelques informations à votre sujet afin que la barre d\'action puisse personnaliser votre expérience.","Example: Sales manager at Acme":"Exemple : gestionnaire des ventes chez Acme","Continue without role":"Continuer sans rôle","Continue":"Poursuivre","Chat with AI or explore resources":"Discuter avec l\'IA ou explorer les ressources","Chat with AI for guidance or explore curated company resources to get the help you need.":"Discutez avec l\'IA pour obtenir des conseils ou explorez les ressources sélectionnées par l\'entreprise pour obtenir l\'aide dont vous avez besoin.","Chat with AI":"Discuter avec l\'IA","Chat with AI to ask questions and complete your daily tasks faster.":"Discutez avec l\'IA pour poser des questions et accomplir vos tâches quotidiennes plus rapidement.","Find helpful resources":"Trouver les ressources utiles","Explore curated company resources and app-specific tips to guide your work.":"Explorez des ressources d\'entreprise sélectionnées et des conseils spécifiques aux applications pour vous guider dans votre travail.","Get quick help":"Obtenir une aide rapide","Ask your question":"Poser votre question","Action Bar understands what you’re working on":{"translation":"La barre d’action montre ce que vous faites","maxCharacters":48},"Ask AI about this page":"Consulter l\'IA à propos de cette page","The Action Bar understands what you’re working on and uses that to run quick actions, like editing text, answering questions, or scanning for key details.":"La barre d\'action identifie votre activité et l\'utilise pour exécuter des actions rapides, telles que la modification de texte, la réponse à des questions ou la recherche d\'informations clés.","Use ready-made AI tools":"Utiliser des outils d\'IA prêts à l\'emploi","Run instant actions like Summarize, Proofread, or Translate, all designed to work with what’s on your screen and give you instant, relevant results.":"Exécutez des actions instantanées telles que Résumer, Relire ou Traduire, toutes conçues pour fonctionner avec le contenu de votre écran et vous fournir des résultats pertinents en temps réel.","Create and save your own actions":"Créer et enregistrer vos propres actions","Not seeing actions or recommendations you need? Turn your favorite prompts into reusable AI actions going forward.":"Vous ne voyez pas les actions ou les recommandations dont vous avez besoin ? Transformez vos invites favorites en actions d\'IA réutilisables à l\'avenir.","Turn this into a LinkedIn post":"Convertir ceci en publication LinkedIn","Draft a response message":"Rédiger un message de réponse","Find next steps":"Trouver les prochaines étapes","Personalize the Action Bar":"Personnaliser la barre d\'action","Set the tone, style, display settings, and more to match how you like to work. Once set, the Action Bar will use these preferences automatically.":"Définissez le ton, le style, les paramètres d\'affichage et plus encore, en fonction de vos préférences de travail. Une fois configurée, la barre d\'action utilisera automatiquement ces préférences.","I am a sales agent at Acme corp.":"Je suis un agent de vente chez Acme corp.","I prefer concise answers":"Je préfère des réponses concises","Your privacy comes first":"Votre confidentialité vient en premier","Your information is processed securely and is never used to train the AI models.":"Vos informations sont traitées de manière sécurisée et ne sont jamais utilisées pour entraîner les modèles d\'IA.","You stay in control":"Vous êtes aux commandes","No data training on your content":{"translation":"Aucune formation sur vos données","maxCharacters":34},"Data processed within your company":"Données traitées dans votre entreprise","Saved to memory":"Enregistré dans la mémoire","Save key information to Memory":"Enregistrer les informations clés dans la mémoire","Save key details for later, so the Action Bar can provide more relevant recommendations and support. You control what\'s stored at all times.":"Enregistrez les informations importantes pour plus tard, afin que la barre d\'action puisse vous fournir des recommandations et une assistance plus pertinentes. Vous contrôlez ce qui est stocké à tout moment.","Customize your Action Bar":"Personnaliser votre barre d\'action","Right-click any action to hide tools you don’t need, pin the ones you use most, or edit custom actions to fit how you work.":"Cliquez avec le bouton droit sur n\'importe quelle action pour masquer les outils dont vous n\'avez pas besoin, épingler ceux que vous utilisez le plus souvent ou modifier les actions personnalisées en fonction de votre façon de travailler.","Manage what the Action Bar remembers":"Gérer ce dont la barre d\'action se souvient","Review, edit, delete, or add memories to keep the Action Bar’s saved information accurate and relevant to your work.":"Examinez, modifiez, supprimez ou ajoutez des souvenirs afin de garantir l\'exactitude et la pertinence des informations enregistrées dans la barre d\'action pour votre travail.","Get smart workflow suggestions":"Obtenir des suggestions de flux de travail intelligentes","These actions are provided by your organization and are condition-based, appearing automatically when relevant to your page or task.":"Ces actions sont fournies par votre organisation et sont basées sur des conditions. Elles apparaissent automatiquement lorsqu\'elles sont pertinentes pour votre page ou votre tâche.","Start tour":"Démarrer la visite","Skip tour":"Ignorer la visite","AI Chat":"Chat IA","Resources":"Resources","Reading Tools":"Outils de lecture","Summarize":"Résumer","Writing Tools":"Outils d\'écriture","Change Tone":"Modifier le ton","Improve":"Améliorer","Secure processing":"Traitement sécurisé","Account renewal due Dec 10":"Renouvellement du compte le 10 décembre","Finance lead: Sarah Kim":"Responsable des finances : Sarah Kim","Save key details for smarter recommendations. Managed by you.":"Enregistrer les détails clés pour des recommandations plus intelligentes. Géré par vous.","AI Action":"Action de l\'IA","Right-click an action to pin, hide, or edit your workspace.":"Effectuez un clic droit sur une action pour épingler, masquer ou modifier votre espace de travail.","I am a sales agent":"Je suis un agent de vente","Set your role and communication preferences to match how you like to work.":"Définissez votre rôle et vos préférences de communication en fonction de la façon dont vous souhaitez travailler.","Keep saved information accurate and relevant to your work.":"Assurez-vous que les informations enregistrées sont exactes et pertinentes pour votre travail.","Turn this into a post":"Transformer cela en une publication","Draft a message":"Rédiger un message","Save your go-to prompts":"Enregistrer vos messages","Not seeing what you need? Turn your favorite prompts into reusable AI actions.":"Vous ne voyez pas ce dont vous avez besoin ? Transformez vos invites favorites en actions d\'IA réutilisables.","Ask your question...":"Posez votre question...","Action Bar understands context":"La barre d\'action comprend le contexte","The Action Bar uses your page to answer questions, scan for key details or edit text.":"La barre d\'action utilise votre page pour répondre à des questions, rechercher des détails clés ou modifier du texte.","Designed to work with what\'s on your screen and give you instant, relevant results.":"Conçu pour fonctionner avec le contenu de votre écran et vous donner des résultats instantanés et pertinents.","Provided by your organization and appear when relevant to your page or task.":"Fournis par votre organisation et apparaissent lorsqu\'ils sont pertinents pour votre page ou votre tâche.","Unhide Action Bar":"Démasquer la barre d\'action","Tools group":"Groupe d\'outils","Automatically expand":"Développer automatiquement","Hide action bar":"Masquer la barre d\'actions","Hide for 1 hour":"Masquer pendant 1 heure","Hide everywhere":"Masquer partout","Disabled while \'Hide for 1 hour\' is active":"Désactivé tant que \'Masquer pendant 1 heure\' est actif","Disabled while \'Hide everywhere\' is active":"Désactivé tant que \'Masquer partout\' est actif","Help menu":"Menu d\'aide"}')}}]);