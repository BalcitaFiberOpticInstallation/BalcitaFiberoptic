window,(window._walkmeWebpackJP=window._walkmeWebpackJP||[]).push([[66],{1439:function(e){e.exports=JSON.parse('{"Add Launcher":"Añadir Launcher","Icon and Name":"Icono y nombre","Name already exists":"El nombre ya existe","Name your action...":"Pon un nombre a tu acción...","Prompt":"Indicación","Type what you want the AI engine to do for you...":"Escribe lo que quieres que el motor de IA haga por ti…","Visibility settings":"Ajustes de visibilidad","Display the action only when the":"Mostrar la acción solo cuando","highlighted text":"el texto resaltado","webpage":"página web","input":"entrada","is":"sea","isn\'t":"no sea","optional":"opcional","Type the criteria for showing the action":"Escribe los criterios para mostrar la acción","a question":"una pregunta","a code snippet":"un fragmento de código","in Spanish and all caps":"en español y en mayúsculas","a non english text":"un texto que no esté en inglés","a report":"un informe","a form":"un formulario","a data table":"una tabla de datos","an email":"un correo electrónico","empty":"vacío","incomplete":"incompleto","Show on all apps":"Mostrar en todas las aplicaciones","Show on this app only":"Mostrar solo en esta aplicación","Use this setting when the action is relevant only to the current app you\'re in":"Usa esta configuración cuando la acción solo sea relevante para la aplicación en la que estés","Use this setting when the action is relevant for any website or app":"Usa esta configuración cuando la acción sea relevante para cualquier sitio web o aplicación","New Action":"Nueva acción","Edit Action":"Editar acción","Delete Action":"Eliminar acción","Deleted custom actions cannot be restored.":"Las acciones personalizadas eliminadas no pueden restaurarse.","Delete Custom Action":"Eliminar acción personalizada","Are you sure you want to delete this custom action?":"¿Seguro que deseas eliminar esta acción personalizada?","Import":"Importar","Export":"Exportar","Share your action with coworkers":"Comparte tu acción con compañeros de trabajo","The action couldn\'t be uploaded. The file seems to be corrupted or incomplete. Please ask your coworker to export the action again and import the new action.":"No se pudo cargar la acción. El archivo parece estar dañado o incompleto. Pide a tu compañero que vuelva a exportar la acción e importa la nueva.","Cancel":"Cancelar","Close":"Cerrar","Save":"Guardar","Save Changes":"Guardar cambios","Save and Export":"Guardar y exportar","Pin":"Anclar","Unpin":"Desanclar","Create First Action":"Crear primera acción","Quick Actions Menu":"Menú de acciones rápidas","Back":"Atrás","Add new action":"Añadir nueva acción","Default action cannot be edited":"La acción predeterminada no se puede editar","Edit":"Editar","Note: Action Bar can display up to 5 actions":"Nota: La barra de acciones puede mostrar hasta cinco acciones","Something went wrong":"Algo salió mal","Content generating has failed. Please try again later":"La generación de contenido ha fallado. Inténtalo de nuevo más tarde","No relevant reference found":"No se encontró ninguna referencia relevante","Stop generating":"Detener la generación","Copy":"Copiar","Copied":"Copiado","Copy Prompt":"Copiar indicación","Prompt copied":"Indicación copiada","Maximize":"Maximizar","Minimize":"Minimizar","Helpful":"Útil","Unhelpful":"Inútil","Save to Memory":"Guardar en memoria","Saved to Memory":"Guardado en memoria","AI-generated content may be incorrect":"El contenido generado por IA puede ser incorrecto","Refine":"Refinar","Refine...":"Refinar...","Refine (eg. add details about...)":"Refinar (por ejemplo, añadir detalles sobre...)","Generate":"Generar","Regenerate":"Volver a generar","Insert":"Insertar","Insert Below":"Insertar abajo","Select tone":"Seleccionar tono","Select format":"Seleccionar formato","Select language":"Seleccionar idioma","Go Back":"Volver","Replace":"Sustituir","New draft":"Nuevo borrador","Save prompt":"Guardar indicación","Don\'t show this message again":"No volver a mostrar este mensaje","Be sure to review carefully before replacing":"Asegúrate de revisar cuidadosamente antes de reemplazar","Be sure to review carefully before inserting":"Asegúrate de revisar detenidamente antes de insertar.","Text options":"Opciones de texto","Working on it...":"Trabajando en ello...","The text used for this response":"El texto utilizado para esta respuesta","Share your ideas or ask me anything, and I\'ll generate a first draft to help you out...":"Comparte tus ideas o pregúntame cualquier cosa, y generaré un primer borrador para ayudarte...","Share your ideas for editing the selected text, or ask me anything about it...":"Comparte tus ideas para editar el texto seleccionado o pregúntame cualquier cosa al respecto...","Share your ideas on what you\'d like to write, and I\'ll help you get started...":"Comparte tus ideas sobre lo que te gustaría escribir, y te ayudaré a empezar...","Share your ideas about the selected text, and I\'ll help with editing or writing something new...":"Comparte tus ideas sobre el texto seleccionado y yo te ayudaré a editar o escribir algo nuevo...","Share your ideas about the text you focused on, and I\'ll help with editing or writing something new...":"Comparte tus ideas sobre el texto en el que te centraste y yo te ayudaré a editar o escribir algo nuevo...","Work with:":"Trabaja con:","Remove":"Eliminar","Open menu":"Abrir menú","Open Joule":"Abrir Joule","Help me write":"Ayúdame a escribir","See more actions":"Ver más acciones","Show actions":"Mostrar acciones","Hide actions":"Ocultar acciones","Actions are kept hidden, Expand to view them":"Las acciones están ocultas. Amplía para verlas","Neutral":"Neutral","Professional":"Profesional","Casual":"Informal","Concise":"Breve","Free Text":"Texto libre","Email":"Correo electrónico","Paragraph":"Párrafo","Bullet List":"Lista con viñetas","Numbered List":"Lista numerada","Included context":"Contexto incluido","This whole page":"Toda esta página","Change tone":"Cambiar tono","Sound neutral":"Sonar neutro","Sound professional":"Sonar profesional","Sound casual":"Sonar informal","Sound concise":"Sonar breve","Sound engaging":"Suena atractivo","Sound enthusiastic":"Sonar entusiasta","Sound confident":"Sonar seguro","Translate":"Traducir","English":"Inglés","French":"Francés","German":"Alemán","Spanish":"Español","Japanese":"Japonés","Hebrew":"Hebreo","Korean":"Coreano","Chinese":"Chino","Portuguese":"Portugués","Vietnamese":"Vietnamita","Greek":"Griego","Polish":"Polaco","Change format":"Cambiar formato","Elaborate":"Elaborar","Shorten":"Acortar","Retry":"Reintentar","Auto Length":"Longitud auto","Shorter":"Corto","Longer":"Elaborado","AI analyzes the user input to set the length":"La IA analiza la entrada del usuario para establecer la longitud","Icons":"Iconos","Settings":"Ajustes","Next":"Siguiente","Ok, got it":"De acuerdo, entendido","Done":"Hecho","Introducing the AI Action Bar":"Presentamos la barra de acciones de IA","Discover the power of your AI copilot to get the next best actions in the flow of your work.":"Descubre el poder de tu copiloto de IA para obtener las siguientes acciones recomendadas en el flujo de tu trabajo.","Upgraded Menu":"Menú mejorado","Open the menu to get instant answers to your questions with our conversational AI Chat":"Abre el menú para obtener respuestas instantáneas a tus preguntas con nuestro chat conversacional de IA","Draft content from scratch with the help of AI":"Redacta contenido desde cero con la ayuda de la IA","Highlighted text tools":"Herramientas de texto resaltado","Highlight text to use AI reading and writing tools, including text summarization, translation, and writing editing tools.":"Resalta texto para usar herramientas de lectura y escritura de IA, entre ellas, herramientas de resumen de texto, traducción y edición de escritura.","Create your own actions":"Crea tus propias acciones","Create and save your own personalized prompts for fast reuse whenever text is highlighted on screen.":"Crea y guarda tus propias indicaciones personalizadas para reutilizarlas rápidamente cuando resaltes texto en pantalla.","Workflow tools":"Herramientas de flujo de trabajo","Get workflow suggestions from your organization in the right place at the right time.":"Obtén sugerencias de flujo de trabajo de la organización en el lugar adecuado y en el momento preciso.","Text tools":"Herramientas de texto","More actions":"Más acciones","Create new action":"Crear nueva acción","Edit highlighted text with AI":"Edita el texto resaltado con IA","Create and save your own custom prompts":"Crear y guardar tus propias indicaciones personalizadas","My actions":"Mis acciones","System actions":"Acciones del sistema","Contextual Action Bar":"Barra de acción contextual","More Settings":"Más ajustes","Text Tools Display":"Visualización de las herramientas de texto","Some actions, made by your organization will still appear in the action bar":"Algunas acciones realizadas por tu organización seguirán apareciendo en la barra de acción","Hide always":"Ocultar siempre","Hide on this site":"Ocultar en este sitio","Learn more":"Más información","My custom actions":"Mis acciones personalizadas","My actions:":"Mis acciones:","All apps":"Todas las aplicaciones","Location-specific":"Específicas de ubicación","Replay onboarding guide":"Reproducir la guía de onboarding","Smart highlights":"Destacados inteligentes","Get instant details on people and customers by hovering over highlighted names":"Obtén detalles instantáneos sobre personas y clientes al pasar el cursor sobre los nombres destacados","Tone":"Tono","Format":"Formato","Length":"Longitud","Language":"Idioma","Suggestions":"Sugerencias","Tools":"Herramientas","Add custom action":"Añadir acción personalizada","Stop listening":"Detener la escucha","Use microphone":"Usar micrófono","I\'m listening...":"Estoy escuchando...","Microphone disabled. Please enable it to be heard":"Micrófono desactivado. Actívalo para que te escuche","Please enable mic to be heard":"Activa el micrófono para que te escuche","Hide from bar":"Ocultar de la barra","Add to bar":"Añadir a la barra","Delete":"Eliminar","Refresh":"Actualizar","Rephrase":"Reformular","No more space in your bar":"No hay más espacio en tu barra","No actions available":"No hay acciones disponibles","Got It":"Entendido","Don’t show again":"No mostrar de nuevo","We noticed you use this action often":"Hemos observado que utilizas esta acción con frecuencia","To quickly reuse, right-click the action and add to the bar. Undo anytime.":"Para volver a utilizarla rápidamente, haz clic con el botón derecho en la acción y añádela a la barra. Deshacer en cualquier momento.","Find your custom action here":"Encuentra tu acción personalizada aquí","Right-click the action to edit, delete, or hide from the bar.":"Haz clic con el botón derecho en la acción para editarla, suprimirla u ocultarla de la barra.","You can find your hidden action here.":"Puedes encontrar tu acción oculta aquí.","Right click and select ‘Hide from bar’ to undo":"Haz clic con el botón derecho y selecciona \\"Ocultar de la barra\\" para deshacer.","Right-click the action to edit or delete.":"Haz clic con el botón derecho en la acción para editar o eliminar.","Approaching the character limit":"Acercándose al límite de caracteres","Character limit reached":"Límite de caracteres alcanzado","Add to memory":"Añadir a la memoria","Add Memory":"Añadir Memoria","Add selected text to memory":"Añadir texto seleccionado a la memoria","An error occurred":"Se produjo un error","Failed to generate memories":"No se pudieron generar memorias","Scanning this page for memory suggestions...":"Explorando esta página para buscar sugerencias de memoria...","Share anything you’d like us to remember to improve future AI responses.":"Comparte cualquier cosa que te gustaría que recordemos para mejorar futuras respuestas de la IA.","Type your own memory...":"Escribe tu propia memoria…","Saved to memory!":"¡Guardado en memoria!","Manage information in the AI\'s memory to improve future responses.":"Gestiona la información en la memoria de la IA para mejorar las respuestas futuras.","Manage Memory":"Gestionar memoria","Memory":"Memoria","Memories":"Memorias","Search...":"Buscar...","Add new memory...":"Añadir nueva memoria...","Add":"Añadir","Edit memory":"Editar memoria","Delete memory":"Eliminar memoria","Clear all memories":"Borrar todas las memorias","No memories added yet":"Aún no se han añadido memorias","Saved memory":"Memoria guardada","Saved in":"Guardado en","Created date":"Fecha de creación","Updated date":"Fecha de actualización","Manage memories":"Administrar memorias","Generate in chat":"Generar en chat","Sort":"Ordenar","Sorted up":"Orden ascendente","Sorted down":"Orden descendente","Memory updated successfully":"Memoria actualizada correctamente","This will permanently remove all saved memories, and the AI will no longer use it to improve future responses.":"Esto eliminará permanentemente todas las memorias guardadas y la IA ya no las utilizará para mejorar respuestas futuras.","Right-Click any action":"Haz clic con el botón derecho en cualquier acción","to explore additional options such as hiding it from the bar, adding it into the bar, and making edits.":"para explorar opciones adicionales, como ocultarla de la barra, añadirla a la barra y realizar ediciones.","Proactive memory suggestion":"Sugerencia proactiva de memoria","Enable to receive memory suggestion action when the page contains relevant information":"Activa la recepción de sugerencias de memoria cuando la página contenga información relevante","Relevant Memory":"Memoria relevante","Enabling this will disable the Hide on this site toggle.":"Si se activa esta opción, se desactivará el conmutador Ocultar en este sitio.","Generating response...":"Generando respuesta...","Chat response:":"Respuesta del chat:","Personalization":"Personalización","Customization":"Personalización","Get better responses by sharing who you are and how you work":"Obtén mejores respuestas compartiendo quién eres y cómo trabajas","Introduce yourself to get better, more personalized responses":"Preséntate para obtener respuestas mejores y más personalizadas","How would you like to be called?":"¿Cómo quieres que te llamen?","Your name":"Tu nombre","What do you do?":"¿Qué haces?","Sales agent at Acme":"Agente de ventas de Acme","How would you like the AI to respond?":"¿Cómo quieres que te responda la IA?","Custom":"Personalizado","Straight Shooter":"Persona directa y honesta","Collaborator":"Colaborador","Task Master":"Maestro de tareas","Decision Advisor":"Asesor de decisiones","Type your communication preferences...":"Escribe tus preferencias para las comunicaciones...","Restore":"Restaurar","Anything else the AI should know about you?":"¿Hay algo más que la IA debería saber sobre ti?","Job responsibilities, areas of interest, career goals":"Responsabilidades laborales, áreas de interés, objetivos profesionales","Generating a prompt that matches your role...":"Generando un prompt que coincida con tu rol...","Enable personalization":"Habilitar la personalización","Run a quick action":"Ejecutar una acción rápida","Hey":"Hola","Ask me anything...":"Pregúntame cualquier cosa...","Ask me anything about this page...":"Pregúntame lo que quieras sobre esta página...","Ask me anything about the text you highlighted...":"Pregúntame lo que quieras sobre el texto que has resaltado...","Ask me anything about what you typed in the field...":"Pregúntame lo que quieras sobre lo que has escrito en el campo...","Use":"Uso","Ignore":"Ignorar","New webpage identified":"Nueva página web identificada","New highlighted text identified":"Nuevo texto resaltado identificado","Webpage identified":"Página web identificada","Highlighted text identified":"Texto resaltado identificado","Text field identified":"Campo de texto identificado","New text field identified":"Nuevo campo de texto identificado","Would you prefer to use this as context for the AI, rather than the webpage?":"¿Preferirías utilizarlo como contexto para la IA, en lugar de la página web?","Would you prefer to use this as context for the AI, rather than the previous webpage?":"¿Preferirías utilizarlo como contexto para la IA, en lugar de la página web anterior?","Would you prefer to use this as context for the AI, rather than the text you highlighted earlier?":"¿Preferirías utilizarlo como contexto para la IA, en lugar del texto que has resaltado anteriormente?","Would you prefer to use this as context for the AI, rather than the text in the previous field?":"¿Preferirías utilizarlo como contexto para la IA, en lugar del texto del campo anterior?","Would you like to use this as context for the AI?":"¿Quieres utilizarlo como contexto para la IA?","The AI can tailor its responses based on context like text you highlight, the page you\'re on, or text you type in a field":"La IA puede personalizar sus respuestas en función del contexto, como el texto resaltado, la página en la que estés o el texto que escribas en un campo","Webpage":"Página web","Highlighted text":"Texto resaltado","Text field":"Campo de texto","Add context":"Añadir contexto","Choose this to focus the AI response on a specific part of the page.":"Elige esta opción para centrar la respuesta de la IA sobre una parte específica de la página.","To use, highlight text on screen first.":"Para utilizarlo, resalta primero el texto de la pantalla.","Choose this to focus the AI response on text you\'ve typed in a specific field.":"Elige esta opción para centrar la respuesta de la IA en torno al texto que has escrito en un campo específico.","To use, click a text field that already contains text.":"Para usarlo, haz clic en un campo de texto que ya contenga texto.","Notifications":"Notificaciones","More notifications":"Más notificaciones","Clear":"Borrar","Clear all":"Borrar todo","Pin to screen":"Fijar a la pantalla","Hide for 1 Hour":"Ocultar durante 1 hora","Hide options":"Ocultar opciones","Auto expand bar":"Barra de expansión automática","Action bar display":{"translation":"Vista de la barra de acción","maxCharacters":29},"Restart":"Reiniciar","Run automation":"Ejecutar automatización","Ask me to do any task for you":"Pídeme que haga alguna tarea por ti","Creating a draft...":"Creando un borrador...","AI Chats":"Chats de IA","Help Content":"Contenido de ayuda","WalkMe Menu":"Menú WalkMe","Learning Content":"Contenido de Learning","Open sidebar":"Abrir barra lateral","Set as default":"Establecer como predeterminado","The AI will use the information you provide to tailor it\'s responses to you.":"La IA utilizará la información que proporcionas para adaptar sus respuestas a ti.","Learn more about how we use your data":"Más información sobre cómo utilizamos tus datos","You can tell the AI to do things like:\\n* Be opinionated. If a question could have multiple answers, try to give only the best one\\n* Be casual and friendly\\n* Be concise and professional":"Puedes decirle a la IA que haga cosas como:\\n* Tener opiniones firmes. Si una pregunta podría tener varias respuestas, intentar dar solo la mejor opción\\n* Ser informal y amable\\n* Ser conciso y profesional","Delivering only blunt facts or instructions—no filler, no questions, no fluff.":"Proporcionar solo hechos o instrucciones claros: sin información poco relevante, sin preguntas, sin florituras.","Brainstorming support with friendly tone, multiple perspectives, and open-ended prompts.":"Asistencia para lluvia de ideas con un tono amable, distintas perspectivas e indicaciones abiertas.","Breaking tasks into concise checklists and focusing on fast, action-oriented execution.":"Dividir las tareas en listas de verificación concisas y concentrarse en una ejecución rápida y orientada a la acción.","Framing choices with data-driven pros/cons and clear, strategic recommendations.":"Enmarcar decisiones con pros y contras basados en datos y recomendaciones claras y estratégicas.","Sources":"Fuentes","Personal AI memory":"Memoria personal de IA","Improve my prompt":"Mejorar mi solicitud","Undo":"Deshacer","Redo":"Rehacer","Improving your prompt...":"Mejorando tu indicación...","Meet the Action Bar":"Conoce la Barra de acción","A secure, company-provided AI tool to improve your daily work.":"Una herramienta de IA segura proporcionada por la empresa para mejorar tu trabajo diario.","What is your role?":"¿Cuál es tu función?","Share a little about yourself so the Action Bar can personalize your experience.":"Comparte un poco sobre ti para que la Barra de acción pueda personalizar tu experiencia.","Example: Sales manager at Acme":"Ejemplo: Gerente de ventas en Acme","Continue without role":"Continuar sin función","Continue":"Continuar","Chat with AI or explore resources":"Chatea con IA o explora los recursos","Chat with AI for guidance or explore curated company resources to get the help you need.":"Chatea con IA para obtener orientación o explora los recursos seleccionados de la empresa para obtener la ayuda que necesitas.","Chat with AI":"Chat con IA","Chat with AI to ask questions and complete your daily tasks faster.":"Chatea con IA para hacer preguntas y realizar tus tareas diarias más rápido.","Find helpful resources":"Busca recursos útiles","Explore curated company resources and app-specific tips to guide your work.":"Explora los recursos seleccionados de la empresa y los consejos específicos de aplicaciones para orientar tu trabajo.","Get quick help":"Obtén ayuda rápida","Ask your question":"Haz tu pregunta","Action Bar understands what you’re working on":"La barra de acción entiende en qué estás trabajando","Ask AI about this page":"Pregunta a la IA sobre esta página","The Action Bar understands what you’re working on and uses that to run quick actions, like editing text, answering questions, or scanning for key details.":"La barra de acción entiende en qué estás trabajando y lo utiliza para ejecutar acciones rápidas, como editar texto, responder preguntas o hacer una búsqueda para encontrar detalles clave.","Use ready-made AI tools":"Usa herramientas de IA listas para usar","Run instant actions like Summarize, Proofread, or Translate, all designed to work with what’s on your screen and give you instant, relevant results.":"Ejecuta acciones instantáneas como Resumir, Revisar o Traducir, todas ellas diseñadas para trabajar con lo que está en tu pantalla y te dan resultados instantáneos y relevantes.","Create and save your own actions":"Crea y guarda tus propias acciones","Not seeing actions or recommendations you need? Turn your favorite prompts into reusable AI actions going forward.":"¿No ves las acciones o recomendaciones que necesitas? Convierte tus indicaciones favoritas en acciones de IA en el futuro.","Turn this into a LinkedIn post":"Convierte esto en una publicación de LinkedIn","Draft a response message":"Redactar un mensaje de respuesta","Find next steps":"Buscar los siguientes pasos","Personalize the Action Bar":"Personaliza la Barra de acción","Set the tone, style, display settings, and more to match how you like to work. Once set, the Action Bar will use these preferences automatically.":"Establece el tono, el estilo, los ajustes de visualización y mucho más para que coincidan con la forma en que te gusta trabajar. Una vez establecida, la Barra de acción utilizará estas preferencias automáticamente.","I am a sales agent at Acme corp.":"Soy un agente de ventas en Acme Corp.","I prefer concise answers":"Prefiero respuestas concisas","Your privacy comes first":"Tu privacidad es lo primero","Your information is processed securely and is never used to train the AI models.":"Tu información se procesa de forma segura y nunca se utiliza para entrenar los modelos de IA.","You stay in control":"Sigues teniendo el control","No data training on your content":"No se entrenan datos con tu contenido","Data processed within your company":"Datos procesados dentro de tu empresa","Saved to memory":"Guardado en la memoria","Save key information to Memory":"Guardar información clave en la memoria","Save key details for later, so the Action Bar can provide more relevant recommendations and support. You control what\'s stored at all times.":"Guarda los detalles clave para más tarde, de modo que la Barra de acción pueda proporcionar recomendaciones y asistencia más relevantes. Controlas lo que se almacena en todo momento","Customize your Action Bar":"Personaliza tu Barra de acción","Right-click any action to hide tools you don’t need, pin the ones you use most, or edit custom actions to fit how you work.":"Haz clic con el botón derecho en cualquier acción para ocultar las herramientas que no necesitas, fija las que más utilizas o edita acciones personalizadas para que se adapten a tu forma de trabajo.","Manage what the Action Bar remembers":"Gestionar lo que recuerda la Barra de acción","Review, edit, delete, or add memories to keep the Action Bar’s saved information accurate and relevant to your work.":"Revisa, edita, elimina o añade memorias para que la información guardada en la Barra de acción sea precisa y relevante para tu trabajo.","Get smart workflow suggestions":"Obtén sugerencias de flujo de trabajo inteligentes","These actions are provided by your organization and are condition-based, appearing automatically when relevant to your page or task.":"Estas acciones las proporciona tu organización y se basan en condiciones, y aparecerán automáticamente cuando sean relevantes para tu página o tarea.","Start tour":"Iniciar recorrido","Skip tour":"Omitir recorrido","AI Chat":"Chat de IA","Resources":"Resources","Reading Tools":"Herramientas de lectura","Summarize":"Resumir","Writing Tools":"Herramientas de escritura","Change Tone":"Cambiar tono","Improve":"Mejorar","Secure processing":"Procesamiento seguro","Account renewal due Dec 10":"Renovación de cuenta prevista el 10 dic.","Finance lead: Sarah Kim":"Directora financiera: Sarah Kim","Save key details for smarter recommendations. Managed by you.":"Guarda detalles clave y obtén recomendaciones más inteligentes. Gestionados por ti.","AI Action":"Acción de IA","Right-click an action to pin, hide, or edit your workspace.":"Pulsa el botón derecho en una acción y fija, oculta o edita tu espacio de trabajo.","I am a sales agent":"Soy un agente de ventas","Set your role and communication preferences to match how you like to work.":"Establece tu función y preferencias de comunicación para adaptarlas a tu forma de trabajar.","Keep saved information accurate and relevant to your work.":"Haz que la información guardada sea precisa y relevante para tu trabajo.","Turn this into a post":"Convierte esto en una publicación","Draft a message":"Redacta un mensaje","Save your go-to prompts":"Guarda tus indicaciones favoritas","Not seeing what you need? Turn your favorite prompts into reusable AI actions.":"¿No encuentras lo que necesitas? Convierte tus indicaciones favoritas en acciones de IA reutilizables.","Ask your question...":"Haz tu pregunta...","Action Bar understands context":"La Barra de acción entiende el contexto","The Action Bar uses your page to answer questions, scan for key details or edit text.":"La Barra de acción usa tu página para responder preguntas, buscar detalles clave o editar texto.","Designed to work with what\'s on your screen and give you instant, relevant results.":"Diseñada para funcionar con lo que hay en tu pantalla y te da resultados instantáneos y relevantes.","Provided by your organization and appear when relevant to your page or task.":"Facilitados por tu organización y aparecen cuando son relevantes para tu página o tarea.","Unhide Action Bar":"Mostrar la Barra de acción","Tools group":"Grupo de herramientas","Automatically expand":"Expandir automáticamente","Hide action bar":"Ocultar barra de acciones","Hide for 1 hour":"Ocultar durante 1 hora","Hide everywhere":"Ocultar en todas partes","Disabled while \'Hide for 1 hour\' is active":"Desactivado mientras \'Ocultar durante 1 hora\' está activo","Disabled while \'Hide everywhere\' is active":"Desactivado mientras \'Ocultar en todas partes\' está activo","Help menu":"Menú de ayuda"}')}}]);