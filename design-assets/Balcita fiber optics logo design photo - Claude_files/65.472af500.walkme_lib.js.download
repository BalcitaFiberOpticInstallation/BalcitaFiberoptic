window,window._walkmeWebpackJP&&(window._walkmeWebpackJP=window._walkmeWebpackJP||[]).push([[65],{1438:function(e){e.exports=JSON.parse('{"Add Launcher":"Προσθήκη προγράμματος εκκίνησης","Icon and Name":"Εικονίδιο και όνομα","Name already exists":"Το όνομα υπάρχει ήδη","Name your action...":"Ονομάστε την ενέργειά σας...","Prompt":"Προτροπή","Type what you want the AI engine to do for you...":"Πληκτρολογήστε τι θέλετε να κάνει η ΤΝ για εσάς...","Visibility settings":"Ρυθμίσεις ορατότητας","Display the action only when the":"Εμφάνιση της ενέργειας μόνο όταν","highlighted text":"το επισημασμένο κείμενο","webpage":"η ιστοσελίδα","input":"η είσοδος","is":"αποτελεί","isn\'t":"δεν αποτελεί","optional":"προαιρετική ενέργεια","Type the criteria for showing the action":"Πληκτρολογήστε τα κριτήρια για την εμφάνιση της ενέργειας","a question":"μια ερώτηση","a code snippet":"ένα απόσπασμα κώδικα","in Spanish and all caps":"στα ισπανικά και με κεφαλαία γράμματα","a non english text":"ένα μη αγγλικό κείμενο","a report":"μια αναφορά","a form":"μια φόρμα","a data table":"ένας πίνακας δεδομένων","an email":"ένα email","empty":"κενό","incomplete":"σε ημιτελή κατάσταση","Show on all apps":"Εμφάνιση σε όλες τις εφαρμογές","Show on this app only":"Εμφάνιση μόνο σε αυτήν την εφαρμογή","Use this setting when the action is relevant only to the current app you\'re in":"Χρησιμοποιήστε αυτήν τη ρύθμιση όταν η ενέργεια είναι σχετική μόνο με την τρέχουσα εφαρμογή στην οποία βρίσκεστε","Use this setting when the action is relevant for any website or app":"Χρησιμοποιήστε αυτήν τη ρύθμιση όταν η ενέργεια είναι σχετική με οποιονδήποτε ιστότοπο ή εφαρμογή","New Action":"Νέα ενέργεια","Edit Action":"Επεξεργασία ενέργειας","Delete Action":"Διαγραφή ενέργειας","Deleted custom actions cannot be restored.":"Δεν είναι δυνατή η επαναφορά των διαγραμμένων προσαρμοσμένων ενεργειών.","Delete Custom Action":"Διαγραφή προσαρμοσμένης ενέργειας","Are you sure you want to delete this custom action?":"Είστε βέβαιοι ότι θέλετε να διαγράψετε αυτήν την προσαρμοσμένη ενέργεια;","Import":"Εισαγωγή","Export":"Εξαγωγή","Share your action with coworkers":"Μοιραστείτε την ενέργειά σας με τους συναδέλφους σας","The action couldn\'t be uploaded. The file seems to be corrupted or incomplete. Please ask your coworker to export the action again and import the new action.":"Η ενέργεια δεν ήταν δυνατό να μεταφορτωθεί. Το αρχείο φαίνεται να είναι κατεστραμμένο ή ελλιπές. Ζητήστε από τον συνάδελφό σας να κάνει εκ νέου εξαγωγή της ενέργειας και να εισαγάγει τη νέα ενέργεια.","Cancel":"Ακύρωση","Close":"Κλείσιμο","Save":"Αποθήκευση","Save Changes":"Αποθήκευση αλλαγών","Save and Export":"Αποθήκευση και εξαγωγή","Pin":"Καρφίτσωμα","Unpin":"Ξεκαρφίτσωμα","Create First Action":"Δημ. πρώτης ενέργειας","Quick Actions Menu":"Μενού γρήγορων ενεργειών","Back":"Πίσω","Add new action":"Προσθήκη νέας ενέργειας","Default action cannot be edited":"Δεν είναι δυνατή η επεξεργασία της προεπιλεγμένης ενέργειας","Edit":"Επεξεργασία","Note: Action Bar can display up to 5 actions":"Σημείωση: Η γραμμή ενεργειών μπορεί να εμφανίσει έως και 5 ενέργειες","Something went wrong":"Κάτι πήγε στραβά","Content generating has failed. Please try again later":"Η δημιουργία περιεχομένου απέτυχε. Δοκιμάστε ξανά αργότερα","No relevant reference found":"Δεν βρέθηκε σχετική αναφορά","Stop generating":"Διακοπή δημιουργίας","Copy":"Αντιγραφή","Copied":"Έχει αντιγραφεί","Copy Prompt":"Αντιγραφή προτροπής","Prompt copied":"Η προτροπή αντιγράφηκε","Maximize":"Μεγιστοποίηση","Minimize":"Ελαχιστοποίηση","Helpful":"Χρήσιμο","Unhelpful":"Μη χρήσιμο","Save to Memory":"Αποθήκευση στη μνήμη","Saved to Memory":"Αποθηκεύτηκε στη μνήμη","AI-generated content may be incorrect":"Το περιεχόμενο που δημιουργείται από Τεχνητή Νοημοσύνη ενδέχεται να είναι λανθασμένο.","Refine":"Περιορισμός","Refine...":"Περιορισμός...","Refine (eg. add details about...)":"Περιορισμός (π.χ. προσθέστε λεπτομέρειες σχετικά με...)","Generate":"Δημιουργία","Regenerate":"Επαναδημιουργία","Insert":"Εισαγωγή","Insert Below":"Εισαγωγή παρακάτω","Select tone":"Επιλογή ύφους","Select format":"Επιλογή μορφής","Select language":"Επιλογή γλώσσας","Go Back":"Επιστροφή","Replace":"Αντικατάσταση","New draft":"Νέο προσχέδιο","Save prompt":"Αποθήκευση προτροπής","Don\'t show this message again":"Να μην εμφανιστεί ξανά αυτό το μήνυμα","Be sure to review carefully before replacing":"Βεβαιωθείτε ότι έχετε ελέγξει προσεκτικά πριν από την αντικατάσταση","Be sure to review carefully before inserting":"Βεβαιωθείτε ότι έχετε ελέγξει προσεκτικά πριν από την εισαγωγή","Text options":"Επιλογές κειμένου","Working on it...":"Εργασία σε εξέλιξη...","The text used for this response":"Το κείμενο αυτής της απάντησης","Share your ideas or ask me anything, and I\'ll generate a first draft to help you out...":"Μοιραστείτε τις ιδέες σας ή ρωτήστε με οτιδήποτε και θα δημιουργήσω ένα πρώτο προσχέδιο για να σας βοηθήσω...","Share your ideas for editing the selected text, or ask me anything about it...":"Μοιραστείτε τις ιδέες σας σχετικά με την επεξεργασία του επιλεγμένου κειμένου ή ρωτήστε με οτιδήποτε σχετικά με αυτό...","Share your ideas on what you\'d like to write, and I\'ll help you get started...":"Μοιραστείτε τις ιδέες σας σχετικά με το τι θα θέλατε να γράψετε και θα σας βοηθήσω να ξεκινήσετε...","Share your ideas about the selected text, and I\'ll help with editing or writing something new...":"Μοιραστείτε τις ιδέες σας σχετικά με το επιλεγμένο κείμενο και θα σας βοηθήσω να το επεξεργαστείτε ή να γράψετε κάτι νέο...","Share your ideas about the text you focused on, and I\'ll help with editing or writing something new...":"Μοιραστείτε τις ιδέες σας σχετικά με το κείμενο στο οποίο εστιάσατε και θα σας βοηθήσω να το επεξεργαστείτε ή να γράψετε κάτι νέο...","Work with:":"Εργασία με:","Remove":"Αφαίρεση","Open menu":"Άνοιγμα μενού","Open Joule":"Άνοιγμα Joule","Help me write":"Βοηθήστε με να γράψω","See more actions":"Προβολή περισσότερων ενεργειών","Show actions":"Εμφάνιση ενεργειών","Hide actions":"Απόκρυψη ενεργειών","Actions are kept hidden, Expand to view them":"Οι ενέργειες παραμένουν κρυφές. Επεκτείνετε για προβολή","Neutral":"Ουδέτερο","Professional":"Επαγγελματικό","Casual":"Καθημερινό","Concise":"Συνοπτικό","Free Text":"Ελεύθερο κείμενο","Email":"Email","Paragraph":"Παράγραφος","Bullet List":"Λίστα με κουκκίδες","Numbered List":"Αριθμημένη λίστα","Included context":"Σχετικές πληροφορίες","This whole page":"Ολόκληρη αυτή η σελίδα","Change tone":"Αλλαγή ύφους","Sound neutral":"Ουδέτερο ύφος","Sound professional":"Επαγγελματικό ύφος","Sound casual":"Καθημερινό ύφος","Sound concise":"Συνοπτικό ύφος","Sound engaging":"Ύφος που θέλει να προσελκύσει κάποιον","Sound enthusiastic":"Ενθουσιώδες ύφος","Sound confident":"Ύφος με αυτοπεποίθηση","Translate":"Μετάφραση","English":"Αγγλικά","French":"Γαλλικά","German":"Γερμανικά","Spanish":"Ισπανικά","Japanese":"Ιαπωνικά","Hebrew":"Εβραϊκά","Korean":"Κορεατικά","Chinese":"Κινεζικά","Portuguese":"Πορτογαλικά","Vietnamese":"Βιετναμέζικα","Greek":"Ελληνικά","Polish":"Πολωνικά","Change format":"Αλλαγή μορφής","Elaborate":"Αναλυτική","Shorten":"Συμπιεσμένη","Retry":"Προσπαθήστε ξανά","Auto Length":"Αυτόματο μήκος","Shorter":"Σύντομο","Longer":"Αναλυτικό","AI analyzes the user input to set the length":"Η ΤΝ αναλύει τα δεδομένα του χρήστη για να καθορίσει το μήκος","Icons":"Εικονίδια","Settings":"Ρυθμίσεις","Next":"Επόμενο","Ok, got it":"Εντάξει, κατάλαβα","Done":"Έγινε","Introducing the AI Action Bar":"Παρουσίαση της γραμμής ενεργειών ΤΝ","Discover the power of your AI copilot to get the next best actions in the flow of your work.":"Ανακαλύψτε τη δύναμη του βοηθού τεχνητής νοημοσύνης που διαθέτετε για να αποκτήσετε τις επόμενες καλύτερες ενέργειες στη ροή της εργασίας σας.","Upgraded Menu":"Αναβαθμισμένο μενού","Open the menu to get instant answers to your questions with our conversational AI Chat":"Ανοίξτε το μενού για να λάβετε άμεσες απαντήσεις στις ερωτήσεις σας μέσω της συνομιλίας AI Chat","Draft content from scratch with the help of AI":"Προσχέδια από την αρχή με τη βοήθεια της ΤΝ","Highlighted text tools":"Εργαλεία επισημασμένου κειμένου","Highlight text to use AI reading and writing tools, including text summarization, translation, and writing editing tools.":"Επισημάνετε κείμενο για να χρησιμοποιήσετε εργαλεία ανάγνωσης και γραφής ΤΝ, συμπεριλαμβανομένων των εργαλείων σύνοψης κειμένου, μετάφρασης και επεξεργασίας.","Create your own actions":"Δημιουργήστε τις δικές σας ενέργειες","Create and save your own personalized prompts for fast reuse whenever text is highlighted on screen.":"Δημιουργήστε και αποθηκεύστε τις δικές σας εξατομικευμένες προτροπές για γρήγορη εκ νέου χρήση, κάθε φορά που επισημαίνεται κείμενο στην οθόνη.","Workflow tools":"Εργαλεία ροής εργασιών","Get workflow suggestions from your organization in the right place at the right time.":"Λάβετε προτάσεις ροής εργασίας από τον οργανισμό σας στο σωστό μέρος την κατάλληλη στιγμή.","Text tools":"Εργαλεία κειμένου","More actions":"Περισσότερες ενέργειες","Create new action":"Δημιουργία νέας ενέργειας","Edit highlighted text with AI":"Επεξεργασία επισημασμένου κειμένου με ΤΝ","Create and save your own custom prompts":"Δημιουργήστε και αποθηκεύστε τις δικές σας προσαρμοσμένες προτροπές","My actions":"Οι ενέργειές μου","System actions":"Ενέργειες συστήματος","Contextual Action Bar":"Γραμμή ενεργειών βάσει περιεχομένου","More Settings":"Περισσότερες ρυθμίσεις","Text Tools Display":"Εμφάνιση εργαλείων κειμένου","Some actions, made by your organization will still appear in the action bar":"Ορισμένες ενέργειες, που πραγματοποιήθηκαν από τον οργανισμό σας, θα εξακολουθούν να εμφανίζονται στη γραμμή ενεργειών","Hide always":"Απόκρυψη πάντα","Hide on this site":"Απόκρυψη στον ιστότοπο","Learn more":"Μάθετε περισσότερα","My custom actions":"Προσαρμοσμένες ενέργειες","My actions:":"Οι ενέργειές μου:","All apps":"Όλες οι εφαρμογές","Location-specific":"Με βάση την τοποθεσία","Replay onboarding guide":"Επανάληψη οδηγ. εισαγωγής","Smart highlights":"Έξυπνα χαρακτηριστικά","Get instant details on people and customers by hovering over highlighted names":"Λάβετε άμεσα λεπτομέρειες σχετικά με άτομα και πελάτες, τοποθετώντας τον κέρσορα πάνω από τα επισημασμένα ονόματα","Tone":"Ύφος","Format":"Μορφή","Length":"Μήκος","Language":"Γλώσσα","Suggestions":"Προτάσεις","Tools":"Εργαλεία","Add custom action":"Προσθήκη προσαρμοσμένης ενέργειας","Stop listening":"Διακοπή συνομιλίας","Use microphone":"Χρήση μικροφώνου","I\'m listening...":"Ακούω...","Microphone disabled. Please enable it to be heard":"Το μικρόφωνο είναι απενεργοποιημένο. Ενεργοποιήστε το για να μιλήσετε","Please enable mic to be heard":"Ενεργοποιήστε το μικρόφωνο για να μιλήσετε","Hide from bar":"Απόκρυψη από τη γραμμή","Add to bar":"Προσθήκη στη γραμμή","Delete":"Διαγραφή","Refresh":"Ανανέωση","Rephrase":"Αναδιατύπωση","No more space in your bar":"Η γραμμή είναι γεμάτη","No actions available":"Δεν υπάρχουν διαθέσιμες ενέργειες","Got It":"Κατάλαβα","Don’t show again":"Να μην εμφανιστεί ξανά","We noticed you use this action often":"Παρατηρήσαμε ότι χρησιμοποιείτε συχνά αυτήν την ενέργεια","To quickly reuse, right-click the action and add to the bar. Undo anytime.":"Για γρήγορη εκ νέου χρήση, κάντε δεξί κλικ στην ενέργεια και προσθέστε την στη γραμμή. Αναίρεση οποτεδήποτε.","Find your custom action here":"Βρείτε την προσαρμοσμένη σας ενέργεια εδώ","Right-click the action to edit, delete, or hide from the bar.":"Κάντε δεξί κλικ στην ενέργεια για επεξεργασία, διαγραφή ή απόκρυψη από τη γραμμή.","You can find your hidden action here.":"Μπορείτε να βρείτε την κρυφή σας ενέργεια εδώ.","Right click and select ‘Hide from bar’ to undo":"Κάντε δεξί κλικ και επιλέξτε «Απόκρυψη από τη γραμμή» για αναίρεση","Right-click the action to edit or delete.":"Κάντε δεξί κλικ στην ενέργεια για επεξεργασία ή διαγραφή.","Approaching the character limit":"Φτάνετε στο μέγιστο όριο χαρακτήρων","Character limit reached":"Το μέγιστο όριο χαρακτήρων επιτεύχθηκε","Add to memory":"Προσθήκη στη μνήμη","Add Memory":"Προσθήκη μνήμης","Add selected text to memory":"Προσθήκη επιλεγμένου κειμένου στη μνήμη","An error occurred":"Προέκυψε σφάλμα","Failed to generate memories":"Αποτυχία δημιουργίας μνημών","Scanning this page for memory suggestions...":"Σάρωση αυτής της σελίδας για προτάσεις μνήμης...","Share anything you’d like us to remember to improve future AI responses.":"Πείτε μας οτιδήποτε θέλετε να θυμόμαστε για να βελτιώσουμε τις μελλοντικές απαντήσεις της ΤΝ.","Type your own memory...":"Πληκτρολογήστε τη δική σας μνήμη...","Saved to memory!":"Αποθηκεύτηκε στη μνήμη!","Manage information in the AI\'s memory to improve future responses.":"Διαχειριστείτε πληροφορίες στη μνήμη της ΤΝ για βελτίωση των μελλοντικών απαντήσεων.","Manage Memory":"Διαχείριση μνήμης","Memory":"Μνήμη","Memories":"Μνήμες","Search...":"Αναζήτηση...","Add new memory...":"Προσθήκη νέας μνήμης...","Add":"Προσθήκη","Edit memory":"Επεξεργασία μνήμης","Delete memory":"Διαγραφή μνήμης","Clear all memories":"Διαγραφή όλων των μνημών","No memories added yet":"Δεν έχει προστεθεί ακόμα μνήμη","Saved memory":"Αποθηκευμένη μνήμη","Saved in":"Αποθηκεύτηκε σε","Created date":"Ημερομηνία δημιουργίας","Updated date":"Ημερομηνία ενημέρωσης","Manage memories":"Διαχείριση μνημών","Generate in chat":"Δημιουργία στη συνομιλία","Sort":"Ταξινόμηση","Sorted up":"Ταξινόμηση σε αύξουσα σειρά","Sorted down":"Ταξινόμηση σε φθίνουσα σειρά","Memory updated successfully":"Η μνήμη ενημερώθηκε επιτυχώς","This will permanently remove all saved memories, and the AI will no longer use it to improve future responses.":"Αυτό θα διαγράψει οριστικά όλες τις αποθηκευμένες μνήμες και η ΤΝ δεν θα τις χρησιμοποιεί πλέον για τη βελτίωση μελλοντικών απαντήσεων.","Right-Click any action":"Κάντε δεξί κλικ σε οποιαδήποτε ενέργεια","to explore additional options such as hiding it from the bar, adding it into the bar, and making edits.":"για να εξερευνήσετε πρόσθετες επιλογές, όπως η απόκρυψη από τη γραμμή, η προσθήκη στη γραμμή και η επεξεργασία.","Proactive memory suggestion":"Έξυπνες προτάσεις μνήμης","Enable to receive memory suggestion action when the page contains relevant information":"Ενεργοποίηση λήψης πρότασης μνήμης όταν η σελίδα περιέχει σχετικές πληροφορίες","Relevant Memory":"Σχετική μνήμη","Enabling this will disable the Hide on this site toggle.":"Η ενεργοποίηση αυτής της δυνατότητας θα απενεργοποιήσει την επιλογή Απόκρυψη σε αυτόν τον ιστότοπο.","Generating response...":"Δημιουργία απάντησης...","Chat response:":"Απάντηση συνομιλίας:","Personalization":"Εξατομίκευση","Customization":"Προσαρμογή","Get better responses by sharing who you are and how you work":"Λάβετε καλύτερες απαντήσεις παρέχοντας πληροφορίες για το ποιοι είστε και πώς εργάζεστε","Introduce yourself to get better, more personalized responses":"Συστηθείτε για να λαμβάνετε καλύτερες, πιο εξατομικευμένες απαντήσεις","How would you like to be called?":"Πώς θα θέλατε να σας αποκαλούν;","Your name":"Το όνομά σας","What do you do?":"Τι κάνετε;","Sales agent at Acme":"Αντιπρόσωπος πωλήσεων στην Acme","How would you like the AI to respond?":"Πώς θα θέλατε να ανταποκριθεί η ΤΝ;","Custom":"Με προσαρμογή στον χρήστη","Straight Shooter":"Με αμεσότητα","Collaborator":"Συνεργάτης","Task Master":"Υπεύθυνος εργασιών","Decision Advisor":"Σύμβουλος αποφάσεων","Type your communication preferences...":"Πληκτρολογήστε τις προτιμήσεις επικοινωνίας σας...","Restore":"Επαναφορά","Anything else the AI should know about you?":"Υπάρχει κάτι άλλο που θα πρέπει να γνωρίζει η ΤΝ για εσάς;","Job responsibilities, areas of interest, career goals":"Καθήκοντα εργασίας, τομείς ενδιαφέροντος, επαγγελματικοί στόχοι","Generating a prompt that matches your role...":"Δημιουργία προτροπής που ταιριάζει με τον ρόλο σας...","Enable personalization":"Ενεργοποίηση εξατομίκευσης","Run a quick action":"Εκτέλεση γρήγορης ενέργειας","Hey":"Γεια σας!","Ask me anything...":"Ρώτα με οτιδήποτε...","Ask me anything about this page...":"Ρωτήστε με οτιδήποτε σχετικά με αυτήν τη σελίδα...","Ask me anything about the text you highlighted...":"Ρωτήστε με οτιδήποτε σχετικά με το κείμενο που επισημάνατε...","Ask me anything about what you typed in the field...":"Ρωτήστε με οτιδήποτε σχετικά με αυτά που πληκτρολογήσατε στο πεδίο...","Use":"Χρήση","Ignore":"Παράβλεψη","New webpage identified":"Εντοπίστηκε νέα ιστοσελίδα","New highlighted text identified":"Εντοπίστηκε νέο επισημασμένο κείμενο","Webpage identified":"Εντοπίστηκε ιστοσελίδα","Highlighted text identified":"Εντοπίστηκε επισημασμένο κείμενο","Text field identified":"Εντοπίστηκε πεδίο κειμένου","New text field identified":"Εντοπίστηκε νέο πεδίο κειμένου","Would you prefer to use this as context for the AI, rather than the webpage?":"Θα προτιμούσατε να χρησιμοποιηθεί αυτό το στοιχείο ως πλαίσιο για την ΤΝ αντί για την ιστοσελίδα;","Would you prefer to use this as context for the AI, rather than the previous webpage?":"Θα προτιμούσατε να χρησιμοποιηθεί αυτό το στοιχείο ως πλαίσιο για την ΤΝ αντί για την προηγούμενη ιστοσελίδα;","Would you prefer to use this as context for the AI, rather than the text you highlighted earlier?":"Θα προτιμούσατε να χρησιμοποιηθεί αυτό το στοιχείο ως πλαίσιο για την ΤΝ αντί για το κείμενο που επισημάνατε προηγουμένως;","Would you prefer to use this as context for the AI, rather than the text in the previous field?":"Θα προτιμούσατε να χρησιμοποιηθεί αυτό το στοιχείο ως πλαίσιο για την ΤΝ αντί για το κείμενο στο προηγούμενο πεδίο;","Would you like to use this as context for the AI?":"Θα θέλατε να χρησιμοποιήσετε αυτό το στοιχείο ως πλαίσιο για την ΤΝ;","The AI can tailor its responses based on context like text you highlight, the page you\'re on, or text you type in a field":"Η ΤΝ μπορεί να προσαρμόσει τις απαντήσεις της βάσει του πλαισίου, όπως το κείμενο που επισημαίνετε, τη σελίδα στην οποία βρίσκεστε ή το κείμενο που πληκτρολογείτε σε ένα πεδίο","Webpage":"Ιστοσελίδα","Highlighted text":"Επισημασμένο κείμενο","Text field":"Πεδίο κειμένου","Add context":"Προσθήκη πλαισίου","Choose this to focus the AI response on a specific part of the page.":"Επιλέξτε για να εστιάσει η ΤΝ σε ένα συγκεκριμένο τμήμα της σελίδας.","To use, highlight text on screen first.":"Για χρήση, επισημάνετε πρώτα το κείμενο στην οθόνη.","Choose this to focus the AI response on text you\'ve typed in a specific field.":"Επιλέξτε για να εστιάσει η ΤΝ στο κείμενο που έχετε πληκτρολογήσει σε ένα συγκεκριμένο πεδίο.","To use, click a text field that already contains text.":"Για χρήση, κάντε κλικ σε ένα πεδίο κειμένου που περιέχει ήδη κείμενο.","Notifications":"Κοινοποιήσεις","More notifications":"Περισσότερες ειδοποιήσεις","Clear":"Καθαρισμός","Clear all":"Εκκαθάριση όλων","Pin to screen":"Καρφίτσωμα στην οθόνη","Hide for 1 Hour":"Απόκρυψη για 1 ώρα","Hide options":"Απόκρυψη επιλογών","Restart":"Επανεκκίνηση","Run automation":"Εκτέλεση αυτοματισμού","Ask me to do any task for you":"Ζητήστε μου να εκτελέσω οποιαδήποτε εργασία για εσάς","Creating a draft...":"Δημιουργία προσχεδίου...","AI Chats":"Συνομιλίες ΤΝ","Help Content":"Υλικό υποστήριξης","WalkMe Menu":"Μενού WalkMe","Learning Content":"Εκπαιδευτικό περιεχόμενο","Open sidebar":"Άνοιγμα πλαϊνής γραμμής","Set as default":"Ορισμός ως προεπιλεγμένου","The AI will use the information you provide to tailor it\'s responses to you.":"Η ΤΝ θα χρησιμοποιήσει τις πληροφορίες που παρέχετε για να προσαρμόσει τις απαντήσεις προς εσάς.","Learn more about how we use your data":"Μάθετε περισσότερα σχετικά με τον τρόπο με τον οποίο χρησιμοποιούμε τα δεδομένα σας","You can tell the AI to do things like:\\n* Be opinionated. If a question could have multiple answers, try to give only the best one\\n* Be casual and friendly\\n* Be concise and professional":"Μπορείτε να ζητήσετε από την ΤΝ να κάνει πράγματα όπως:\\n* Εκφράστε τη γνώμη σας. Εάν μια ερώτηση θα μπορούσε να έχει πολλές απαντήσεις, δώστε μόνο την καλύτερη\\n* Διατηρήστε φιλικό και καθημερινό ύφος\\n* Διατηρήστε συνοπτικό και επαγγελματικό ύφος","Delivering only blunt facts or instructions—no filler, no questions, no fluff.":"Παράθεση μόνο των ουσιαστικών γεγονότων ή οδηγιών χωρίς περιττά λόγια, ερωτήσεις ή φλυαρία.","Brainstorming support with friendly tone, multiple perspectives, and open-ended prompts.":"Υποστήριξη ανταλλαγής ιδεών με φιλικό τόνο, πολλαπλές οπτικές γωνίες και ανοικτές προτροπές.","Breaking tasks into concise checklists and focusing on fast, action-oriented execution.":"Κατανομή εργασιών σε συνοπτικές λίστες ελέγχου και εστίαση στην ταχεία, προσανατολισμένη στις δράσεις εκτέλεση.","Framing choices with data-driven pros/cons and clear, strategic recommendations.":"Διαμόρφωση επιλογών με πλεονεκτήματα και μειονεκτήματα βασισμένα σε δεδομένα και με σαφείς, στρατηγικές συστάσεις.","Sources":"Πηγές","Personal AI memory":"Προσωπική μνήμη ΤΝ","Improve my prompt":"Βελτιώστε την προτροπή μου","Undo":"Αναίρεση","Redo":"Επανάληψη","Improving your prompt...":"Βελτίωση της προτροπής σας...","Meet the Action Bar":"Γνωρίστε τη γραμμή ενεργειών","A secure, company-provided AI tool to improve your daily work.":"Ένα ασφαλές, εταιρικό εργαλείο ΤΝ για τη βελτίωση της καθημερινής εργασίας σας.","What is your role?":"Ποιος είναι ο ρόλος σας;","Share a little about yourself so the Action Bar can personalize your experience.":"Μοιραστείτε λίγα στοιχεία για τον εαυτό σας, ώστε η γραμμή ενεργειών να μπορέσει να εξατομικεύσει την εμπειρία σας.","Example: Sales manager at Acme":"Παράδειγμα: Διευθυντής πωλήσεων στην Acme","Continue without role":"Συνέχεια χωρίς ρόλο","Continue":"Συνέχεια","Chat with AI or explore resources":"Συνομιλία με την ΤΝ ή εξερευνήστε πόρους","Chat with AI for guidance or explore curated company resources to get the help you need.":"Συνομιλήστε με την ΤΝ για καθοδήγηση ή εξερευνήστε επιλεγμένους εταιρικούς πόρους για να λάβετε τη βοήθεια που χρειάζεστε.","Chat with AI":"Συνομιλία με AI","Chat with AI to ask questions and complete your daily tasks faster.":"Συνομιλήστε με την ΤΝ για να κάνετε ερωτήσεις και να ολοκληρώσετε τις καθημερινές σας εργασίες γρηγορότερα.","Find helpful resources":"Βρείτε χρήσιμους πόρους","Explore curated company resources and app-specific tips to guide your work.":"Εξερευνήστε επιλεγμένους εταιρικούς πόρους και συμβουλές για συγκεκριμένες εφαρμογές για να καθοδηγήσετε την εργασία σας.","Get quick help":"Λάβετε γρήγορη βοήθεια","Ask your question":"Κάντε την ερώτησή σας","Action Bar understands what you’re working on":"Η γραμμή ενεργειών κατανοεί σε τι εργάζεστε","Ask AI about this page":"Ρωτήστε την ΤΝ σχετικά με αυτήν τη σελίδα","The Action Bar understands what you’re working on and uses that to run quick actions, like editing text, answering questions, or scanning for key details.":"Η γραμμή ενεργειών κατανοεί τι επεξεργάζεστε και το χρησιμοποιεί για την εκτέλεση γρήγορων ενεργειών, όπως επεξεργασία κειμένου, απάντηση σε ερωτήσεις ή σάρωση για βασικές λεπτομέρειες.","Use ready-made AI tools":"Χρησιμοποιήστε έτοιμα εργαλεία ΤΝ","Run instant actions like Summarize, Proofread, or Translate, all designed to work with what’s on your screen and give you instant, relevant results.":"Εκτελέστε άμεσες ενέργειες, όπως Σύνοψη, Διόρθωση ή Μετάφραση, οι οποίες έχουν σχεδιαστεί έτσι ώστε να λειτουργούν με βάση τα στοιχεία που εμφανίζονται στην οθόνη σας και να σας παρέχουν άμεσα, συναφή αποτελέσματα.","Create and save your own actions":"Δημιουργήστε και αποθηκεύστε τις δικές σας ενέργειες","Not seeing actions or recommendations you need? Turn your favorite prompts into reusable AI actions going forward.":"Δεν βλέπετε τις ενέργειες ή τις συστάσεις που χρειάζεστε; Μετατρέψτε τις αγαπημένες σας προτροπές σε επαναχρησιμοποιήσιμες ενέργειες ΤΝ στο μέλλον.","Turn this into a LinkedIn post":"Μετατροπή αυτής της ανάρτησης σε LinkedIn","Draft a response message":"Σύνταξη μηνύματος απάντησης","Find next steps":"Βρείτε τα επόμενα βήματα","Personalize the Action Bar":"Εξατομίκευση της γραμμής ενεργειών","Set the tone, style, display settings, and more to match how you like to work. Once set, the Action Bar will use these preferences automatically.":"Ορίστε τον τόνο, το στυλ, τις ρυθμίσεις εμφάνισης και πολλά άλλα, ώστε να ταιριάζουν με τον τρόπο που θέλετε να εργάζεστε. Μόλις οριστεί, η γραμμή ενεργειών θα χρησιμοποιήσει αυτόματα αυτές τις προτιμήσεις.","I am a sales agent at Acme corp.":"Είμαι αντιπρόσωπος πωλήσεων στην Acme corp.","I prefer concise answers":"Προτιμώ συνοπτικές απαντήσεις","Your privacy comes first":"Το απόρρητό σας έχει προτεραιότητα","Your information is processed securely and is never used to train the AI models.":"Τα δεδομένα σας υποβάλλονται σε επεξεργασία με ασφάλεια και δεν χρησιμοποιούνται ποτέ για την εκπαίδευση μοντέλων ΤΝ.","You stay in control":"Παραμένετε εσείς στον έλεγχο","No data training on your content":{"translation":"Χωρίς εκπαίδευση δεδομένων σας","maxCharacters":32},"Data processed within your company":{"translation":"Δεδομένα σε επεξεργασία εντός της εταιρείας σας","maxCharacters":48},"Saved to memory":"Αποθηκεύτηκε στη μνήμη","Save key information to Memory":"Αποθήκευση βασικών πληροφοριών στη μνήμη","Save key details for later, so the Action Bar can provide more relevant recommendations and support. You control what\'s stored at all times.":"Αποθηκεύστε βασικές λεπτομέρειες για αργότερα, ώστε η γραμμή ενεργειών να μπορεί να παρέχει πιο σχετικές συστάσεις και υποστήριξη. Εσείς ελέγχετε ανά πάσα στιγμή τι αποθηκεύεται.","Customize your Action Bar":"Προσαρμόστε τη γραμμή ενεργειών σας","Right-click any action to hide tools you don’t need, pin the ones you use most, or edit custom actions to fit how you work.":"Κάντε δεξί κλικ σε οποιαδήποτε ενέργεια για να αποκρύψετε εργαλεία που δεν χρειάζεστε, να καρφιτσώσετε αυτά που χρησιμοποιείτε περισσότερο ή να επεξεργαστείτε προσαρμοσμένες ενέργειες ώστε να ταιριάζουν στον τρόπο εργασίας σας.","Manage what the Action Bar remembers":"Διαχείριση τι απομνημονεύει η γραμμή ενεργειών","Review, edit, delete, or add memories to keep the Action Bar’s saved information accurate and relevant to your work.":"Αναθεωρήσετε, επεξεργαστείτε, διαγράψτε ή προσθέστε υπενθυμίσεις, για να διατηρήσετε τις αποθηκευμένες πληροφορίες στη γραμμή ενεργειών ακριβείς και συναφείς με την εργασία σας.","Get smart workflow suggestions":"Λάβετε έξυπνες προτάσεις ροής εργασίας","These actions are provided by your organization and are condition-based, appearing automatically when relevant to your page or task.":"Αυτές οι ενέργειες παρέχονται από τον οργανισμό σας και βασίζονται σε συνθήκες, ενώ εμφανίζονται αυτόματα όταν είναι σχετικές με τη σελίδα ή την εργασία σας.","Start tour":"Έναρξη περιήγησης","Skip tour":"Παράλειψη περιήγησης","AI Chat":"Συνομιλία AI","Resources":"Πόροι","Reading Tools":"Εργαλεία ανάγνωσης","Summarize":"Σύνοψη","Writing Tools":"Εργαλεία γραφής","Change Tone":"Αλλαγή τόνου","Improve":"Βελτίωση","Secure processing":"Ασφαλής επεξεργασία","Account renewal due Dec 10":"Η ανανέωση λογαριασμού λήγει στις 10 Δεκεμβρίου","Finance lead: Sarah Kim":"Επικεφαλής οικονομικών: Sarah Kim","Save key details for smarter recommendations. Managed by you.":"Αποθηκεύστε βασικές λεπτομέρειες για πιο έξυπνες συστάσεις. Είναι υπό τη διαχείρισή σας.","AI Action":"Δράση ΤΝ","Right-click an action to pin, hide, or edit your workspace.":"Κάντε δεξί κλικ σε μια ενέργεια για να καρφιτσώσετε, να αποκρύψετε ή να επεξεργαστείτε τον χώρο εργασίας σας.","I am a sales agent":"Είμαι αντιπρόσωπος πωλήσεων","Set your role and communication preferences to match how you like to work.":"Ορίστε τον ρόλο και τις προτιμήσεις επικοινωνίας σας ώστε να ταιριάζουν με τον τρόπο που θέλετε να εργάζεστε.","Keep saved information accurate and relevant to your work.":"Διατηρήστε τις αποθηκευμένες πληροφορίες ακριβείς και συναφείς με την εργασία σας.","Turn this into a post":"Μετατροπή αυτού του στοιχείου σε ανάρτηση","Draft a message":"Σύνταξη μηνύματος","Save your go-to prompts":"Αποθηκεύστε τις αγαπημένες σας προτροπές","Not seeing what you need? Turn your favorite prompts into reusable AI actions.":"Δεν βλέπετε αυτό που χρειάζεστε; Μετατρέψτε τις αγαπημένες σας προτροπές σε επαναχρησιμοποιήσιμες ενέργειες ΤΝ.","Ask your question...":"Κάντε την ερώτησή σας...","Action Bar understands context":"Η γραμμή ενεργειών κατανοεί το πλαίσιο","The Action Bar uses your page to answer questions, scan for key details or edit text.":"Η γραμμή ενεργειών χρησιμοποιεί τη σελίδα σας για να απαντήσει σε ερωτήσεις, να σαρώσει για βασικές λεπτομέρειες ή να επεξεργαστεί κείμενο.","Designed to work with what\'s on your screen and give you instant, relevant results.":"Σχεδιάστηκε για να λειτουργεί με αυτά που εμφανίζονται στην οθόνη σας και να σας παρέχει άμεσα, σχετικά αποτελέσματα.","Provided by your organization and appear when relevant to your page or task.":"Παρέχεται από τον οργανισμό σας και εμφανίζονται όταν είναι σχετικές με τη σελίδα ή την εργασία σας.","Unhide Action Bar":"Απόκρυψη γραμμής ενεργειών","Tools group":"Ομάδα εργαλείων","Automatically expand":"Αυτόματη επέκταση","Hide action bar":"Απόκρυψη γραμμής ενεργειών","Hide for 1 hour":"Απόκρυψη για 1 ώρα","Hide everywhere":"Απόκρυψη παντού","Disabled while \'Hide for 1 hour\' is active":"Απενεργοποιημένο όσο το \'Απόκρυψη για 1 ώρα\' είναι ενεργό","Disabled while \'Hide everywhere\' is active":"Απενεργοποιημένο όσο το \'Απόκρυψη παντού\' είναι ενεργό","Help menu":"Μενού βοήθειας"}')}}]);